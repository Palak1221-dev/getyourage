---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
---

<Layout 
  title="Server Error - Tooltails.com" 
  description="An unexpected server error occurred. Please try again later."
>
  <div class="max-w-[1200px] mx-auto px-4 py-20 md:py-32 flex flex-col items-center justify-center text-center">
    <h1 class="text-6xl md:text-8xl font-bold tracking-tighter text-ink mb-6 leading-none">
      500
    </h1>
    <h2 class="text-2xl md:text-3xl font-bold text-ink mb-4">
      Something Went Wrong
    </h2>
    <p class="text-lg md:text-xl text-body leading-relaxed max-w-lg mb-10">
      We experienced an unexpected internal server error. Please try refreshing the page or navigating back home.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
      <a href="/" class="w-full sm:w-auto">
        <Button variant="primary" size="lg" class="w-full shadow-lg shadow-link/20">Return Home</Button>
      </a>
      <button onclick="window.location.reload()" class="w-full sm:w-auto">
        <Button variant="secondary" size="lg" class="w-full">Refresh Page</Button>
      </button>
    </div>
  </div>
</Layout>
