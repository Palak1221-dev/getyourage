---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/ui/Button.astro";
---

<Layout 
  title="Contact Support - Tooltails Focus"
  description="Contact support or leave feedback for Tooltails Focus. We would love to hear your suggestions for improving the focus timer."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24">
    <h1 class="text-3xl md:text-4xl font-black tracking-tighter text-ink mb-3 select-none leading-none">
      Contact Focus Support
    </h1>
    <p class="text-base text-body mb-10 max-w-xl select-none leading-relaxed">
      Have a feature suggestion, found a bug in the recovery engine, or want to share your focus streaks? Let us know what you're building.
    </p>

    <!-- Borderless card with soft shadow and padding -->
    <div class="bg-canvas rounded-2xl shadow-[0_12px_40px_rgba(0,0,0,0.015)] dark:shadow-[0_12px_40px_rgba(0,0,0,0.22)] p-6 sm:p-10 select-none">
      <form class="space-y-8">
        
        <!-- Name -->
        <div class="flex flex-col gap-2">
          <label for="contact-name" class="text-xs font-semibold text-mute uppercase tracking-widest">
            My name is
          </label>
          <input 
            type="text" 
            id="contact-name" 
            placeholder="Your Name" 
            required 
            class="w-full h-11 px-4 bg-canvas-soft-2/65 border-0 rounded-lg text-sm text-ink placeholder:text-mute focus:outline-none focus:bg-canvas focus:ring-2 focus:ring-link/20 transition-all select-text shadow-sm"
          />
        </div>

        <!-- Email -->
        <div class="flex flex-col gap-2">
          <label for="contact-email" class="text-xs font-semibold text-mute uppercase tracking-widest">
            You can reply to me at
          </label>
          <input 
            type="email" 
            id="contact-email" 
            placeholder="your@email.com" 
            required 
            class="w-full h-11 px-4 bg-canvas-soft-2/65 border-0 rounded-lg text-sm text-ink placeholder:text-mute focus:outline-none focus:bg-canvas focus:ring-2 focus:ring-link/20 transition-all select-text shadow-sm"
          />
        </div>
        
        <!-- Reason Select -->
        <div class="flex flex-col gap-2">
          <label for="contact-reason" class="text-xs font-semibold text-mute uppercase tracking-widest">
            I am writing regarding
          </label>
          <div class="relative">
            <select 
              id="contact-reason"
              class="w-full h-11 px-4 bg-canvas-soft-2/65 border-0 rounded-lg text-sm text-ink focus:outline-none focus:bg-canvas focus:ring-2 focus:ring-link/20 transition-all cursor-pointer shadow-sm appearance-none"
              required
            >
              <option value="" disabled selected>Select an option...</option>
              <option value="feedback">General Feedback</option>
              <option value="bug">Reporting a bug</option>
              <option value="feature">Requesting a feature</option>
              <option value="other">Other topics</option>
            </select>
            <!-- Custom chevron arrow for select dropdown -->
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-4 text-mute">
              <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
          </div>
        </div>

        <!-- Message -->
        <div class="flex flex-col gap-2">
          <label for="contact-message" class="text-xs font-semibold text-mute uppercase tracking-widest">
            My message
          </label>
          <textarea 
            id="contact-message"
            class="w-full min-h-[160px] p-4 bg-canvas-soft-2/65 border-0 rounded-lg text-sm text-ink placeholder:text-mute focus:outline-none focus:bg-canvas focus:ring-2 focus:ring-link/20 transition-all select-text shadow-sm"
            placeholder="Tell us details..."
            required
          ></textarea>
        </div>

        <!-- Send Button -->
        <div class="pt-2">
          <button 
            type="submit" 
            class="w-full h-12 bg-link text-white hover:bg-link-hover shadow-lg shadow-link/10 active:scale-[0.98] text-sm font-bold rounded-lg transition-all duration-200 cursor-pointer flex items-center justify-center gap-1.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link"
          >
            Send Message
          </button>
        </div>

      </form>
    </div>
  </div>
</Layout>
