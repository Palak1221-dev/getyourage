                <input type="text" id="log-notes" class="w-full h-10 px-3 bg-canvas-soft border border-transparent rounded-sm text-xs text-ink placeholder:text-mute/45 focus:outline-none focus:bg-canvas focus:border-link/30 focus:ring-2 focus:ring-link/5 transition-all duration-200 shadow-sm" placeholder="e.g. Completed chapters 3 & 4" />
              </div>

              <button type="submit" class="w-full h-10 bg-link text-white hover:bg-link-hover active:scale-[0.98] text-sm font-bold rounded-sm border border-link/25 transition-all cursor-pointer">
