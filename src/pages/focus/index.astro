    if (wsTodayFocus) wsTodayFocus.textContent = todayFocusFormatted;

    const wsTodayStreak = document.getElementById('workspace-today-streak');
    if (wsTodayStreak) wsTodayStreak.innerHTML = `<span class="text-warning">🔥</span> ${currentStreak}d`;

    const wsTodayRate = document.getElementById('workspace-today-rate');
    if (wsTodayRate) wsTodayRate.textContent = `${rate}%`;

    // Analytics Page values
    const minutesFocused = Math.round(totalSeconds / 60);
    const h = Math.floor(minutesFocused / 60);
    const m = minutesFocused % 60;
    
    const timeEl = document.getElementById('stat-total-time');
    if (timeEl) timeEl.textContent = `${h}h ${m.toString().padStart(2, '0')}m`;

    const rateEl = document.getElementById('stat-completion-rate');
