---
import Layout from "../../layouts/Layout.astro";
import FAQ from "../../components/ui/FAQ.astro";

// FAQ Items for SEO
const faqItems = [
  {
    question: "What's the difference between this and a regular Pomodoro timer?",
    answer: "A Pomodoro timer just counts down 25-minute blocks. Tooltails Focus flips the question from 'how long did you sit there?' to 'did you actually get it done?'. You write down a real goal before you start, break it into smaller checkpoints, then log whether you finished, partly finished, or hit a wall. It's less about compliance and more about shipping."
  },
  {
    question: "What happens when I mark a session as Partial or Failed?",
    answer: "Instead of guilt, you get a recovery plan. The engine looks at what went wrong — distraction, fatigue, or a goal that was too big — and suggests a practical next step. Maybe shorter blocks, a screen break, or breaking your goal down further. The idea is to learn, not to punish."
  },
  {
    question: "Is my data safe? Do I need an account?",
    answer: "No accounts, no servers, no cloud. Everything — your sessions, streaks, checkpoints, journal entries — lives in your browser's LocalStorage. You can export a backup anytime, but nothing ever leaves your machine unless you choose to save the file."
  },
  {
    question: "How do the ambient sounds work without downloading anything?",
    answer: "Instead of loading audio files, your browser generates the sounds on the fly using the Web Audio API. Brown noise, white noise, and rain are all synthesized in real time. That means zero downloads, zero buffering, and it all works offline."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Tooltails Focus",
  "operatingSystem": "Web",
  "applicationCategory": "ProductivityApplication",
  "description": "Focus on goals, not just time. A premium, offline-first productivity workspace with goal-planning checklist, recovery recommendations, streaks, and GitHub-style heatmaps.",
  "url": "https://tooltails.com/focus",
  "featureList": [
    "Goal-Oriented Focus Timer (Intention over raw seconds)",
    "Checkpoint Decomposer (Milestone checklist)",
    "Cognitive Recovery Coach (Actionable diagnostics)",
    "Synthesized Ambient Sound Engine (Web Audio API)",
    "Offline-first LocalStorage Persistence",
    "Personal Growth & Weekly Reflection Diagnostics"
  ],
  "browserRequirements": "Requires JavaScript. Requires HTML5.",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout 
  title="Focus Goals Timer - Goal-Oriented Productivity Tool | Tooltails" 
  description="Focus on goals, not just time. An offline-first productivity workspace with goal-planning checklist, recovery recommendations, streaks, and GitHub-style heatmaps."
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(appSchema)} />
  <!-- Main View Container -->
  <div class="max-w-[1440px] mx-auto px-3 sm:px-4 py-2 md:py-4 relative">
    
    <span id="global-streak-value" class="hidden">0</span>
    <span id="global-success-rate" class="hidden">0%</span>

    <!-- Minimal header -->
    <div class="flex items-center justify-between mb-4 md:mb-5 select-none">
      <h1 class="text-xl md:text-2xl font-bold tracking-tight text-ink">
        Focus
      </h1>
      <div class="flex items-center gap-1.5 bg-canvas-soft-2/80 rounded-full p-0.5">
        <button id="tab-btn-workspace" class="tab-btn px-4 py-1.5 text-sm font-semibold rounded-full bg-canvas text-ink shadow-sm focus-visible:outline-none transition-all duration-150 cursor-pointer" onclick="switchTab('workspace')" aria-label="Open workspace tab">
          Timer
        </button>
        <button id="tab-btn-analytics" class="tab-btn px-4 py-1.5 text-sm font-semibold rounded-full text-body hover:text-ink transition-all duration-150 cursor-pointer" onclick="switchTab('analytics')" aria-label="Open progress analytics tab">
          Progress
        </button>
        <button id="tab-btn-premium" class="tab-btn px-4 py-1.5 text-sm font-semibold rounded-full text-body hover:text-ink transition-all duration-150 cursor-pointer" onclick="switchTab('premium')" aria-label="Open growth and coaching tab">
          Journal
        </button>
      </div>
    </div>

    <!-- APP CONTENT BODY -->
    
    <!-- TAB 1: WORKSPACE -->
    <div id="tab-workspace" class="transition-all duration-500">
      <!-- Hidden onboarding tracker for LocalStorage warning insertion -->
      <div id="onboarding-tracker" class="hidden" aria-hidden="true"></div>

      <!-- FOCUS WORKSPACE — two-column grid: Setup + Details on left, Timer + Today's Progress on right -->
      <div id="focus-workspace-container" class="max-w-[1320px] mx-auto bg-canvas rounded-2xl transition-all duration-500">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-12 px-4 sm:px-6 lg:px-10 pt-3 sm:pt-4 lg:pt-6 pb-1 md:pb-2">
          
          <!-- LEFT COLUMN: Setup (goal, activity, active info) + Details (why, checkpoints, duration, sound) -->
          <div class="flex flex-col space-y-3 lg:space-y-5 min-w-0">

            <!-- SETUP PANEL (shown in setup mode) -->
            <div id="setup-panel" class="w-full space-y-3 flex flex-col items-center">
              <!-- Session Goal Input — large, inviting, borderless -->
              <div class="w-full">
                <input 
                  type="text" 
                  id="session-goal" 
                  autocomplete="off"
                  spellcheck="true"
                  class="w-full h-11 sm:h-12 lg:h-14 px-5 lg:px-6 bg-canvas-soft/70 rounded-2xl text-base sm:text-lg lg:text-xl font-semibold tracking-tight text-ink placeholder:text-mute/50 focus:outline-none focus:bg-canvas-soft/90 focus:shadow-[0_0_0_3px_rgba(0,0,0,0.05)] transition-all duration-300 select-text text-center md:text-left"
                  placeholder="What do you want to make happen?" 
                  aria-label="What do you want to make happen today?"
                />
              </div>

              <!-- Activity Selector — larger, pill-style cards -->
              <div class="w-full select-none">
                  <span class="text-sm lg:text-base font-medium text-body/70 block mb-2 text-center md:text-left">What kind of work are you doing?</span>
                <div class="flex items-center justify-center md:justify-start gap-2 lg:gap-2.5 flex-wrap">
                  <button type="button" class="activity-btn px-4 lg:px-5 py-1.5 lg:py-2 text-sm lg:text-base rounded-2xl bg-canvas-soft text-body hover:bg-canvas-soft-2 hover:text-ink active:scale-[0.97] transition-all duration-200 cursor-pointer flex items-center gap-1.5 border border-transparent font-medium shadow-sm" data-activity="Coding" aria-label="Select Coding">
                    <span class="text-base">💻</span> Coding
                  </button>
                  <button type="button" class="activity-btn px-4 lg:px-5 py-1.5 lg:py-2 text-sm lg:text-base rounded-2xl bg-canvas-soft text-body hover:bg-canvas-soft-2 hover:text-ink active:scale-[0.97] transition-all duration-200 cursor-pointer flex items-center gap-1 border border-transparent font-medium shadow-sm" data-activity="Study" aria-label="Select Study">
                    <span class="text-base">📚</span> Study
                  </button>
                  <button type="button" class="activity-btn px-4 lg:px-5 py-1.5 lg:py-2 text-sm lg:text-base rounded-2xl bg-canvas-soft text-body hover:bg-canvas-soft-2 hover:text-ink active:scale-[0.97] transition-all duration-200 cursor-pointer flex items-center gap-1 border border-transparent font-medium shadow-sm" data-activity="Reading" aria-label="Select Reading">
                    <span class="text-base">📖</span> Reading
                  </button>
                  <button type="button" class="activity-btn px-4 lg:px-5 py-1.5 lg:py-2 text-sm lg:text-base rounded-2xl bg-canvas-soft text-body hover:bg-canvas-soft-2 hover:text-ink active:scale-[0.97] transition-all duration-200 cursor-pointer flex items-center gap-1 border border-transparent font-medium shadow-sm" data-activity="Writing" aria-label="Select Writing">
                    <span class="text-base">✍️</span> Writing
                  </button>
                  <button type="button" class="activity-btn px-4 lg:px-5 py-1.5 lg:py-2 text-sm lg:text-base rounded-2xl bg-canvas-soft text-body hover:bg-canvas-soft-2 hover:text-ink active:scale-[0.97] transition-all duration-200 cursor-pointer flex items-center gap-1 border border-transparent font-medium shadow-sm" data-activity="Art" aria-label="Select Art">
                    <span class="text-base">🎨</span> Art
                  </button>
                  <button type="button" class="activity-btn px-4 lg:px-5 py-1.5 lg:py-2 text-sm lg:text-base rounded-2xl bg-canvas-soft text-body hover:bg-canvas-soft-2 hover:text-ink active:scale-[0.97] transition-all duration-200 cursor-pointer flex items-center gap-1 border border-transparent font-medium shadow-sm" data-activity="Custom" id="act-btn-custom" aria-label="Select Custom">
                    <span class="text-base">⚙️</span> Custom
                  </button>
                </div>
              </div>

              <!-- Custom Activity Input -->
              <input type="text" id="custom-activity-input" autocomplete="off" class="hidden w-full max-w-xs h-11 px-4 bg-canvas-soft/70 rounded-xl text-base text-ink text-center focus:outline-none focus:bg-canvas-soft/90 focus:shadow-[0_0_0_3px_rgba(0,0,0,0.05)] transition-all duration-200" placeholder="What are you working on?" aria-label="Describe what you are working on" />
              <div id="custom-activity-next-panel" class="hidden"></div>

              <!-- Checkpoints — minimal inline add, unhides below if needed -->
              <div class="hidden" id="setup-milestones-compact">
                <!-- populated via JS if milestones exist -->
              </div>

              <!-- Single Start Action Button (kept hidden for JS event binding) -->
              <button type="button" id="start-session-btn" class="hidden" aria-label="Start Goal Focus Session"></button>
            </div>

            <!-- ACTIVE FOCUS PANEL (shown during session) -->
            <div id="active-info-panel" class="hidden w-full space-y-2 flex flex-col items-center">
              <!-- Activity tag chip -->
              <span id="active-activity-tag" class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-canvas-soft-2 text-mute/70 self-start"></span>
              <!-- Goal title -->
              <h2 id="active-goal-title" class="text-2xl sm:text-3xl lg:text-4xl font-bold tracking-tight text-ink leading-snug text-pretty w-full text-left"></h2>
              <!-- Why this matters -->
              <div id="active-why-matters-panel" class="hidden w-full text-base text-body/80 italic leading-relaxed">
                <span id="active-why-matters-text"></span>
              </div>
              <!-- Current step highlight during active session -->
              <div id="active-current-step-container" class="hidden w-full px-4 py-2 bg-canvas-soft/60 rounded-2xl flex items-center gap-2 select-none">
                <span class="w-1.5 h-1.5 bg-body/50 rounded-full animate-pulse"></span>
                <span class="text-sm text-mute">Right now:</span>
                <span id="active-current-step-text" class="text-xs font-semibold text-ink truncate max-w-[180px]"></span>
              </div>
            </div>

            <!-- Divider (shown only when setup has content) -->
            <div class="w-full h-px bg-hairline/15 my-1.5"></div>

            <!-- DETAILS PANEL (Why, Checkpoints, Duration, Sound — inside the workspace grid) -->
            <div id="setup-panel-below-fold" class="w-full space-y-3 select-none">

              <!-- Why This Matters Input — inline subtle card -->
              <div class="w-full">
                <input 
                  type="text" 
                  id="session-goal-why" 
                  autocomplete="off"
                  spellcheck="true"
                  class="w-full h-11 sm:h-12 lg:h-14 px-5 lg:px-6 bg-canvas-soft/70 rounded-2xl text-base sm:text-lg lg:text-xl font-semibold tracking-tight text-ink placeholder:text-mute/50 focus:outline-none focus:bg-canvas-soft/90 focus:shadow-[0_0_0_3px_rgba(0,0,0,0.05)] transition-all duration-300 select-text text-center md:text-left" 
                  placeholder="What makes this meaningful to you? (optional)" 
                  aria-label="Tell yourself why this goal matters"
                />
              </div>

              <!-- Checkpoints + Duration/Sound in a unified row -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-6">
                
                <!-- Checkpoints (left side on md+) -->
                <div class="space-y-2">
                  <span class="text-sm font-semibold text-body/80 block">Map out your path</span>
                  <div class="flex gap-2">
                  <input 
                    type="text" 
                    id="milestone-input" 
                    autocomplete="off" 
                    class="flex-grow h-11 sm:h-12 lg:h-14 px-5 lg:px-6 bg-canvas-soft/70 rounded-2xl text-base sm:text-lg lg:text-xl font-semibold tracking-tight text-ink placeholder:text-mute/50 focus:outline-none focus:bg-canvas-soft/90 focus:shadow-[0_0_0_3px_rgba(0,0,0,0.05)] transition-all duration-300" 
                    placeholder="Add a step…" 
                    aria-label="Add a checkpoint to your plan" 
                  />
                  <button 
                    type="button" 
                    id="add-milestone-btn" 
                    class="h-11 sm:h-12 lg:h-14 px-5 lg:px-6 bg-link text-white hover:bg-link-hover active:scale-95 text-sm lg:text-base font-semibold rounded-2xl border-0 transition-all duration-150 cursor-pointer focus-visible:ring-2 focus-visible:ring-link/50 focus-visible:outline-none" 
                    aria-label="Add checkpoint to checklist"
                  >
                    Add step
                  </button>
                  </div>

                  <ul id="setup-milestones-list" class="space-y-1 max-h-[140px] overflow-y-auto scrollbar-thin">
                    <li class="flex items-center gap-2 text-sm text-mute/60 py-2 select-none">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 opacity-50"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/><path d="M15 5l3 3"/></svg>
                      What's your first step?
                    </li>
                  </ul>
                </div>

                <!-- Duration presets + Sound (right side on md+) -->
                <div class="space-y-2">
                  <span class="text-sm font-semibold text-body/80 block">Duration &amp; Sound</span>
                  <div class="grid grid-cols-2 gap-2">
                    <button type="button" class="preset-btn py-1.5 lg:py-2 px-3 lg:px-4 rounded-2xl bg-canvas-soft/60 text-body hover:bg-canvas-soft-2 active:scale-[0.98] transition-all duration-200 cursor-pointer font-medium text-sm lg:text-base group" data-focus="25" data-break="5" aria-label="Classic Pomodoro: 25 minutes work focus and 5 minutes rest break">
                      <span class="group-hover:text-link transition-colors tabular-nums">25m</span>
                    </button>
                    <button type="button" class="preset-btn py-1.5 lg:py-2 px-3 lg:px-4 rounded-2xl bg-canvas-soft/60 text-body hover:bg-canvas-soft-2 active:scale-[0.98] transition-all duration-200 cursor-pointer font-medium text-sm lg:text-base group" data-focus="50" data-break="10" aria-label="Extended sprint: 50 minutes work focus and 10 minutes rest break">
                      <span class="group-hover:text-link transition-colors tabular-nums">50m</span>
                    </button>
                    <button type="button" class="preset-btn py-1.5 lg:py-2 px-3 lg:px-4 rounded-2xl bg-canvas-soft/60 text-body hover:bg-canvas-soft-2 active:scale-[0.98] transition-all duration-200 cursor-pointer font-medium text-sm lg:text-base group" data-focus="90" data-break="0" aria-label="Deep Flow sprint: 90 minutes work focus with no rest break">
                      <span class="group-hover:text-link transition-colors tabular-nums">90m</span>
                    </button>
                    <button type="button" class="preset-btn py-1.5 lg:py-2 px-3 lg:px-4 rounded-2xl bg-canvas-soft/60 text-body hover:bg-canvas-soft-2 active:scale-[0.98] transition-all duration-200 cursor-pointer font-medium text-sm lg:text-base group" data-focus="custom" aria-label="Set custom work focus and rest timing block">
                      <span class="group-hover:text-ink transition-colors">Custom</span>
                    </button>
                    <button type="button" class="sound-btn py-1.5 lg:py-2 px-3 lg:px-4 rounded-2xl bg-canvas-soft/60 text-body hover:bg-canvas-soft-2 active:scale-[0.98] transition-all cursor-pointer text-sm lg:text-base font-medium" data-sound="mute" aria-label="Mute ambient noise">Mute</button>
                    <button type="button" class="sound-btn py-1.5 lg:py-2 px-3 lg:px-4 rounded-2xl bg-canvas-soft/60 text-body hover:bg-canvas-soft-2 active:scale-[0.98] transition-all cursor-pointer text-sm lg:text-base font-medium" data-sound="brown" aria-label="Play ambient brown noise">Brown</button>
                    <button type="button" class="sound-btn py-1.5 lg:py-2 px-3 lg:px-4 rounded-2xl bg-canvas-soft/60 text-body hover:bg-canvas-soft-2 active:scale-[0.98] transition-all cursor-pointer text-sm lg:text-base font-medium" data-sound="white" aria-label="Play ambient white noise">White</button>
                    <button type="button" class="sound-btn py-1.5 lg:py-2 px-3 lg:px-4 rounded-2xl bg-canvas-soft/60 text-body hover:bg-canvas-soft-2 active:scale-[0.98] transition-all cursor-pointer text-sm lg:text-base font-medium" data-sound="rain" aria-label="Play ambient rain sound">Rain</button>
                  </div>

                  <!-- Custom slider inputs -->
                  <div id="custom-presets-panel" class="hidden rounded-xl p-3 space-y-2 bg-canvas-soft/40">
                    <div class="flex items-center justify-between text-sm">
                      <span class="text-mute">Focus: <span id="custom-focus-val" class="font-semibold text-ink tabular-nums">30m</span></span>
                      <input type="range" id="custom-focus-slider" min="1" max="180" value="30" class="w-1/2 accent-link" aria-label="Custom work focus minutes slider" />
                    </div>
                    <div class="flex items-center justify-between text-sm">
                      <span class="text-mute">Break: <span id="custom-break-val" class="font-semibold text-ink tabular-nums">5m</span></span>
                      <input type="range" id="custom-break-slider" min="0" max="60" value="5" class="w-1/2 accent-link" aria-label="Custom rest break minutes slider" />
                    </div>
                  </div>
                </div>

              </div>
            </div>

          </div>

          <!-- RIGHT COLUMN: Timer + Today's Progress -->
          <div class="flex flex-col space-y-3 lg:space-y-6 md:sticky md:top-4 md:self-start min-w-0">

            <!-- THE TIMER — emotional center of the experience -->
            <div id="timer-container-card" class="w-full flex flex-col items-center justify-center relative transition-all duration-500">
              <!-- Soft background glow -->
              <div id="timer-active-glow" class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(37,99,235,0.04),transparent_70%)] pointer-events-none opacity-0 transition-opacity duration-700 ease-out"></div>
              
              <div class="relative w-60 h-60 sm:w-72 sm:h-72 md:w-80 md:h-80 lg:w-[420px] lg:h-[420px] flex items-center justify-center select-none mb-2 timer-dial-wrapper">
                <!-- Subtle dial shadow — layered for depth -->
                <div class="absolute inset-[3%] rounded-full bg-gradient-to-b from-canvas-soft/10 to-transparent dark:from-white/[0.02] pointer-events-none timer-dial-shadow"></div>
                <!-- Bezel ring for premium feel -->
                <div class="absolute inset-[2.5%] rounded-full border border-hairline/10 pointer-events-none"></div>

                <!-- Progress Ring SVG -->
                <svg viewBox="0 0 100 100" class="w-full h-full transform -rotate-90 relative z-10" aria-hidden="true">
                  <defs>
                    <linearGradient id="timer-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                      <stop offset="0%" stop-color="var(--color-link)" />
                      <stop offset="100%" stop-color="var(--color-link)" stop-opacity="0.6" />
                    </linearGradient>
                  </defs>
                  <circle id="timer-progress-bg" cx="50" cy="50" r="45" stroke="currentColor" stroke-width="3" opacity="0.06" fill="transparent" />
                  <circle id="timer-progress-ring" cx="50" cy="50" r="45" stroke="url(#timer-gradient)" stroke-width="4.5" stroke-linecap="round" fill="transparent" stroke-dasharray="282.74" stroke-dashoffset="0" class="transition-all duration-700 ease-out" />
                  <!-- Glowing dot at the end of the progress arc -->
                  <circle id="timer-progress-dot-glow" cx="50" cy="5" r="7" fill="var(--color-link)" opacity="0.15" class="transition-all duration-700 ease-out" />
                  <circle id="timer-progress-dot" cx="50" cy="5" r="3.5" fill="var(--color-link)" class="transition-all duration-700 ease-out" />
                </svg>

                <!-- Center content -->
                <div class="absolute flex flex-col items-center justify-center text-center z-20 px-6 w-full select-none">
                  <!-- Goal shown inside timer when active -->
                  <span id="timer-active-goal" class="text-sm lg:text-base font-medium text-body/70 max-w-[200px] lg:max-w-[280px] truncate mb-2 hidden"></span>
                  <!-- Session label -->
                  <span id="timer-session-label" class="text-sm lg:text-base font-medium text-mute/70 mb-1 inline-flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 opacity-50"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    <span id="timer-session-text">Clear your mind. You've got this.</span>
                  </span>
                  <!-- Countdown -->
                  <span id="timer-countdown" class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-normal tracking-tight text-ink leading-none tabular-nums" style="font-variant-numeric: tabular-nums;">
                    25:00
                  </span>
                  <!-- Next step hint -->
                  <span id="timer-next-step" class="text-sm lg:text-base font-medium text-mute/70 mt-3 hidden max-w-[180px] lg:max-w-[240px] truncate"></span>
                  <!-- Checkpoint ratio -->
                  <span id="timer-milestone-ratio" class="text-xs text-mute/60 mt-2 hidden tabular-nums"></span>
                </div>
              </div>

              <!-- Controls Panel -->
              <div class="flex items-center gap-2 lg:gap-3 mt-1 w-full max-w-xs justify-center">
                <!-- Skip button -->
                <button type="button" id="skip-btn" class="control-btn w-11 h-11 lg:w-12 lg:h-12 rounded-2xl bg-canvas-soft/60 hover:bg-canvas-soft-2/80 active:scale-95 flex items-center justify-center transition-all duration-200 cursor-pointer text-mute hover:text-ink disabled:opacity-25 disabled:pointer-events-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link/30" disabled title="End this session" aria-label="End this focus session">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19"/></svg>
                </button>

                <!-- Primary CTA: Play / Pause -->
                <button type="button" id="play-pause-btn" class="btn-primary px-8 lg:px-10 h-11 lg:h-12 bg-gradient-to-b from-link to-link/90 text-white hover:from-link-hover hover:to-link-hover/90 hover:shadow-lg hover:shadow-link/20 active:scale-[0.97] text-sm lg:text-base font-semibold rounded-2xl transition-all duration-200 cursor-pointer flex items-center gap-2.5 lg:gap-3 justify-center min-w-[160px] lg:min-w-[180px] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link/50">
                  <svg id="play-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  <svg id="pause-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="hidden" aria-hidden="true"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                  <span id="play-btn-text">Let's go</span>
                </button>

                <!-- Fullscreen trigger -->
