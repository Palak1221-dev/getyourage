---
import LegalLayout from "../../components/legal/LegalLayout.astro";
import { SUPPORT_EMAIL } from "../../constants";

const sections = [
  { id: "overview", title: "Overview" },
  { id: "information-we-collect", title: "Information We Collect" },
  { id: "how-we-use", title: "How We Use Information" },
  { id: "analytics-cookies", title: "Analytics & Cookies" },
  { id: "data-storage", title: "Data Storage" },
  { id: "third-party", title: "Third-Party Services" },
  { id: "security", title: "Security" },
  { id: "your-rights", title: "Your Rights" },
  { id: "contact", title: "Contact" },
];
---

<LegalLayout
  type="privacy"
  siteTitle="Tooltails Focus"
  pageTitle="Privacy Policy"
  pageDescription="How Tooltails Focus handles your productivity data. Everything stays on your device."
  lastUpdated="June 27, 2026"
  {sections}
  summaryItems={[
    { text: "All timer and goal data stays in your browser" },
    { text: "No account or registration required" },
    { text: "No personal data sold or shared" },
    { text: "Ambient sounds generated locally via Web Audio API" },
    { text: "Analytics used in aggregate only" },
  ]}
  faqItems={[
    { question: "Is my Focus data backed up on Tooltails servers?", answer: "No. All goals, session history, streaks, and analytics are stored in your browser's localStorage. We never receive or store this data. Clearing your browser data will erase it." },
    { question: "Can you see what goals I set?", answer: "No. The Focus Timer is a local-first application. Your goals, milestones, and reflections never leave your device." },
    { question: "What happens if I switch browsers or clear my data?", answer: "Your data is tied to the browser and device you use. Switching browsers, using incognito mode, or clearing localStorage will reset your history. We cannot recover it." },
    { question: "Does Focus use any tracking?", answer: "The Focus page itself loads Google Analytics (GA4) and Microsoft Clarity for aggregated analytics, same as the rest of Tooltails. No timer-specific data is transmitted." },
    { question: "How are the ambient sounds generated?", answer: "Brown noise, white noise, and rain sounds are generated in real time using the Web Audio API in your browser. No audio files are downloaded from external servers." },
  ]}
  productName="Tooltails Focus"
  productUrl="/focus"
  backPath="/focus"
  breadcrumbItems={[
    { name: "Tooltails", item: "https://tooltails.com" },
    { name: "Focus", item: "https://tooltails.com/focus" },
    { name: "Privacy", item: "https://tooltails.com/focus/privacy" },
  ]}
>
  <div class="space-y-10 divide-y divide-hairline/50">
    <section id="overview" class="pt-0">
      <p class="text-body leading-relaxed">
        Tooltails Focus is a local-first productivity tool. It was designed around a straightforward premise: your goals, focus sessions, and progress data belong entirely to you.
      </p>
      <p class="text-body leading-relaxed mt-4">
        This policy explains what data the application accesses, how it is used, and what stays under your control.
      </p>
    </section>

    <section id="information-we-collect" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Information We Collect</h2>
      <div class="space-y-4">
        <div class="bg-green-50 dark:bg-green-950/20 border border-green-200 dark:border-green-800/30 rounded-xl p-5">
          <h3 class="text-sm font-semibold text-green-800 dark:text-green-200 mb-2">Not collected (by design)</h3>
          <ul class="space-y-1.5 text-sm text-green-700 dark:text-green-300">
            <li>- Goal titles, descriptions, or milestones</li>
            <li>- Session timestamps or duration data</li>
            <li>- Mood logs or journal entries</li>
            <li>- Streak counts or productivity scores</li>
            <li>- Personal identifiers or contact information</li>
          </ul>
        </div>
        <div class="bg-canvas-soft rounded-xl border border-hairline p-5">
          <h3 class="text-sm font-semibold text-ink mb-2">Collected (aggregated analytics only)</h3>
          <ul class="space-y-1.5 text-sm text-body">
            <li>- Page view counts and session duration</li>
            <li>- Browser and device type</li>
            <li>- Country-level location data</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="how-we-use" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">How We Use Information</h2>
      <p class="text-body leading-relaxed">
        Analytics data helps us understand how the Focus Timer is used and identify areas for improvement. For example, if many users attempt a particular feature and miss it, we can adjust the interface.
      </p>
      <p class="text-body leading-relaxed mt-4">
        No personal or productivity data is used for advertising, profiling, or any purpose beyond aggregate product analytics.
      </p>
    </section>

    <section id="analytics-cookies" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Analytics & Cookies</h2>
      <p class="text-body leading-relaxed">
        The Focus page uses the same analytics stack as the rest of Tooltails: Google Analytics 4 and Microsoft Clarity. These services may set cookies to distinguish unique visitors. We do not set any first-party cookies.
      </p>
      <div class="bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-800/30 rounded-xl p-5 mt-4">
        <p class="text-sm text-amber-800 dark:text-amber-200 leading-relaxed">
          You can block analytics cookies through your browser settings without affecting the Focus Timer's core functionality.
        </p>
      </div>
    </section>

    <section id="data-storage" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Data Storage</h2>
      <p class="text-body leading-relaxed mb-4">
        Focus Timer uses your browser's localStorage for data persistence. This includes:
      </p>
      <ul class="space-y-2 text-body mb-4">
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Current and past goals with milestones</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Session history and completion data</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Streak counters and daily progress</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Mood logs and journal entries</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Application preferences (sounds, durations)</span>
        </li>
      </ul>
      <p class="text-body leading-relaxed">
        This data never leaves your device. Clearing your browser's localStorage will reset all Focus data. We cannot recover it.
      </p>
    </section>

    <section id="third-party" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Third-Party Services</h2>
      <p class="text-body leading-relaxed">
        The Focus page integrates the same third-party services as the main Tooltails site: Google Analytics 4 for traffic analysis and Microsoft Clarity for session insights. No Focus-specific data is shared with these services.
      </p>
    </section>

    <section id="security" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Security</h2>
      <p class="text-body leading-relaxed">
        All Tooltails pages are served over HTTPS. Since your Focus data is stored locally and never transmitted, the primary security consideration is your local browser environment. Keep your browser updated and avoid using Focus on shared devices if you are concerned about local data privacy.
      </p>
    </section>

    <section id="your-rights" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Your Rights</h2>
      <ul class="space-y-2 text-body">
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span><strong class="text-ink">Delete your data.</strong> Clear your browser's localStorage to remove all Focus data.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span><strong class="text-ink">Opt out of analytics.</strong> Use browser settings or extensions to block analytics scripts.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span><strong class="text-ink">Know what is collected.</strong> This policy describes every category of data access.</span>
        </li>
      </ul>
    </section>

    <section id="contact" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Contact</h2>
      <p class="text-body leading-relaxed">
        Questions about Focus privacy? Reach out through our <a href="/focus/contact" class="text-link hover:text-link-hover underline underline-offset-2">contact page</a> or email us directly at <a href={`mailto:${SUPPORT_EMAIL}`} class="text-link hover:text-link-hover underline underline-offset-2">{SUPPORT_EMAIL}</a>.
      </p>
    </section>
  </div>
</LegalLayout>
