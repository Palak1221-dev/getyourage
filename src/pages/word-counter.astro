---
import Layout from "../layouts/Layout.astro";
import WordCounter from "../components/calculators/WordCounter.astro";
import FAQ from "../components/ui/FAQ.astro";

const faqItems = [
  {
    question: "How does the word counter work?",
    answer: "Our word counter analyzes your text in real-time as you type or paste. It splits the text by whitespace to count words, counts every character (with and without spaces), detects sentences by end punctuation, and identifies paragraphs by blank lines. All processing happens locally in your browser — nothing is sent to a server."
  },
  {
    question: "What is reading time and how is it calculated?",
    answer: "Reading time estimates how long it takes an average person to read your text. We use the standard rate of 200 words per minute. Speaking time uses 150 words per minute, the average conversational pace. Both are rounded up to the nearest minute."
  },
  {
    question: "What is keyword density?",
    answer: "Keyword density shows how frequently each word appears in your text as a percentage of total words. Common stop words (like 'the', 'and', 'is') are filtered out so you can see your content's meaningful keywords. This helps with SEO optimization and identifying overused terms."
  },
  {
    question: "Is my text stored or sent anywhere?",
    answer: "No. All text processing happens entirely in your browser. Your text never leaves your device. You can paste sensitive content like draft articles, essays, or reports with complete privacy."
  },
  {
    question: "Can I upload a file instead of pasting?",
    answer: "Yes. Click the 'Upload .txt' button to select a plain text file from your device. The file contents will be loaded into the text area and analyzed instantly. We support .txt files of any reasonable size."
  }
];
---

<Layout
  title="Word Counter - Free Online Word & Character Counter | Tooltails"
  description="Count words, characters, sentences, paragraphs, and reading time for free. Fast and accurate online word counter tool."
>
  <!-- Hero Section -->
  <section class="w-full pt-4 lg:pt-8 pb-6">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr,460px] gap-6 lg:gap-16 items-start">
        <div class="text-center lg:text-left lg:pt-2">
          <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-6xl font-bold tracking-tighter text-ink mb-3 leading-[1.1]">
            Free Online Word Counter
          </h1>
          <p class="text-base md:text-lg text-body leading-relaxed max-w-lg mx-auto lg:mx-0 mb-6">
            Count words, characters, sentences, paragraphs, and reading time instantly. Fast, accurate, and private.
          </p>

          <!-- Trust Signals Desktop -->
          <div class="hidden lg:flex items-center gap-8 text-[12px] font-bold text-mute uppercase tracking-[0.2em]">
            <div class="flex items-center gap-2 group">
              <div class="p-2 rounded-full bg-link/5 group-hover:bg-link/10 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-link"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </div>
              Privacy First
            </div>
            <div class="flex items-center gap-2 group">
              <div class="p-2 rounded-full bg-link/5 group-hover:bg-link/10 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-link"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
              </div>
              Instant Results
            </div>
            <div class="flex items-center gap-2 group">
              <div class="p-2 rounded-full bg-link/5 group-hover:bg-link/10 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-link"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
              </div>
              100% Free
            </div>
          </div>
        </div>

        <div class="w-full">
          <WordCounter />

          <!-- Trust Signals Mobile -->
          <div class="flex lg:hidden flex-wrap justify-center gap-4 mt-6 text-[10px] font-bold text-mute uppercase tracking-widest">
            <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Privacy First</span>
            <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg> Instant</span>
            <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg> Free</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Grid -->
  <section class="w-full py-24 bg-canvas-soft-2/50 border-y border-hairline">
    <div class="max-w-[1200px] mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="p-6 sm:p-8 bg-canvas border border-hairline rounded-xl sm:rounded-lg card-shadow">
        <h3 class="text-lg font-bold text-ink mb-3">Real-Time Counting</h3>
        <p class="text-sm text-body leading-relaxed">
          See word, character, sentence, and paragraph counts update instantly as you type or paste text.
        </p>
      </div>
      <div class="p-6 sm:p-8 bg-canvas border border-hairline rounded-xl sm:rounded-lg card-shadow">
        <h3 class="text-lg font-bold text-ink mb-3">Privacy Friendly</h3>
        <p class="text-sm text-body leading-relaxed">
          Your text stays on your device. All processing is done locally in your browser — nothing is sent to any server.
        </p>
      </div>
      <div class="p-6 sm:p-8 bg-canvas border border-hairline rounded-xl sm:rounded-lg card-shadow">
        <h3 class="text-lg font-bold text-ink mb-3">SEO Insights</h3>
        <p class="text-sm text-body leading-relaxed">
          Analyze keyword density to optimize your content for search engines and improve readability.
        </p>
      </div>
    </div>
  </section>

  <!-- Related Tools -->
  <section class="w-full py-16 bg-canvas-soft-2/50 border-y border-hairline">
    <div class="max-w-[1200px] mx-auto px-6 text-center">
      <h2 class="text-2xl font-bold text-ink mb-8">Try our other tools</h2>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href="/pomodoro-timer" class="inline-flex items-center justify-center px-6 h-12 text-base font-medium rounded-pill bg-canvas text-ink border border-hairline hover:bg-canvas-soft-2 hover:shadow-sm transition-all active:scale-[0.98]">
          Pomodoro Timer
        </a>
        <a href="/focus" class="inline-flex items-center justify-center px-6 h-12 text-base font-medium rounded-pill bg-canvas text-ink border border-hairline hover:bg-canvas-soft-2 hover:shadow-sm transition-all active:scale-[0.98]">
          Focus Goals Timer
        </a>
        <a href="/age-calculator" class="inline-flex items-center justify-center px-6 h-12 text-base font-medium rounded-pill bg-canvas text-ink border border-hairline hover:bg-canvas-soft-2 hover:shadow-sm transition-all active:scale-[0.98]">
          Age Calculator
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="w-full py-24">
    <div class="max-w-[800px] mx-auto px-6">
      <FAQ items={faqItems} />
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
      { "@type": "ListItem", "position": 2, "name": "Word Counter", "item": "https://tooltails.com/word-counter" }
    ]
  })} />
</Layout>
