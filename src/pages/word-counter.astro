---
import Layout from "../layouts/Layout.astro";
---
<Layout title="Word Counter - Free Online Word & Character Counter | Tooltails"
        description="Count words, characters, sentences, paragraphs, and reading time for free. Fast and accurate online word counter tool.">
  <main class="min-h-screen flex items-center justify-center bg-canvas">
    <div class="text-center p-8">
      <h1 class="text-2xl font-bold text-ink mb-2">Loading Word Counter...</h1>
      <p class="text-body">Redirecting to tool...</p>
    </div>
  </main>
</Layout>
