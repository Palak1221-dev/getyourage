---
import Layout from "../layouts/Layout.astro";
---

<Layout title="About Us - Tooltails.com" description="Learn about Tooltails.com — free, private, and accurate age calculators and date tools. Built for speed, privacy, and ease of use.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24">
    <h1 class="text-4xl font-bold text-ink mb-8">About Tooltails.com</h1>
    <div class="prose prose-neutral">
      <p class="text-lg text-body leading-relaxed mb-6">
        Tooltails.com was founded with a simple goal: to provide the most accurate, modern, and user-friendly date calculation tools on the web.
      </p>
      <p class="text-body leading-relaxed mb-6">
        Unlike other calculators that are cluttered with ads and outdated designs, we prioritize a "tool-first" experience. Our calculators are fast, mobile-responsive, and designed with a focus on precision and privacy.
      </p>
      <h2 class="text-2xl font-bold text-ink mt-12 mb-4">Our Mission</h2>
      <p class="text-body leading-relaxed mb-6">
        We believe that utility tools should be beautiful and easy to use. Whether you're calculating your age for a legal form, checking the age gap with a partner, or counting down to your birthday, we provide the data you need in seconds.
      </p>
    </div>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "About Us - Tooltails.com",
    "description": "Learn about Tooltails.com — free, private, and accurate age calculators and date tools. Built for speed, privacy, and ease of use.",
    "url": Astro.url.origin + "/about",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": Astro.url.origin + "/about"
    }
  })} />
</Layout>
