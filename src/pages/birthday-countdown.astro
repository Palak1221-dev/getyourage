---
import Layout from "../layouts/Layout.astro";
import BirthdayCountdown from "../components/calculators/BirthdayCountdown.astro";
import FAQ from "../components/ui/FAQ.astro";

const faqItems = [
  {
    question: "When is my next birthday?",
    answer: "Our countdown shows you exactly how many days are left until your next birthday celebration, along with the specific day of the week it falls on."
  },
  {
    question: "How old will I be on my next birthday?",
    answer: "The calculator automatically determines your upcoming age by looking at your birth year and the current year."
  },
  {
    question: "Does it account for leap years?",
    answer: "Yes, our algorithm correctly accounts for leap years to ensure the countdown to your next big day is 100% accurate."
  }
];
---

<Layout 
  title="Birthday Countdown - Days until your next birthday" 
  description="See exactly how many days, weeks, and months are left until your next birthday. Find out what day of the week your birthday falls on this year."
>
  <div class="max-w-[1200px] mx-auto px-4 py-6 md:py-10">
    <div class="max-w-4xl mx-auto text-center mb-6">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-ink mb-4">
        Birthday Countdown
      </h1>
      <p class="text-lg md:text-xl text-body leading-relaxed max-w-[700px] mx-auto mb-6">
        Can't wait for your next birthday? Enter your birth date to see the live countdown and fun facts about your upcoming special day.
      </p>
    </div>

    <div class="max-w-[800px] mx-auto">
      <BirthdayCountdown />
    </div>

    <div class="max-w-4xl mx-auto mt-24">
      <section class="w-full py-16 -mx-4 px-4 bg-canvas-soft-2/50 border-y border-hairline mb-24">
        <div class="max-w-[1200px] mx-auto text-center">
          <h2 class="text-2xl font-bold text-ink mb-8">Try our other calculators</h2>
          <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a href="/age-calculator" class="inline-flex items-center justify-center px-6 h-12 text-base font-medium rounded-pill bg-canvas text-ink border border-hairline hover:bg-canvas-soft-2 hover:shadow-sm transition-all active:scale-[0.98]">
              Exact Age Calculator
            </a>
            <a href="/future-age" class="inline-flex items-center justify-center px-6 h-12 text-base font-medium rounded-pill bg-canvas text-ink border border-hairline hover:bg-canvas-soft-2 hover:shadow-sm transition-all active:scale-[0.98]">
              Future Age Calculator
            </a>
          </div>
        </div>
      </section>

      <FAQ items={faqItems} />
    </div>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
      { "@type": "ListItem", "position": 2, "name": "Birthday Countdown", "item": "https://tooltails.com/birthday-countdown" }
    ]
  })} />
</Layout>
