---
import Layout from "../layouts/Layout.astro";
import Input from "../components/ui/Input.astro";
import Button from "../components/ui/Button.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
    { "@type": "ListItem", "position": 2, "name": "Pomodoro Timer", "item": "https://tooltails.com/pomodoro-timer" }
  ]
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Tooltails Pomodoro Timer - Focus & Productivity Timer",
  "operatingSystem": "All",
  "applicationCategory": "ProductivityApplication",
  "description": "Free Pomodoro Timer with task tracking, daily streaks, focus analytics, session history, and productivity scoring. Stay focused and get more done with Tooltails.",
  "browserRequirements": "Requires JavaScript. Requires HTML5.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": "Task tracking, Daily streaks, Focus analytics, Productivity score, Session history, Custom durations, Sound notifications, Desktop notifications, Offline support"
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Pomodoro Timer That Tracks Real Progress - Tooltails",
  "description": "Stay focused, build streaks, measure productivity, and turn work sessions into completed goals with the Tooltails Pomodoro Timer. Free, no login required.",
  "url": "https://tooltails.com/pomodoro-timer"
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Tooltails Pomodoro",
  "url": "https://tooltails.com/pomodoro-timer",
  "description": "Free Pomodoro Timer with task tracking, daily streaks, focus analytics, session history, and productivity scoring."
};
---

<Layout
  title="Pomodoro Timer That Tracks Real Progress – Free Focus Timer | Tooltails"
  description="Stay focused, build streaks, measure productivity, and turn work sessions into completed goals. Free Pomodoro Timer with task tracking, focus analytics, and daily streaks. No login required."
  image="/og-image.png"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- ===== HERO SECTION ===== -->
  <div class="max-w-[1440px] mx-auto px-4 pt-1 pb-0">
    <div>
      <h1 class="text-pretty text-2xl sm:text-3xl md:text-4xl font-black tracking-tighter text-ink leading-tight">Focus on <span class="bg-gradient-to-r from-link via-blue-500 to-indigo-600 bg-clip-text text-transparent font-black">one thing</span>.</h1>
      <p class="text-xs sm:text-sm text-ink/75 font-medium leading-relaxed mt-1">A premium focus space designed to protect your attention, rhythm, and flow.</p>
    </div>
  </div>

  <!-- ===== MAIN CONTENT ===== -->
  <div class="max-w-[1440px] mx-auto px-4 pb-2">

    <!-- ===== TWO-COLUMN LAYOUT ===== -->
    <!--
      Mobile stacking (order-*): Focus → Timer → Glance → Note → Streak → Recent
      Desktop grid: Focus | Timer (sticky) — Glance | Note — Recent | Streak
    -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_1.3fr] gap-3 lg:gap-4 items-start">

            <!-- ===== LEFT COLUMN (Focus, Glance, Recent) ===== -->
      <div class="order-2 flex flex-col gap-3 lg:col-start-1 lg:row-start-1 lg:row-end-4 w-full">
        <div aria-busy="true" class="bg-canvas rounded-2xl border border-link/15 border-t-[3px] border-t-link shadow-[0_8px_30px_rgba(37,99,235,0.05)] ring-1 ring-inset ring-black/[0.03] dark:ring-white/[0.03] p-3.5 sm:p-4 transition-colors duration-300 hover:shadow-[0_12px_40px_rgba(37,99,235,0.08)] hover:border-link/25">
            <div class="flex items-center gap-2 mb-1.5 border-b border-hairline/10 pb-1">
            <svg class="w-4 h-4 text-link shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/></svg>
            <h2 class="text-pretty text-sm sm:text-base font-extrabold tracking-tight text-ink">Today's Focus</h2>
            <span id="tasks-count" class="text-[9px] sm:text-[10px] font-bold uppercase tracking-widest text-ink/75 ml-auto bg-canvas-soft-2 px-2 py-0.5 rounded-full border border-hairline/40">🌱 Nothing planned</span>
          </div>
          <ul id="tasks-list" class="space-y-0.5">
            <li class="text-sm text-ink/70 text-center py-8 leading-relaxed" id="tasks-empty">What do you want to work on today?</li>
          </ul>
          <div class="flex gap-2 mt-1.5 pt-1.5 border-t border-hairline/30">
            <input id="task-add-input" type="text" placeholder="Add a task…" class="flex-1 h-10 px-3 text-sm bg-canvas-soft-2 border border-hairline/50 rounded-xl text-ink placeholder:text-ink/40 outline-none focus:border-link/50 focus:ring-2 focus:ring-link/10 transition-all" / autocomplete="off"><button id="task-add-btn" class="h-10 px-4 text-sm font-bold text-white bg-link rounded-xl hover:bg-link-hover transition-all shrink-0 cursor-pointer active:scale-95 shadow-sm shadow-link/20" type="button" style="touch-action: manipulation">Add task</button></div>
          <div id="quick-start-section" class="mt-1.5 pt-1.5 border-t border-hairline/30">
            <span class="text-xs font-bold uppercase tracking-widest text-ink/70 block mb-1.5">Quick start</span>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
              <button type="button" class="quick-start-btn flex flex-col items-center justify-center min-h-[56px] py-2 px-3 rounded-xl border border-hairline/40 bg-canvas hover:bg-canvas-soft-2 transition-all cursor-pointer active:scale-95 text-center w-full" data-template="Study" style="touch-action: manipulation"><span class="text-xs font-bold text-ink">Study</span>
                <span class="text-[9px] text-ink/65 font-medium mt-0.5 leading-none whitespace-nowrap">Review, notes</span>
              </button>
              <button type="button" class="quick-start-btn flex flex-col items-center justify-center min-h-[56px] py-2 px-3 rounded-xl border border-hairline/40 bg-canvas hover:bg-canvas-soft-2 transition-all cursor-pointer active:scale-95 text-center w-full" data-template="Writing" style="touch-action: manipulation"><span class="text-xs font-bold text-ink">Writing</span>
                <span class="text-[9px] text-ink/65 font-medium mt-0.5 leading-none whitespace-nowrap">Draft, outline</span>
              </button>
              <button type="button" class="quick-start-btn flex flex-col items-center justify-center min-h-[56px] py-2 px-3 rounded-xl border border-hairline/40 bg-canvas hover:bg-canvas-soft-2 transition-all cursor-pointer active:scale-95 text-center w-full" data-template="Coding" style="touch-action: manipulation"><span class="text-xs font-bold text-ink">Coding</span>
                <span class="text-[9px] text-ink/65 font-medium mt-0.5 leading-none whitespace-nowrap">Feature, debug</span>
              </button>
              <button type="button" class="quick-start-btn flex flex-col items-center justify-center min-h-[56px] py-2 px-3 rounded-xl border border-hairline/40 bg-canvas hover:bg-canvas-soft-2 transition-all cursor-pointer active:scale-95 text-center w-full" data-template="Reading" style="touch-action: manipulation"><span class="text-xs font-bold text-ink">Reading</span>
                <span class="text-[9px] text-ink/65 font-medium mt-0.5 leading-none whitespace-nowrap">Articles, books</span>
              </button>
            </div>
          </div>
          <div id="task-input-container" class="hidden">
            <input id="task-input" type="text" class="hidden" />
          </div>
          <div id="active-task-container" class="hidden">
            <span id="active-task-name"></span>
          </div>
          <div id="active-task-footer" class="hidden">
            <button type="button" id="btn-complete-task" class="hidden"></button>
          </div>
        </div>
        <div aria-busy="true" class="bg-canvas rounded-xl border border-indigo-500/15 border-t-[3px] border-t-indigo-500 shadow-[0_8px_30px_rgba(99,102,241,0.05)] p-2.5 sm:p-3 transition-colors duration-300 hover:shadow-[0_12px_40px_rgba(99,102,241,0.08)] hover:border-indigo-500/25">
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 sm:gap-3">
            <div>
              <span class="text-[9px] sm:text-[10px] font-medium text-ink uppercase tracking-widest">Sessions</span>
              <div class="flex items-baseline gap-0.5 mt-0.5">
                <span id="stat-sessions" class="text-xl sm:text-2xl font-black tracking-tight text-ink leading-none" aria-live="polite">0</span>
                <span class="text-xs text-ink/65 font-medium">/ <span id="stat-goal-total">4</span></span>
              </div>
              <div class="w-full h-0.5 bg-hairline/60 rounded-full overflow-hidden mt-1.5">
                <div id="stat-goal-bar" class="bg-link h-full rounded-full transition-colors duration-500" style="width:0%"></div>
              </div>
            </div>
            <div>
              <span class="text-[9px] sm:text-[10px] font-medium text-ink uppercase tracking-widest">Tasks done</span>
              <div class="flex items-baseline mt-0.5">
                <span id="stat-tasks" class="text-xl sm:text-2xl font-black tracking-tight text-green-500 leading-none" aria-live="polite">0</span>
              </div>
              <div id="tasks-completed-sub" class="text-[10px] text-ink/75 mt-1 font-medium leading-tight">Add a task</div>
            </div>
            <div>
              <span class="text-[9px] sm:text-[10px] font-medium text-ink uppercase tracking-widest">Time spent</span>
              <div class="flex items-baseline mt-0.5">
                <span id="stat-total-time" class="text-xl sm:text-2xl font-black tracking-tight text-link leading-none" aria-live="polite">0m</span>
              </div>
              <div class="text-[10px] text-ink/75 mt-1 font-medium leading-tight">Ready when you are</div>
            </div>
            <div>
              <span class="text-[9px] sm:text-[10px] font-medium text-ink uppercase tracking-widest">Focus score</span>
              <div class="flex items-baseline gap-0.5 mt-0.5">
                <span id="stat-focus-score" class="text-xl sm:text-2xl font-black tracking-tight text-ink leading-none" aria-live="polite">0</span>
                <span class="text-xs text-ink/65 font-medium">/100</span>
              </div>
              <span id="focus-score-label" class="text-[10px] font-medium text-link hidden"></span>
              <div id="focus-score-label-fallback" class="text-[10px] text-ink/75 mt-1 font-medium leading-tight">Start a session</div>
            </div>
          </div>
          <p id="stat-encouragement" class="text-xs text-ink/70 mt-2 pt-1.5 border-t border-hairline/20 leading-relaxed" aria-live="polite">Small progress still counts. Start where you are.</p>
          <span id="session-counter-text" class="hidden"></span>
          <span id="stat-goal-percentage" class="hidden">0%</span>
        </div>

      

        <!-- 4. UTILITY GRID CONTAINER (2x2 Grid) -->
        <div class="w-full">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            
            <!-- Card 1: Your Streak -->
            <div class="bg-gradient-to-b from-orange-500/[0.04] via-orange-500/[0.01] to-canvas rounded-xl border border-orange-500/15 border-t-[3px] border-t-orange-500 shadow-[0_8px_30px_rgba(249,115,22,0.04)] p-3 sm:p-3.5 flex flex-col justify-between min-h-[120px] sm:min-h-[130px] md:min-h-[140px] transition-colors duration-300 hover:shadow-[0_16px_40px_rgba(249,115,22,0.08)] hover:border-orange-500/25 overflow-hidden">
              <div class="flex flex-col grow">
                <div class="flex items-center gap-1.5 mb-1.5 border-b border-hairline/10 pb-1">
                  <svg class="w-3.5 h-3.5 text-orange-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                  <span class="text-[9px] sm:text-[10px] font-extrabold uppercase text-ink tracking-widest">Your Streak</span>
                </div>
                <div class="flex items-center justify-between text-xs text-ink mt-2 mb-2 bg-orange-500/[0.04] dark:bg-orange-500/[0.01] px-2 py-1.5 rounded-xl border border-orange-500/10 select-none">
                  <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-lg bg-orange-500/10 dark:bg-orange-500/20 flex items-center justify-center text-xs shrink-0 select-none shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]">🔥</div>
                    <div class="flex flex-col">
                      <span class="text-[8px] font-semibold uppercase tracking-widest text-ink/75 leading-none">Streak</span>
                      <span class="text-xs sm:text-sm font-black text-ink mt-0.5" aria-live="polite"><span id="stat-streak">0</span><span class="text-[8px] text-ink/50 font-bold ml-0.5">d</span></span>
                    </div>
                  </div>
                  <div class="w-px h-6 bg-orange-500/10"></div>
                  <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-lg bg-amber-500/10 dark:bg-amber-500/20 flex items-center justify-center text-xs shrink-0 select-none shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]">🏆</div>
                    <div class="flex flex-col">
                      <span class="text-[8px] font-semibold uppercase tracking-widest text-ink/75 leading-none">Best</span>
                      <span class="text-xs sm:text-sm font-black text-ink mt-0.5" aria-live="polite"><span id="stat-longest-streak">0</span><span class="text-[8px] text-ink/50 font-bold ml-0.5">d</span></span>
                    </div>
                  </div>
                  <div class="w-px h-6 bg-orange-500/10"></div>
                  <div class="flex items-center gap-2">
                    <div class="w-7 h-7 rounded-lg bg-blue-500/10 dark:bg-blue-500/20 flex items-center justify-center text-xs shrink-0 select-none shadow-[inset_0_1px_0_rgba(255,255,255,0.2)]">⚡</div>
                    <div class="flex flex-col">
                      <span class="text-[8px] font-semibold uppercase tracking-widest text-ink/75 leading-none">Score</span>
                      <span class="text-xs sm:text-sm font-black text-ink mt-0.5"><span id="dash-score">0</span></span>
                    </div>
                  </div>
                </div>
                <p id="streak-context" class="text-[10px] sm:text-[11px] text-ink/80 mt-2.5 leading-snug font-medium border-l-2 border-orange-500/30 pl-1.5">Start today to begin your streak.</p>
                <span id="streak-context-fallback" class="hidden"></span>
              </div>
              <div class="mt-1 pt-1 border-t border-hairline/20 shrink-0">
                <span id="heatmap-week-label" class="hidden"></span>
                <div id="weekly-heatmap" class="flex gap-1 min-h-[20px] items-end">
                  <div class="text-[9px] text-ink/75 w-full text-center">No sessions yet</div>
                </div>
                <!-- Dynamic day labels row placeholder -->
                <div id="weekly-heatmap-labels" class="flex gap-1 mt-0.5 select-none"></div>
                <div class="flex items-center justify-between mt-1 pt-1 border-t border-hairline/15 select-none">
                  <span class="text-[8px] text-ink/75 font-semibold">Activity (Past 7 days)</span>
                  <div class="flex gap-0.5">
                    <span class="w-1.5 h-1.5 rounded-sm bg-slate-100 dark:bg-zinc-800/50 border border-slate-200 dark:border-zinc-700"></span>
                    <span class="w-1.5 h-1.5 rounded-sm bg-violet-200 dark:bg-violet-800/40 border border-violet-300/40"></span>
                    <span class="w-1.5 h-1.5 rounded-sm bg-violet-300 dark:bg-violet-700/50 border border-violet-400/40"></span>
                    <span class="w-1.5 h-1.5 rounded-sm bg-violet-400 dark:bg-violet-600/60 border border-violet-500/40"></span>
                    <span class="w-1.5 h-1.5 rounded-sm bg-violet-500 dark:bg-violet-500/70 border border-violet-600/40"></span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Card 2: Daily Target -->
            <div class="bg-canvas rounded-xl border border-green-500/15 border-t-[3px] border-t-green-500 shadow-[0_8px_30px_rgba(34,197,94,0.04)] p-2.5 sm:p-3 flex flex-col justify-between min-h-[85px] sm:min-h-[95px] md:min-h-[105px] transition-colors duration-300 hover:shadow-[0_12px_40px_rgba(34,197,94,0.08)] hover:border-green-500/25 overflow-hidden">
              <div class="flex flex-col grow">
                <div class="flex items-center gap-1.5 mb-1.5 border-b border-hairline/10 pb-1">
                  <svg class="w-3.5 h-3.5 text-green-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                  <span class="text-[9px] sm:text-[10px] font-extrabold uppercase text-ink tracking-widest">Daily Target</span>
                </div>
                <div class="flex flex-col mt-1.5">
                  <span id="daily-target-large-text" class="text-sm font-black tracking-tight text-ink leading-none" aria-live="polite">0 of 4 sessions</span>
                  <p id="daily-target-subtext" class="text-[10px] text-ink/75 mt-1 leading-normal font-medium">Keep going, you've got this!</p>
                </div>
              </div>
              <div class="flex items-center gap-2 mt-auto w-full">
                <div class="flex-1 h-1.5 bg-hairline/60 rounded-full overflow-hidden">
                  <div id="daily-target-bar" class="bg-gradient-to-r from-emerald-500 to-green-500 shadow-[0_0_8px_rgba(34,197,94,0.35)] h-full rounded-full transition-colors duration-500" style="width:0%"></div>
                </div>
                <span id="daily-target-pct" class="text-[10px] font-bold text-green-500 shrink-0">0%</span>
                <span id="daily-target-text" class="hidden">0/4</span>
              </div>
            </div>


          </div>
        </div>


        <!-- 5. A NOTE FOR TODAY -->
        <div class="w-full">
          <div class="bg-canvas rounded-xl border border-violet-500/20 border-t-[3px] border-t-violet-500 shadow-[0_8px_30px_rgba(139,92,246,0.05)] p-2 sm:p-2.5 transition-colors duration-300 hover:shadow-[0_12px_40px_rgba(139,92,246,0.08)] hover:border-violet-500/30">
            <div class="flex items-center gap-1.5 mb-1.5 border-b border-hairline/10 pb-1">
              <svg class="w-3.5 h-3.5 text-ink/70 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
              <h2 class="text-pretty text-xs sm:text-sm font-extrabold tracking-tight text-ink">A Note for Today</h2>
            </div>
            <div id="daily-timeline-content" class="space-y-0">
              <div id="focus-insight-card">
                <p id="focus-insight-text" class="text-xs text-ink/80 leading-relaxed">☕ One focus block is enough.</p>
                <button type="button" id="focus-insight-refresh" class="mt-0.5 text-xs font-semibold text-ink/70 hover:text-link transition-colors cursor-pointer" aria-label="Show another insight" style="touch-action: manipulation">Show another</button></div>
            </div>
            <span id="timeline-badge" class="hidden"></span>
          </div>
        </div>

      </div>

      <!-- 2. TIMER + SETTINGS + WIDGETS -->
      <div class="order-1 flex flex-col gap-3 lg:col-start-2 lg:row-start-1 lg:row-end-4 lg:sticky lg:top-4" style="overscroll-behavior: contain"><div aria-busy="true" class="bg-gradient-to-b from-link/[0.05] via-link/[0.02] to-canvas rounded-2xl border border-link/20 border-t-[4px] border-t-link shadow-[0_20px_50px_rgba(37,99,235,0.08)] ring-1 ring-inset ring-black/[0.03] dark:ring-white/[0.03] p-3 pb-1.5 transition-colors duration-300 hover:shadow-[0_24px_60px_rgba(37,99,235,0.12)] hover:border-link/30">
            <div class="flex gap-0.5 p-1 bg-link/[0.06] rounded-full w-full max-w-[300px] mx-auto mb-1.5">
              <button type="button" id="mode-pomodoro" class="flex-1 py-1.5 text-xs sm:text-sm font-bold rounded-full transition-all cursor-pointer bg-link text-white shadow-[0_2px_8px_rgba(37,99,235,0.25)] ring-1 ring-link/20" aria-label="Switch to Pomodoro focus session" style="touch-action: manipulation">Pomodoro</button><button type="button" id="mode-short" class="flex-1 py-1.5 text-xs sm:text-sm font-bold text-body/70 hover:text-ink rounded-full transition-all cursor-pointer" aria-label="Switch to short break" style="touch-action: manipulation">Short Break</button><button type="button" id="mode-long" class="flex-1 py-1.5 text-xs sm:text-sm font-bold text-body/70 hover:text-ink rounded-full transition-all cursor-pointer" aria-label="Switch to long break" style="touch-action: manipulation">Long Break</button></div>
            <div class="flex flex-col items-center gap-1">
              <div id="timer-ring-container" class="relative w-full max-w-[230px] sm:max-w-[270px] md:max-w-[300px] aspect-square mx-auto flex items-center justify-center">
                <svg class="w-full h-full transform -rotate-90" viewBox="0 0 256 256" style="filter: drop-shadow(0 0 12px rgba(59,130,246,0.15))">
                  <defs>
                    <filter id="ring-glow"><feGaussianBlur stdDeviation="5" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
                  </defs>
                  <circle cx="128" cy="128" r="120" stroke="currentColor" stroke-width="1" fill="transparent" class="text-link/[0.04]" />
                  <circle cx="128" cy="128" r="116" stroke="currentColor" stroke-width="4" fill="transparent" class="text-hairline/20" />
                  <circle id="timer-progress-ring" cx="128" cy="128" r="116" stroke="currentColor" stroke-width="10" fill="transparent" stroke-dasharray="728.85" stroke-dashoffset="0" stroke-linecap="round" class="text-link transition-colors duration-1000 ease-linear drop-shadow-[0_0_8px_rgba(59,130,246,0.35)]" filter="url(#ring-glow)" />
                </svg>
                <div class="absolute flex flex-col items-center justify-center select-none">
                  <span id="timer-display" class="text-4xl sm:text-5xl md:text-6xl font-black tracking-tighter text-ink tabular-nums leading-none">25:00</span>
                  <span id="timer-status-text" class="text-[10px] sm:text-xs font-black text-link/70 mt-1 uppercase tracking-[0.2em]">Focus time</span>
                </div>
                <div id="timer-pulse" class="absolute inset-0 rounded-full border-[3px] border-link/15 pointer-events-none hidden"></div>
                <div id="celebration-container" class="absolute inset-0 pointer-events-none hidden"></div>
              </div>
              <div id="timer-phase-container" class="text-center min-h-[10px]">
                <span id="timer-phase" class="text-sm sm:text-base font-bold text-link/80 opacity-0 transition-colors duration-500">Whenever you're ready, begin.</span>
              </div>
              <div class="flex items-center gap-2 sm:gap-3">
