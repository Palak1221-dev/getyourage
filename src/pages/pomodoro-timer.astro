---
import Layout from "../layouts/Layout.astro";
import FAQ from "../components/ui/FAQ.astro";
import Card from "../components/ui/Card.astro";
import Button from "../components/ui/Button.astro";
import Input from "../components/ui/Input.astro";

const faqItems = [
  {
    question: "What is the Pomodoro Technique?",
    answer: "The Pomodoro Technique is a time-management method developed by Francesco Cirillo in the late 1980s. It uses a timer to break work down into intervals, traditionally 25 minutes in length, separated by 5-minute breaks. These intervals are named pomodoros, the plural in English of the Italian word pomodoro (tomato), after the tomato-shaped kitchen timer Cirillo used as a university student."
  },
  {
    question: "How long should Pomodoro breaks be?",
    answer: "Traditionally, short breaks are 5 minutes and long breaks are 15 to 30 minutes. Typically, a long break is taken after completing a cycle of four Pomodoro focus sessions. Our timer allows you to customize these durations to match your personal workflow."
  },
  {
    question: "Can I customize the timer durations?",
    answer: "Yes, absolutely! You can customize the work session length, short break length, long break length, and your daily Pomodoro goal directly in the settings panel of our Pomodoro Timer."
  },
  {
    question: "Does this timer support sound and browser notifications?",
    answer: "Yes. It features an audio toggle that triggers a pleasant, high-quality synthesized chime when a session ends. It also supports browser desktop notifications to alert you when the timer finishes, even if you are working in another browser tab."
  },
  {
    question: "How is the Focus Score calculated?",
    answer: "Your daily focus score is a gamified productivity metric ranging from 0 to 100. It increases as you complete Pomodoro work sessions (20 points each) and take scheduled breaks (5 points each), motivating you to maintain a healthy and consistent focus routine."
  }
];

// Structured data schemas
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Tooltails",
      "item": "https://tooltails.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Pomodoro Timer",
      "item": "https://tooltails.com/pomodoro-timer"
    }
  ]
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Pomodoro Timer",
  "operatingSystem": "All",
  "applicationCategory": "ProductivityApplication",
  "description": "Free Pomodoro Timer with task tracking, focus analytics, streaks, and productivity insights. Stay focused and get more done with Tooltails.",
  "browserRequirements": "Requires JavaScript. Requires HTML5.",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  }
};
---

<Layout 
  title="Pomodoro Timer – Free Focus & Productivity Timer | Tooltails" 
  description="Free Pomodoro Timer with task tracking, focus analytics, streaks, and productivity insights. Stay focused and get more done with Tooltails."
>
  <!-- Hero / Header Section -->
  <section class="w-full pt-4 lg:pt-8 pb-6">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center lg:text-left mb-8">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tighter text-ink mb-3 leading-[1.1]">
          Pomodoro Timer
        </h1>
        <p class="text-base md:text-lg text-body leading-relaxed max-w-2xl">
          Supercharge your productivity using the Pomodoro Technique. Set tasks, track focus statistics, build daily streaks, and measure your flow state.
        </p>
      </div>

      <!-- Main Layout Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-[1fr,420px] gap-8 items-start">
        
        <!-- LEFT COLUMN: The Timer Core -->
        <div class="space-y-6">
          <Card elevation="lg" padding="lg" class="bg-canvas border border-hairline/80 relative">
            <!-- Mode Tabs -->
            <div class="flex justify-center gap-1 p-1 bg-canvas-soft-2 rounded-full max-w-sm mx-auto mb-8 border border-hairline">
              <button 
                id="mode-pomodoro" 
                class="flex-1 py-2 px-4 rounded-full text-xs font-semibold transition-all cursor-pointer bg-link text-white shadow-sm"
                aria-label="Switch to Pomodoro focus session"
              >
                Pomodoro
              </button>
              <button 
                id="mode-short" 
                class="flex-1 py-2 px-4 rounded-full text-xs font-semibold text-body hover:text-ink hover:bg-canvas-soft transition-all cursor-pointer"
                aria-label="Switch to short break"
              >
                Short Break
              </button>
              <button 
                id="mode-long" 
                class="flex-1 py-2 px-4 rounded-full text-xs font-semibold text-body hover:text-ink hover:bg-canvas-soft transition-all cursor-pointer"
                aria-label="Switch to long break"
              >
                Long Break
              </button>
            </div>

            <!-- Timer Circle Ring -->
            <div class="relative w-64 h-64 md:w-72 md:h-72 mx-auto flex items-center justify-center mb-8">
              <svg class="w-full h-full transform -rotate-90" viewBox="0 0 256 256">
                <!-- Background Circle -->
                <circle 
                  cx="128" 
                  cy="128" 
                  r="116" 
                  stroke="currentColor" 
                  stroke-width="8" 
                  fill="transparent" 
                  class="text-hairline"
                />
                <!-- Active Progress Ring -->
                <circle 
                  id="timer-progress-ring" 
                  cx="128" 
                  cy="128" 
                  r="116" 
                  stroke="currentColor" 
                  stroke-width="8" 
                  fill="transparent" 
                  stroke-dasharray="728.85" 
                  stroke-dashoffset="0" 
                  stroke-linecap="round" 
                  class="text-link transition-all duration-1000 ease-linear"
                />
              </svg>
              <!-- Center Display Text -->
              <div class="absolute flex flex-col items-center justify-center">
                <span id="timer-display" class="text-5xl md:text-6xl font-bold tracking-tighter text-ink tabular-nums leading-none">25:00</span>
                <span id="timer-status-text" class="text-[10px] font-mono text-mute uppercase tracking-[0.2em] mt-3">Focus Time</span>
              </div>
            </div>

            <!-- Interactive Main Controls -->
            <div class="flex justify-center items-center gap-4 max-w-xs mx-auto mb-8">
              <button 
                id="btn-reset" 
                class="w-12 h-12 rounded-full border border-hairline bg-canvas text-body hover:text-ink hover:bg-canvas-soft-2 transition-all flex items-center justify-center cursor-pointer active:scale-95 shadow-sm"
                title="Reset Timer"
                aria-label="Reset Timer"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              </button>

              <button 
                id="btn-play-pause" 
                class="w-16 h-16 rounded-full bg-link text-white hover:bg-link-hover transition-all flex items-center justify-center cursor-pointer active:scale-95 shadow-lg shadow-link/25"
                title="Start Timer (Spacebar)"
                aria-label="Start or Pause Timer"
              >
                <svg id="icon-play" class="ml-1" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 3 20 12 6 21 6 3"/></svg>
                <svg id="icon-pause" class="hidden" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><rect x="14" y="4" width="4" height="16" rx="1"/><rect x="6" y="4" width="4" height="16" rx="1"/></svg>
              </button>

              <button 
                id="btn-skip" 
                class="w-12 h-12 rounded-full border border-hairline bg-canvas text-body hover:text-ink hover:bg-canvas-soft-2 transition-all flex items-center justify-center cursor-pointer active:scale-95 shadow-sm"
                title="Skip Session"
                aria-label="Skip Session"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" x2="19" y1="5" y2="19"/></svg>
              </button>
            </div>

            <!-- Task Display Banner & Task input -->
            <div class="border-t border-hairline pt-6 max-w-md mx-auto">
              <!-- Active Task Mode Display -->
              <div id="active-task-container" class="hidden flex items-center justify-between p-4 bg-link/5 rounded-xl border border-link/10 animate-in fade-in duration-300">
                <div class="flex items-center gap-3">
                  <div class="w-2.5 h-2.5 rounded-full bg-link animate-pulse"></div>
                  <div>
                    <span class="block text-[10px] font-mono text-link uppercase tracking-wider">Currently Focusing On</span>
                    <span id="active-task-name" class="text-sm font-bold text-ink truncate max-w-[200px] md:max-w-[280px]">Study DSA</span>
                  </div>
                </div>
                <button 
                  id="btn-complete-task" 
                  class="text-xs font-semibold text-link hover:text-link-hover cursor-pointer border border-link/20 bg-canvas hover:bg-link/5 px-2.5 py-1 rounded-sm"
                  aria-label="Mark task as complete"
                >
                  Done
                </button>
              </div>

              <!-- Input for Task -->
              <div id="task-input-container" class="space-y-3">
                <Input 
                  id="task-input" 
                  label="What are you working on?" 
                  placeholder="e.g. Study DSA, Write blog post, Read documentation..." 
                />
                
                <!-- Recent Task Tags -->
                <div id="recent-tasks-container" class="hidden">
                  <span class="text-xs text-mute block mb-1.5 font-medium">Recent tasks:</span>
                  <div id="recent-tasks-list" class="flex flex-wrap gap-1.5">
                    <!-- Dynamic tag pills will be injected here -->
                  </div>
                </div>
              </div>
            </div>
          </Card>

          <!-- Drawer Options Panel -->
          <Card elevation="sm" padding="md" class="bg-canvas border border-hairline/80">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
              <h3 class="text-sm font-bold text-ink uppercase tracking-wider">Preferences</h3>
              <button 
                id="btn-toggle-settings" 
                class="flex items-center gap-1.5 text-xs text-body hover:text-ink font-semibold cursor-pointer"
                aria-expanded="false"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                Custom Durations
              </button>
            </div>

            <!-- Toggles and options -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-4 pt-4 border-t border-hairline">
              
              <!-- Sound Toggle -->
              <div class="flex items-center justify-between md:justify-start gap-4">
                <div>
                  <span class="block text-xs font-semibold text-ink">Sound Chime</span>
                  <span class="text-[10px] text-mute">Audio alert at interval end</span>
                </div>
                <label class="relative inline-flex items-center cursor-pointer select-none">
                  <input type="checkbox" id="toggle-sound" class="sr-only peer" checked />
                  <div class="w-10 h-6 bg-canvas-soft-2 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-hairline after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-link border border-hairline"></div>
                </label>
              </div>

              <!-- Desktop Notifications -->
              <div class="flex items-center justify-between md:justify-start gap-4">
                <div>
                  <span class="block text-xs font-semibold text-ink">Tab Alerts</span>
                  <span class="text-[10px] text-mute">Browser desktop notifications</span>
                </div>
                <label class="relative inline-flex items-center cursor-pointer select-none">
                  <input type="checkbox" id="toggle-notifications" class="sr-only peer" />
                  <div class="w-10 h-6 bg-canvas-soft-2 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-hairline after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-link border border-hairline"></div>
                </label>
              </div>

              <!-- Auto start -->
              <div class="flex items-center justify-between md:justify-start gap-4">
                <div>
                  <span class="block text-xs font-semibold text-ink">Auto-Start</span>
                  <span class="text-[10px] text-mute">Automatically start next timer</span>
                </div>
                <label class="relative inline-flex items-center cursor-pointer select-none">
                  <input type="checkbox" id="toggle-autostart" class="sr-only peer" />
                  <div class="w-10 h-6 bg-canvas-soft-2 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-hairline after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-link border border-hairline"></div>
                </label>
              </div>
            </div>

            <!-- Collapsible Settings Panel -->
            <div id="settings-panel" class="hidden mt-6 pt-6 border-t border-hairline space-y-4 animate-in slide-in-from-top-4 duration-300">
              <h4 class="text-xs font-bold text-ink uppercase tracking-wider">Custom Durations (Minutes)</h4>
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <Input type="number" id="settings-work" label="Focus" min="1" max="180" placeholder="25" />
                <Input type="number" id="settings-short" label="Short Break" min="1" max="60" placeholder="5" />
                <Input type="number" id="settings-long" label="Long Break" min="1" max="60" placeholder="15" />
                <Input type="number" id="settings-goal" label="Daily Goal" min="1" max="24" placeholder="4" />
              </div>
              <div class="flex justify-end gap-2 pt-2">
                <Button variant="secondary" size="sm" id="btn-reset-durations">Defaults</Button>
                <Button size="sm" id="btn-save-settings">Save Settings</Button>
              </div>
            </div>
          </Card>
        </div>

        <!-- RIGHT COLUMN: Analytics, Streaks & History -->
        <div class="space-y-6">
          
          <!-- Focus score & Streak card -->
          <Card elevation="sm" padding="md" class="bg-canvas border border-hairline/80">
            <h3 class="text-xs font-bold text-ink uppercase tracking-wider mb-6">Today's Focus Status</h3>
            
            <div class="grid grid-cols-2 gap-4 mb-6">
              <!-- Completed Goal progress -->
              <div class="p-4 bg-canvas-soft-2 rounded-xl border border-hairline flex flex-col justify-between">
                <div>
                  <span class="block text-[10px] font-mono text-mute uppercase tracking-wider">Daily Goal</span>
                  <div class="flex items-baseline gap-1 mt-1">
                    <span id="stat-sessions" class="text-2xl font-bold text-link">0</span>
                    <span id="stat-goal-total" class="text-sm font-medium text-mute">/ 4</span>
                  </div>
                </div>
                <div class="mt-3">
                  <div class="w-full bg-hairline h-1.5 rounded-full overflow-hidden">
                    <div id="stat-goal-bar" class="bg-link h-full transition-all duration-500" style="width: 0%"></div>
                  </div>
                  <div class="flex justify-between items-center mt-1.5 text-[10px] font-semibold">
                    <span id="stat-goal-percentage" class="text-link">0%</span>
                    <span class="text-mute">completed</span>
                  </div>
                </div>
              </div>

              <!-- Streak card -->
              <div class="p-4 bg-canvas-soft-2 rounded-xl border border-hairline flex flex-col justify-between">
                <div>
                  <span class="block text-[10px] font-mono text-mute uppercase tracking-wider">Daily Streak</span>
                  <div class="flex items-baseline gap-1 mt-1">
                    <span id="stat-streak" class="text-2xl font-bold text-ink">0</span>
                    <span class="text-sm font-medium text-mute">days</span>
                  </div>
                </div>
                <div class="mt-3 flex items-center justify-between text-[10px] font-semibold text-mute">
                  <span class="flex items-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" class="text-orange-500 fill-orange-500" width="10" height="10" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
                    Streak
                  </span>
                  <span>Max: <span id="stat-longest-streak" class="text-ink">0</span></span>
                </div>
              </div>
            </div>

            <!-- Goal visual circle dots list -->
            <div class="border-b border-hairline pb-5 mb-5">
              <span class="block text-[10px] font-mono text-mute uppercase tracking-wider mb-2.5">Focus Progress</span>
              <div id="goal-dots-container" class="flex items-center gap-2">
                <!-- Javascript will inject dots dynamically -->
              </div>
            </div>

            <!-- Focus score gauge and time -->
            <div class="flex items-center justify-between p-4 bg-canvas-soft border border-hairline rounded-xl">
              <div>
                <span class="block text-[10px] font-mono text-mute uppercase tracking-wider">Productivity Score</span>
                <span id="stat-focus-score" class="text-3xl font-extrabold text-ink tracking-tight">0</span>
                <span class="text-xs font-semibold text-mute block mt-1" id="focus-score-label">Getting Started</span>
              </div>
              <div class="flex flex-col items-end">
                <span class="text-[10px] font-mono text-mute uppercase tracking-wider block">Total Focus Today</span>
                <div class="flex items-baseline gap-1 mt-1 text-ink font-bold text-xl">
                  <span id="stat-total-time">0</span>
                  <span class="text-xs font-semibold text-mute">min</span>
                </div>
              </div>
            </div>
          </Card>

          <!-- History card -->
          <Card elevation="sm" padding="md" class="bg-canvas border border-hairline/80">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-xs font-bold text-ink uppercase tracking-wider">Session History</h3>
              <button 
                id="btn-clear-history" 
                class="hidden text-[10px] font-bold text-red-600 hover:text-red-500 uppercase tracking-widest cursor-pointer"
                aria-label="Clear session history"
              >
                Clear
              </button>
            </div>

            <!-- Empty state -->
            <div id="history-empty" class="py-12 px-4 text-center border border-dashed border-hairline rounded-xl bg-canvas-soft">
              <div class="w-10 h-10 rounded-full bg-canvas-soft-2 border border-hairline mx-auto flex items-center justify-center text-mute mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <p class="text-xs font-semibold text-ink">No completed sessions today</p>
              <p class="text-[11px] text-mute mt-1">Complete focus blocks to see your productivity log.</p>
            </div>

            <!-- Sessions list -->
            <div id="history-list" class="space-y-3 max-h-64 overflow-y-auto hidden pr-1">
              <!-- Injected by script -->
            </div>
          </Card>

        </div>

      </div>
    </div>
  </section>

  <!-- SEO Content Section -->
  <section class="max-w-[800px] mx-auto px-6 py-20 mt-12 border-t border-hairline">
    <div class="prose prose-neutral dark:prose-invert">
      <h2 class="text-3xl font-bold tracking-tight text-ink mb-4">What is the Pomodoro Technique?</h2>
      <p class="text-body leading-relaxed mb-6">
        The Pomodoro Technique is a classic time-management system created by Francesco Cirillo in the late 1980s. 
        It uses a timer to break work down into intervals, traditionally 25 minutes in length, separated by short breaks. 
        These intervals are named <strong>pomodoros</strong>, the plural in English of the Italian word pomodoro (tomato), 
        named after the tomato-shaped kitchen timer Cirillo used as a university student.
      </p>
      <p class="text-body leading-relaxed mb-6">
        The system is designed to provide maximum focus and creative freshness, allowing you to complete projects with less mental fatigue. 
        It operates on the premise that frequent breaks keep the mind sharp, focused, and ready for work.
      </p>

      <h2 class="text-3xl font-bold tracking-tight text-ink mb-4">Benefits of Using a Pomodoro Timer</h2>
      <p class="text-body leading-relaxed mb-4">
        Implementing a focus timer in your daily workflow offers key cognitive benefits that can significantly upgrade your output:
      </p>
      <ul class="list-disc pl-6 space-y-2 text-body mb-6">
        <li><strong>Prevent Fatigue:</strong> Frequent short breaks give your brain time to rest, preventing burnout and reducing cognitive exhaustion.</li>
        <li><strong>Boost Concentration:</strong> Splitting tasks into bite-sized 25-minute intervals trains your brain to enter deep focus quickly.</li>
        <li><strong>Eliminate Distractions:</strong> Committing to a single task for a short duration makes it easier to defer incoming texts, emails, and distractions.</li>
        <li><strong>Improve Time Estimates:</strong> By logging how many "Pomodoros" a project takes, you learn how to schedule your calendar accurately.</li>
        <li><strong>Gamify Productivity:</strong> Watching your daily analytics, completed sets, and streak metrics grow builds positive momentum.</li>
      </ul>

      <h2 class="text-3xl font-bold tracking-tight text-ink mb-4">How to Use This Focus Timer</h2>
      <p class="text-body leading-relaxed mb-4">
        Follow these steps to integrate the Tooltails Pomodoro Timer into your study or work routine:
      </p>
      <ol class="list-decimal pl-6 space-y-2 text-body mb-8">
        <li><strong>Declare your focus:</strong> Enter the specific task you want to work on in the text box (e.g., "Read documentation" or "Refactor auth controller").</li>
        <li><strong>Start focusing:</strong> Click the Play button or press <kbd class="px-2 py-0.5 font-mono text-[10px] bg-canvas-soft-2 border border-hairline rounded text-ink shadow-sm">Space</kbd> on your keyboard. Work on your declared task without interruption for 25 minutes.</li>
        <li><strong>Take a short break:</strong> When the chime rings, rest for 5 minutes. Walk around, stretch, or drink water. Avoid social media or other cognitive tasks.</li>
        <li><strong>Repeat:</strong> Continue this cycle of 25 minutes of work followed by a 5-minute break.</li>
        <li><strong>Take a long break:</strong> After completing 4 Pomodoros, reward yourself with a longer 15-minute break to restore your mental capacity.</li>
      </ol>
    </div>

    <!-- FAQ Component Wrapper -->
    <div class="border-t border-hairline pt-12 mt-12">
      <FAQ items={faqItems} />
    </div>
  </section>

  <!-- Structured Data Scripts -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(appSchema)} />
</Layout>

<!-- Client Side Scripting -->
<script>
  // Duration defaults in minutes
  const DEFAULT_WORK = 25;
  const DEFAULT_SHORT = 5;
  const DEFAULT_LONG = 15;
  const DEFAULT_GOAL = 4;

  // State Variables
  let currentMode: 'pomodoro' | 'short' | 'long' = 'pomodoro';
  let timeLeft = DEFAULT_WORK * 60;
  let totalDuration = DEFAULT_WORK * 60;
  let isRunning = false;
  let timerInterval: number | null = null;
  let currentTask = '';

  // DOM Elements
  const timerDisplay = document.getElementById('timer-display');
  const timerStatusText = document.getElementById('timer-status-text');
  const progressRing = document.getElementById('timer-progress-ring') as unknown as SVGCircleElement;
  
  const btnPlayPause = document.getElementById('btn-play-pause');
  const btnReset = document.getElementById('btn-reset');
  const btnSkip = document.getElementById('btn-skip');
  const iconPlay = document.getElementById('icon-play');
  const iconPause = document.getElementById('icon-pause');
  
  const modePomodoro = document.getElementById('mode-pomodoro');
  const modeShort = document.getElementById('mode-short');
  const modeLong = document.getElementById('mode-long');
  
  const taskInput = document.getElementById('task-input') as HTMLInputElement;
  const taskInputContainer = document.getElementById('task-input-container');
  const activeTaskContainer = document.getElementById('active-task-container');
  const activeTaskName = document.getElementById('active-task-name');
  const btnCompleteTask = document.getElementById('btn-complete-task');
  
  const toggleSound = document.getElementById('toggle-sound') as HTMLInputElement;
  const toggleNotifications = document.getElementById('toggle-notifications') as HTMLInputElement;
  const toggleAutostart = document.getElementById('toggle-autostart') as HTMLInputElement;
  
  const btnToggleSettings = document.getElementById('btn-toggle-settings');
  const settingsPanel = document.getElementById('settings-panel');
  const settingsWork = document.getElementById('settings-work') as HTMLInputElement;
  const settingsShort = document.getElementById('settings-short') as HTMLInputElement;
  const settingsLong = document.getElementById('settings-long') as HTMLInputElement;
  const settingsGoal = document.getElementById('settings-goal') as HTMLInputElement;
  const btnSaveSettings = document.getElementById('btn-save-settings');
  const btnResetDurations = document.getElementById('btn-reset-durations');
  
  const statSessions = document.getElementById('stat-sessions');
  const statGoalTotal = document.getElementById('stat-goal-total');
  const statGoalBar = document.getElementById('stat-goal-bar');
  const statGoalPercentage = document.getElementById('stat-goal-percentage');
  const statStreak = document.getElementById('stat-streak');
  const statLongestStreak = document.getElementById('stat-longest-streak');
  const statFocusScore = document.getElementById('stat-focus-score');
  const focusScoreLabel = document.getElementById('focus-score-label');
  const statTotalTime = document.getElementById('stat-total-time');
  const goalDotsContainer = document.getElementById('goal-dots-container');
  
  const historyEmpty = document.getElementById('history-empty');
  const historyList = document.getElementById('history-list');
  const btnClearHistory = document.getElementById('btn-clear-history');
  
  const recentTasksContainer = document.getElementById('recent-tasks-container');
  const recentTasksList = document.getElementById('recent-tasks-list');

  // --- Utility helper functions ---
  const getTodayString = () => {
    const d = new Date();
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  };

  const getYesterdayString = () => {
    const d = new Date();
    d.setDate(d.getDate() - 1);
    return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  };

  // Dual tone chime synthesis (Programmatic Audio)
  const playChime = () => {
    if (toggleSound && !toggleSound.checked) return;
    try {
      const audioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
      const now = audioCtx.currentTime;
      
      // Tone 1: A5 (880Hz)
      const osc1 = audioCtx.createOscillator();
      const gain1 = audioCtx.createGain();
      osc1.type = 'sine';
      osc1.frequency.setValueAtTime(880, now);
      gain1.gain.setValueAtTime(0.15, now);
      gain1.gain.exponentialRampToValueAtTime(0.001, now + 0.15);
      osc1.connect(gain1);
      gain1.connect(audioCtx.destination);
      
      // Tone 2: C6 (1046.5Hz)
      const osc2 = audioCtx.createOscillator();
      const gain2 = audioCtx.createGain();
      osc2.type = 'sine';
      osc2.frequency.setValueAtTime(1046.50, now + 0.1);
      gain2.gain.setValueAtTime(0.15, now + 0.1);
      gain2.gain.exponentialRampToValueAtTime(0.001, now + 0.45);
      osc2.connect(gain2);
      gain2.connect(audioCtx.destination);
      
      osc1.start(now);
      osc1.stop(now + 0.15);
      osc2.start(now + 0.1);
      osc2.stop(now + 0.45);
    } catch (e) {
      console.error('Audio play failed:', e);
    }
  };

  // Browser desktop notification trigger
  const triggerNotification = (title: string, body: string) => {
    if (toggleNotifications && toggleNotifications.checked && Notification.permission === 'granted') {
      try {
        new Notification(title, {
          body,
          icon: '/favicon.svg'
        });
      } catch (err) {
        console.error('Desktop notification failed:', err);
      }
    }
  };

  // Get configured duration in seconds
  const getModeDurationSeconds = (mode: 'pomodoro' | 'short' | 'long') => {
    const minStr = localStorage.getItem(`pomodoro_duration_${mode}`);
    if (minStr) {
      return parseInt(minStr) * 60;
    }
    if (mode === 'pomodoro') return DEFAULT_WORK * 60;
    if (mode === 'short') return DEFAULT_SHORT * 60;
    return DEFAULT_LONG * 60;
  };

  // --- Preference settings management ---
  const initSettingsInputs = () => {
    if (settingsWork) settingsWork.value = (parseInt(localStorage.getItem('pomodoro_duration_pomodoro') || '') || DEFAULT_WORK).toString();
    if (settingsShort) settingsShort.value = (parseInt(localStorage.getItem('pomodoro_duration_short') || '') || DEFAULT_SHORT).toString();
    if (settingsLong) settingsLong.value = (parseInt(localStorage.getItem('pomodoro_duration_long') || '') || DEFAULT_LONG).toString();
    if (settingsGoal) settingsGoal.value = (parseInt(localStorage.getItem('pomodoro_goal') || '') || DEFAULT_GOAL).toString();
  };

  const saveSettings = () => {
    const workVal = Math.max(1, Math.min(180, parseInt(settingsWork.value) || DEFAULT_WORK));
    const shortVal = Math.max(1, Math.min(60, parseInt(settingsShort.value) || DEFAULT_SHORT));
    const longVal = Math.max(1, Math.min(60, parseInt(settingsLong.value) || DEFAULT_LONG));
    const goalVal = Math.max(1, Math.min(24, parseInt(settingsGoal.value) || DEFAULT_GOAL));

    localStorage.setItem('pomodoro_duration_pomodoro', workVal.toString());
    localStorage.setItem('pomodoro_duration_short', shortVal.toString());
    localStorage.setItem('pomodoro_duration_long', longVal.toString());
    localStorage.setItem('pomodoro_goal', goalVal.toString());

    // Update settings panel input fields
    settingsWork.value = workVal.toString();
    settingsShort.value = shortVal.toString();
    settingsLong.value = longVal.toString();
    settingsGoal.value = goalVal.toString();

    // Trigger UI updates
    updateAnalytics();
    if (!isRunning) {
      resetTimer();
    }
  };

  // --- Daily Analytics & Score calculations ---
  const checkDailyReset = () => {
    const today = getTodayString();
    const lastDate = localStorage.getItem('pomodoro_last_focus_date') || '';
    
    if (lastDate !== today) {
      // It's a new day! Reset daily totals
      localStorage.setItem('pomodoro_sessions_completed_today', '0');
      localStorage.setItem('pomodoro_breaks_taken_today', '0');
      localStorage.setItem('pomodoro_minutes_focused_today', '0');
      
      // Reset streak if last activity was before yesterday
      const yesterday = getYesterdayString();
      if (lastDate !== yesterday && lastDate !== '') {
        localStorage.setItem('pomodoro_streak_current', '0');
      }
    }
  };

  const incrementDailyStats = (mode: 'pomodoro' | 'short' | 'long', minutes: number) => {
    checkDailyReset();
    const today = getTodayString();
    localStorage.setItem('pomodoro_last_focus_date', today);

    if (mode === 'pomodoro') {
      // Focus Completed
      const completed = parseInt(localStorage.getItem('pomodoro_sessions_completed_today') || '0') + 1;
      const minutesFocused = parseInt(localStorage.getItem('pomodoro_minutes_focused_today') || '0') + minutes;
      
      localStorage.setItem('pomodoro_sessions_completed_today', completed.toString());
      localStorage.setItem('pomodoro_minutes_focused_today', minutesFocused.toString());
      
      // Update Daily Streak
      const lastDate = localStorage.getItem('pomodoro_last_focus_date_success') || '';
      if (lastDate !== today) {
        const currentStreak = parseInt(localStorage.getItem('pomodoro_streak_current') || '0');
        let newStreak = 1;
        
        if (lastDate === getYesterdayString()) {
          newStreak = currentStreak + 1;
        } else if (lastDate === today) {
          newStreak = currentStreak; // Already updated today
        }
        
        localStorage.setItem('pomodoro_streak_current', newStreak.toString());
        
        const longestStreak = parseInt(localStorage.getItem('pomodoro_streak_longest') || '0');
        if (newStreak > longestStreak) {
          localStorage.setItem('pomodoro_streak_longest', newStreak.toString());
        }
        localStorage.setItem('pomodoro_last_focus_date_success', today);
      }
    } else {
      // Break Completed
      const breaks = parseInt(localStorage.getItem('pomodoro_breaks_taken_today') || '0') + 1;
      localStorage.setItem('pomodoro_breaks_taken_today', breaks.toString());
    }
    
    updateAnalytics();
  };

  const updateAnalytics = () => {
    checkDailyReset();
    
    // Read stats from local storage
    const sessions = parseInt(localStorage.getItem('pomodoro_sessions_completed_today') || '0');
    const breaks = parseInt(localStorage.getItem('pomodoro_breaks_taken_today') || '0');
    const minutes = parseInt(localStorage.getItem('pomodoro_minutes_focused_today') || '0');
    const streak = parseInt(localStorage.getItem('pomodoro_streak_current') || '0');
    const longest = parseInt(localStorage.getItem('pomodoro_streak_longest') || '0');
    const goal = parseInt(localStorage.getItem('pomodoro_goal') || '') || DEFAULT_GOAL;
    
    // Update Stats Display elements
    if (statSessions) statSessions.textContent = sessions.toString();
    if (statGoalTotal) statGoalTotal.textContent = `/ ${goal}`;
    if (statStreak) statStreak.textContent = streak.toString();
    if (statLongestStreak) statLongestStreak.textContent = longest.toString();
    if (statTotalTime) statTotalTime.textContent = minutes.toLocaleString();

    // Goal Progress Bar
    const percentage = Math.min(100, Math.round((sessions / goal) * 100));
    if (statGoalBar) statGoalBar.style.width = `${percentage}%`;
    if (statGoalPercentage) statGoalPercentage.textContent = `${percentage}%`;

    // Dynamic Goal Dots
    if (goalDotsContainer) {
      goalDotsContainer.innerHTML = '';
      for (let i = 1; i <= goal; i++) {
        const dot = document.createElement('div');
        dot.className = `w-4 h-4 rounded-full border transition-all duration-300 ${
          i <= sessions 
            ? 'bg-link border-link shadow-sm shadow-link/20 flex items-center justify-center text-[8px] text-white font-bold' 
            : 'bg-canvas-soft-2 border-hairline'
        }`;
        if (i <= sessions) {
          dot.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><polyline points="20 6 9 17 4 12"/></svg>`;
        }
        goalDotsContainer.appendChild(dot);
      }
    }

    // Focus Score Gauge Calculation
    // Base formula: 20 points per Focus session, 5 points per break session. Capped at 100.
    const score = Math.min(100, (sessions * 20) + (breaks * 5));
    if (statFocusScore) statFocusScore.textContent = score.toString();

    // Color code and labels for focus score
    let label = 'Getting Started';
    let labelColor = 'text-mute';
    if (score > 80) {
      label = 'Flow State';
      labelColor = 'text-link';
    } else if (score > 50) {
      label = 'Productive';
      labelColor = 'text-ink';
    } else if (score > 20) {
      label = 'Focused';
      labelColor = 'text-body';
    }
    
    if (focusScoreLabel) {
      focusScoreLabel.textContent = label;
      focusScoreLabel.className = `text-xs font-semibold block mt-1 ${labelColor}`;
    }
  };

  // --- Session History management ---
  const saveSessionToHistory = (taskName: string, minutes: number, mode: 'pomodoro' | 'short' | 'long') => {
    const historyJson = localStorage.getItem('pomodoro_history') || '[]';
    let history = [];
    try {
      history = JSON.parse(historyJson);
    } catch (e) {
      history = [];
    }

    const d = new Date();
    const timeString = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    const dateString = d.toLocaleDateString([], { month: 'short', day: 'numeric', year: 'numeric' });

    const newSession = {
      task: taskName || (mode === 'pomodoro' ? 'Focus Session' : 'Rest Break'),
      duration: minutes,
      time: timeString,
      date: dateString,
      mode
    };

    history.unshift(newSession); // Add to top
    history = history.slice(0, 15); // Limit to 15 items
    localStorage.setItem('pomodoro_history', JSON.stringify(history));
    updateHistoryUI();
  };

  const updateHistoryUI = () => {
    const historyJson = localStorage.getItem('pomodoro_history') || '[]';
    let history = [];
    try {
      history = JSON.parse(historyJson);
    } catch (e) {
      history = [];
    }

    if (history.length === 0) {
      historyEmpty?.classList.remove('hidden');
      historyList?.classList.add('hidden');
      btnClearHistory?.classList.add('hidden');
    } else {
      historyEmpty?.classList.add('hidden');
      historyList?.classList.remove('hidden');
      btnClearHistory?.classList.remove('hidden');

      if (historyList) {
        historyList.innerHTML = '';
        history.forEach((session: any) => {
          const item = document.createElement('div');
          item.className = 'p-3 bg-canvas-soft-2/60 border border-hairline rounded-lg flex items-center justify-between text-xs transition-colors hover:bg-canvas-soft-2';
          
          const isWork = session.mode === 'pomodoro' || !session.mode;
          
          item.innerHTML = `
            <div class="flex items-center gap-2.5 truncate">
              <span class="w-1.5 h-1.5 rounded-full shrink-0 ${isWork ? 'bg-link' : 'bg-green-500'}"></span>
              <div class="truncate">
                <span class="font-semibold text-ink block truncate max-w-[160px] sm:max-w-[200px]" title="${session.task}">${session.task}</span>
                <span class="text-[10px] text-mute font-mono block">${session.date} • ${session.time}</span>
              </div>
            </div>
            <div class="text-right shrink-0">
              <span class="font-bold text-ink">${session.duration} min</span>
              <span class="text-[10px] text-mute block">${isWork ? 'focus' : 'break'}</span>
            </div>
          `;
          historyList.appendChild(item);
        });
      }
    }
  };

  // --- Task Input and Management ---
  const saveTaskToRecent = (task: string) => {
    if (!task || task.trim() === '') return;
    const cleanTask = task.trim();
    
    let recent = [];
    try {
      recent = JSON.parse(localStorage.getItem('pomodoro_recent_tasks') || '[]');
    } catch (e) {
      recent = [];
    }

    // Filter duplicates and push to front
    recent = recent.filter((t: string) => t.toLowerCase() !== cleanTask.toLowerCase());
    recent.unshift(cleanTask);
    recent = recent.slice(0, 5); // Keep up to 5 items

    localStorage.setItem('pomodoro_recent_tasks', JSON.stringify(recent));
    updateRecentTasksUI();
  };

  const updateRecentTasksUI = () => {
    let recent = [];
    try {
      recent = JSON.parse(localStorage.getItem('pomodoro_recent_tasks') || '[]');
    } catch (e) {
      recent = [];
    }

    if (recent.length === 0) {
      recentTasksContainer?.classList.add('hidden');
    } else {
      recentTasksContainer?.classList.remove('hidden');
      if (recentTasksList) {
        recentTasksList.innerHTML = '';
        recent.forEach((task: string) => {
          const tagBtn = document.createElement('button');
          tagBtn.className = 'px-2.5 py-1 text-[11px] font-semibold bg-canvas-soft-2 border border-hairline rounded-sm hover:border-link/30 hover:text-link text-body transition-all cursor-pointer truncate max-w-[120px]';
          tagBtn.textContent = task;
          tagBtn.title = task;
          tagBtn.type = 'button';
          tagBtn.addEventListener('click', () => {
            if (taskInput) {
              taskInput.value = task;
              // Trigger input event to update states if listening
            }
          });
          recentTasksList.appendChild(tagBtn);
        });
      }
    }
  };

  // --- Timer Core Engine ---
  const updateTimerDisplay = () => {
    const mins = Math.floor(timeLeft / 60);
    const secs = timeLeft % 60;
    const formatted = `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
    
    if (timerDisplay) {
      timerDisplay.textContent = formatted;
    }

    // Update Browser Document Title
    const statusSymbol = isRunning ? '▶ ' : '⏸ ';
    const modeLabel = currentMode === 'pomodoro' ? 'Focus' : 'Break';
    document.title = `${statusSymbol}${formatted} - ${modeLabel} | Tooltails`;

    // Circular ring progress update
    if (progressRing) {
      const progress = timeLeft / totalDuration;
      // Circumference is exactly 728.85
      const offset = 728.85 * (1 - progress);
      progressRing.style.strokeDashoffset = offset.toString();
    }
  };

  const setMode = (mode: 'pomodoro' | 'short' | 'long') => {
    currentMode = mode;
    timeLeft = getModeDurationSeconds(mode);
    totalDuration = timeLeft;
    
    // Toggle active state classes on tab buttons
    const tabs = [
      { el: modePomodoro, mode: 'pomodoro', color: 'bg-link text-white shadow-sm' },
      { el: modeShort, mode: 'short', color: 'bg-link text-white shadow-sm' },
      { el: modeLong, mode: 'long', color: 'bg-link text-white shadow-sm' }
    ];

    tabs.forEach(tab => {
      if (tab.el) {
        if (tab.mode === mode) {
          tab.el.className = `flex-1 py-2 px-4 rounded-full text-xs font-semibold transition-all cursor-pointer ${tab.color}`;
        } else {
          tab.el.className = "flex-1 py-2 px-4 rounded-full text-xs font-semibold text-body hover:text-ink hover:bg-canvas-soft transition-all cursor-pointer";
        }
      }
    });

    if (timerStatusText) {
      if (mode === 'pomodoro') {
        timerStatusText.textContent = 'Focus Time';
        if (progressRing) {
          progressRing.className = 'text-link transition-all duration-1000 ease-linear';
        }
      } else {
        timerStatusText.textContent = mode === 'short' ? 'Short Break' : 'Long Break';
        if (progressRing) {
          progressRing.className = 'text-green-500 transition-all duration-1000 ease-linear';
        }
      }
    }

    pauseTimer();
    updateTimerDisplay();
  };

  const startTimer = () => {
    if (isRunning) return;
    
    isRunning = true;
    
    // Switch Play/Pause icons
    iconPlay?.classList.add('hidden');
    iconPause?.classList.remove('hidden');
    
    // Lock in current task on starting Pomodoro
    if (currentMode === 'pomodoro') {
      currentTask = taskInput ? taskInput.value.trim() : '';
      if (currentTask) {
        saveTaskToRecent(currentTask);
        if (activeTaskName) activeTaskName.textContent = currentTask;
        taskInputContainer?.classList.add('hidden');
        activeTaskContainer?.classList.remove('hidden');
      } else {
        if (activeTaskName) activeTaskName.textContent = 'Focus Session';
        taskInputContainer?.classList.add('hidden');
        activeTaskContainer?.classList.remove('hidden');
      }
    }

    timerInterval = window.setInterval(() => {
      if (timeLeft > 0) {
        timeLeft--;
        updateTimerDisplay();
      } else {
        handleTimerCompletion();
      }
    }, 1000);
  };

  const pauseTimer = () => {
    if (!isRunning) return;
    isRunning = false;
    
    iconPlay?.classList.remove('hidden');
    iconPause?.classList.add('hidden');

    if (timerInterval) {
      clearInterval(timerInterval);
      timerInterval = null;
    }
  };

  const togglePlayPause = () => {
    if (isRunning) {
      pauseTimer();
    } else {
      startTimer();
    }
  };

  const resetTimer = () => {
    pauseTimer();
    timeLeft = getModeDurationSeconds(currentMode);
    totalDuration = timeLeft;
    updateTimerDisplay();
    
    // Release task input lock
    if (currentMode === 'pomodoro') {
      taskInputContainer?.classList.remove('hidden');
      activeTaskContainer?.classList.add('hidden');
    }
  };

  const skipTimer = () => {
    pauseTimer();
    handleTimerCompletion(true);
  };

  const handleTimerCompletion = (isSkipped = false) => {
    if (timerInterval) {
      clearInterval(timerInterval);
      timerInterval = null;
    }
    isRunning = false;
    iconPlay?.classList.remove('hidden');
    iconPause?.classList.add('hidden');

    const durationMins = Math.round(totalDuration / 60);

    if (!isSkipped) {
      playChime();
      
      // Update statistics and history logs
      if (currentMode === 'pomodoro') {
        incrementDailyStats('pomodoro', durationMins);
        saveSessionToHistory(currentTask, durationMins, 'pomodoro');
        triggerNotification("Focus Session Completed!", `Great job! Your ${durationMins}-minute focus session is complete.`);
      } else {
        incrementDailyStats(currentMode, durationMins);
        saveSessionToHistory(currentMode === 'short' ? 'Short Break' : 'Long Break', durationMins, currentMode);
        triggerNotification("Break Over!", "Time to start focusing again. Let's get to work!");
      }
    }

    // Auto-transition to next session mode
    if (currentMode === 'pomodoro') {
      // Find out if we should trigger a long break or short break
      // Take a long break after 4 completed focus sessions today
      const todaySessions = parseInt(localStorage.getItem('pomodoro_sessions_completed_today') || '0');
      const goal = parseInt(localStorage.getItem('pomodoro_goal') || '') || DEFAULT_GOAL;
      
      if (todaySessions > 0 && todaySessions % goal === 0) {
        setMode('long');
      } else {
        setMode('short');
      }
    } else {
      setMode('pomodoro');
      // Show task input field again for new Pomodoro
      taskInputContainer?.classList.remove('hidden');
      activeTaskContainer?.classList.add('hidden');
    }

    // Auto-Start preferences check
    if (toggleAutostart && toggleAutostart.checked) {
      // Small timeout to allow progress ring layout rendering to reset nicely
      setTimeout(() => {
        startTimer();
      }, 300);
    }
  };

  // --- Notification Permissions Handling ---
  const requestNotificationPermission = () => {
    if (!('Notification' in window)) {
      alert('Desktop notifications are not supported by this browser.');
      if (toggleNotifications) toggleNotifications.checked = false;
      return;
    }

    if (Notification.permission === 'default') {
      Notification.requestPermission().then(permission => {
        if (permission === 'granted') {
          localStorage.setItem('pomodoro_notifications_enabled', 'true');
          if (toggleNotifications) toggleNotifications.checked = true;
        } else {
          localStorage.setItem('pomodoro_notifications_enabled', 'false');
          if (toggleNotifications) toggleNotifications.checked = false;
        }
      });
    } else if (Notification.permission === 'granted') {
      localStorage.setItem('pomodoro_notifications_enabled', 'true');
    } else {
      alert('Notifications are blocked by browser settings. Please enable them in site settings.');
      localStorage.setItem('pomodoro_notifications_enabled', 'false');
      if (toggleNotifications) toggleNotifications.checked = false;
    }
  };

  // --- Click & Event Listeners binding ---
  
  // Tabs and Modes selection
  modePomodoro?.addEventListener('click', () => setMode('pomodoro'));
  modeShort?.addEventListener('click', () => setMode('short'));
  modeLong?.addEventListener('click', () => setMode('long'));

  // Main buttons trigger
  btnPlayPause?.addEventListener('click', togglePlayPause);
  btnReset?.addEventListener('click', resetTimer);
  btnSkip?.addEventListener('click', skipTimer);

  // Mark task completed button action
  btnCompleteTask?.addEventListener('click', () => {
    if (isRunning && currentMode === 'pomodoro') {
      handleTimerCompletion();
    } else {
      // Just release container back to input
      taskInputContainer?.classList.remove('hidden');
      activeTaskContainer?.classList.add('hidden');
      if (taskInput) taskInput.value = '';
    }
  });

  // Settings Accordion panel toggle
  btnToggleSettings?.addEventListener('click', () => {
    const isExpanded = btnToggleSettings.getAttribute('aria-expanded') === 'true';
    btnToggleSettings.setAttribute('aria-expanded', String(!isExpanded));
    settingsPanel?.classList.toggle('hidden');
  });

  // Custom durations forms actions
  btnSaveSettings?.addEventListener('click', () => {
    saveSettings();
    btnToggleSettings?.setAttribute('aria-expanded', 'false');
    settingsPanel?.classList.add('hidden');
  });

  btnResetDurations?.addEventListener('click', () => {
    if (settingsWork) settingsWork.value = DEFAULT_WORK.toString();
    if (settingsShort) settingsShort.value = DEFAULT_SHORT.toString();
    if (settingsLong) settingsLong.value = DEFAULT_LONG.toString();
    if (settingsGoal) settingsGoal.value = DEFAULT_GOAL.toString();
    saveSettings();
    btnToggleSettings?.setAttribute('aria-expanded', 'false');
    settingsPanel?.classList.add('hidden');
  });

  // Clear session history button action
  btnClearHistory?.addEventListener('click', () => {
    if (confirm('Are you sure you want to clear your session logs? This cannot be undone.')) {
      localStorage.setItem('pomodoro_history', '[]');
      updateHistoryUI();
    }
  });

  // Audio preference toggling
  toggleSound?.addEventListener('change', () => {
    localStorage.setItem('pomodoro_sound_enabled', String(toggleSound.checked));
  });

  // Notifications preference toggling
  toggleNotifications?.addEventListener('change', () => {
    if (toggleNotifications.checked) {
      requestNotificationPermission();
    } else {
      localStorage.setItem('pomodoro_notifications_enabled', 'false');
    }
  });

  // Auto-Start preference toggling
  toggleAutostart?.addEventListener('change', () => {
    localStorage.setItem('pomodoro_autostart_enabled', String(toggleAutostart.checked));
  });

  // Keyboard Shortcuts (Space for Start/Pause)
  window.addEventListener('keydown', (e) => {
    // Only capture space if the user is not actively typing inside input fields
    if (e.code === 'Space' && document.activeElement !== taskInput && document.activeElement?.tagName !== 'INPUT') {
      e.preventDefault(); // Stop window scroll
      togglePlayPause();
    }
  });

  // --- Initializing App State on Page Load ---
  const initApp = () => {
    checkDailyReset();
    initSettingsInputs();
    
    // Load local storage options toggles
    if (toggleSound) {
      toggleSound.checked = localStorage.getItem('pomodoro_sound_enabled') !== 'false';
    }
    if (toggleAutostart) {
      toggleAutostart.checked = localStorage.getItem('pomodoro_autostart_enabled') === 'true';
    }
    if (toggleNotifications) {
      const notifEnabled = localStorage.getItem('pomodoro_notifications_enabled') === 'true';
      toggleNotifications.checked = notifEnabled && Notification.permission === 'granted';
    }

    // Set default initial timer duration
    setMode('pomodoro');
    
    // Render logs
    updateAnalytics();
    updateHistoryUI();
    updateRecentTasksUI();
  };

  // Run initialization
  initApp();
</script>
