---
import Layout from "../layouts/Layout.astro";
import PomodoroHeader from "../components/pomodoro/PomodoroHeader.astro";
import FAQ from "../components/ui/FAQ.astro";
import Card from "../components/ui/Card.astro";
import Button from "../components/ui/Button.astro";
import Input from "../components/ui/Input.astro";

const faqItems = [
  {
    question: "What is the Pomodoro Technique?",
    answer: "The Pomodoro Technique is a time-management method developed by Francesco Cirillo in the late 1980s. It uses a timer to break work down into intervals, traditionally 25 minutes in length, separated by 5-minute breaks. These intervals are named pomodoros, the plural in English of the Italian word pomodoro (tomato), after the tomato-shaped kitchen timer Cirillo used as a university student."
  },
  {
    question: "How long should Pomodoro breaks be?",
    answer: "Traditionally, short breaks are 5 minutes and long breaks are 15 to 30 minutes. Typically, a long break is taken after completing a cycle of four Pomodoro focus sessions. Our timer allows you to customize these durations to match your personal workflow."
  },
  {
    question: "Can I customize the timer durations?",
    answer: "Yes, absolutely! You can customize the work session length, short break length, long break length, and your daily Pomodoro goal directly in the settings panel of our Pomodoro Timer."
  },
  {
    question: "How is the Productivity Score calculated?",
    answer: "Your daily productivity score ranges from 0 to 100. It increases by 20 points for each completed Pomodoro focus session and 5 points for each scheduled break you take. This gamified metric motivates you to maintain a healthy and consistent focus routine throughout the day."
  },
  {
    question: "Is the Pomodoro Technique good for studying?",
    answer: "Yes, the Pomodoro Technique is excellent for studying. Breaking study sessions into 25-minute blocks helps maintain concentration, prevents mental fatigue, and makes large subjects feel more manageable. Many students report improved retention and reduced procrastination when using this method."
  },
  {
    question: "Can I use Pomodoro for coding?",
    answer: "Absolutely. Software developers and programmers widely use the Pomodoro Technique to enter deep focus states. The 25-minute sprint is ideal for writing code, debugging, or code review before taking a short break to recharge. It helps prevent burnout during long coding sessions."
  },
  {
    question: "Does this timer work offline?",
    answer: "Yes, the Tooltails Pomodoro Timer works fully offline. All timer logic, session history, streaks, and analytics are stored locally in your browser using localStorage. No data is sent to any server."
  },
  {
    question: "Is there a daily goal or streak tracker?",
    answer: "Yes, you can set a daily Pomodoro goal (default is 4 sessions). The timer tracks your daily streak, longest streak, total focus minutes, and a productivity score. Goal progress is shown as visual dots and a percentage bar."
  },
  {
    question: "What happens when I complete my daily goal?",
    answer: "When you reach your daily Pomodoro goal, the progress bar shows 100%, all goal dots turn green with checkmarks, and your productivity score updates. This visual feedback helps maintain momentum and motivates you to keep going."
  },
  {
    question: "Does the timer support browser notifications?",
    answer: "Yes, it supports browser desktop notifications to alert you when a session ends, even if you are working in another browser tab. You can enable or disable this in the preferences panel."
  },
  {
    question: "How do I reset my session history?",
    answer: "You can clear your session history by clicking the 'Clear' button in the Session History section. A confirmation prompt will appear before the data is permanently deleted."
  },
  {
    question: "What is the difference between Pomodoro and time blocking?",
    answer: "Pomodoro uses fixed intervals (traditionally 25 minutes) with scheduled breaks, while time blocking assigns specific tasks to dedicated time slots in your calendar. Pomodoro is more rigid and rhythm-based, whereas time blocking is task-driven and flexible."
  },
  {
    question: "Can Pomodoro help with ADHD?",
    answer: "Yes, many people with ADHD find the Pomodoro Technique helpful. The short, structured work intervals reduce overwhelm, the timer creates external accountability, and frequent breaks accommodate shorter attention spans. The visual progress tracking provides motivation and a sense of achievement."
  },
  {
    question: "How many Pomodoros should I do per day?",
    answer: "Most people aim for 4 to 8 Pomodoros per day (roughly 2 to 4 hours of focused work). Beginners should start with 2-4 and gradually increase. The key is consistency over volume. Our timer lets you set a custom daily goal that works for you."
  },
  {
    question: "Does this tool save my data between sessions?",
    answer: "Yes, all your data is saved locally in your browser. When you return to the page, your streak, session history, settings, and daily progress are restored. Clearing your browser data will reset this information."
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
    { "@type": "ListItem", "position": 2, "name": "Pomodoro Timer", "item": "https://tooltails.com/pomodoro-timer" }
  ]
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Tooltails Pomodoro Timer - Focus & Productivity Timer",
  "operatingSystem": "All",
  "applicationCategory": "ProductivityApplication",
  "description": "Free Pomodoro Timer with task tracking, daily streaks, focus analytics, session history, and productivity scoring. Stay focused and get more done with Tooltails.",
  "browserRequirements": "Requires JavaScript. Requires HTML5.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": "Task tracking, Daily streaks, Focus analytics, Productivity score, Session history, Custom durations, Sound notifications, Desktop notifications, Offline support"
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Pomodoro Timer That Tracks Real Progress - Tooltails",
  "description": "Stay focused, build streaks, measure productivity, and turn work sessions into completed goals with the Tooltails Pomodoro Timer. Free, no login required.",
  "url": "https://tooltails.com/pomodoro-timer"
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Tooltails Pomodoro",
  "url": "https://tooltails.com/pomodoro-timer",
  "description": "Free Pomodoro Timer with task tracking, daily streaks, focus analytics, session history, and productivity scoring."
};
---

<Layout
  title="Pomodoro Timer That Tracks Real Progress – Free Focus Timer | Tooltails"
  description="Stay focused, build streaks, measure productivity, and turn work sessions into completed goals. Free Pomodoro Timer with task tracking, focus analytics, and daily streaks. No login required."
  image="/og-image.png"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <PomodoroHeader />

  <div class="max-w-[1600px] mx-auto px-4 sm:px-6 pt-4 pb-2">
    <!-- Compact Hero -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2 mb-4">
      <div>
        <h1 class="text-xl sm:text-2xl md:text-3xl font-extrabold tracking-tight text-ink">Pomodoro Timer</h1>
        <p class="text-sm text-body/70">Stay focused, build streaks, measure productivity.</p>
      </div>
      <div class="flex flex-wrap gap-1.5">
        <span class="inline-flex items-center gap-1 px-2.5 py-1 text-[10px] font-semibold bg-success/5 text-link rounded-full border border-link/10">Free</span>
        <span class="inline-flex items-center gap-1 px-2.5 py-1 text-[10px] font-semibold bg-canvas-soft-2 text-ink rounded-full border border-hairline">No Login</span>
        <span class="inline-flex items-center gap-1 px-2.5 py-1 text-[10px] font-semibold bg-canvas-soft-2 text-ink rounded-full border border-hairline">Works Offline</span>
        <span class="inline-flex items-center gap-1 px-2.5 py-1 text-[10px] font-semibold bg-canvas-soft-2 text-ink rounded-full border border-hairline">Local Privacy</span>
      </div>
    </div>

    <!-- Main Grid: Timer + Stats -->
    <div class="grid grid-cols-1 lg:grid-cols-[1fr,380px] gap-4 items-start">

      <!-- LEFT: TIMER CARD -->
      <div class="bg-canvas rounded-2xl border border-hairline/60 card-shadow p-5 md:p-6">
        <!-- Mode Tabs -->
        <div class="flex justify-center gap-1 p-1 bg-canvas-soft-2 rounded-full max-w-sm mx-auto mb-5 border border-hairline">
          <button id="mode-pomodoro" class="flex-1 py-2.5 px-4 min-h-11 rounded-full text-xs font-semibold transition-all cursor-pointer bg-link text-white shadow-sm" aria-label="Switch to Pomodoro focus session">Pomodoro</button>
          <button id="mode-short" class="flex-1 py-2.5 px-4 min-h-11 rounded-full text-xs font-semibold text-body hover:text-ink hover:bg-canvas-soft transition-all cursor-pointer" aria-label="Switch to short break">Short Break</button>
          <button id="mode-long" class="flex-1 py-2.5 px-4 min-h-11 rounded-full text-xs font-semibold text-body hover:text-ink hover:bg-canvas-soft transition-all cursor-pointer" aria-label="Switch to long break">Long Break</button>
        </div>

        <!-- Timer Ring -->
        <div class="relative w-full max-w-[280px] aspect-square mx-auto flex items-center justify-center mb-5">
          <svg class="w-full h-full transform -rotate-90" viewBox="0 0 256 256">
            <circle cx="128" cy="128" r="116" stroke="currentColor" stroke-width="8" fill="transparent" class="text-hairline" />
            <circle id="timer-progress-ring" cx="128" cy="128" r="116" stroke="currentColor" stroke-width="8" fill="transparent" stroke-dasharray="728.85" stroke-dashoffset="0" stroke-linecap="round" class="text-link transition-all duration-1000 ease-linear" />
          </svg>
          <div class="absolute flex flex-col items-center justify-center select-none">
            <span id="timer-display" class="text-5xl md:text-6xl font-extrabold tracking-tighter text-ink tabular-nums leading-none">25:00</span>
            <span id="timer-status-text" class="text-[10px] font-mono text-mute uppercase tracking-[0.2em] mt-2">Focus Time</span>
            <span id="timer-phase" class="text-[10px] font-medium text-link/70 mt-1.5 opacity-0 transition-all duration-500">One session at a time.</span>
          </div>
        </div>

        <!-- Controls -->
        <div class="flex justify-center items-center gap-4 mb-5">
          <button id="btn-reset" class="w-11 h-11 rounded-full border border-hairline bg-canvas text-body hover:text-ink hover:bg-canvas-soft-2 transition-all flex items-center justify-center cursor-pointer active:scale-95 shadow-sm" title="Reset Timer" aria-label="Reset Timer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
          </button>
          <button id="btn-play-pause" class="w-14 h-14 rounded-full bg-link text-white hover:bg-link-hover transition-all flex items-center justify-center cursor-pointer active:scale-95 shadow-lg shadow-link/25" title="Start Timer (Spacebar)" aria-label="Start or Pause Timer">
            <svg id="icon-play" class="ml-0.5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 3 20 12 6 21 6 3"/></svg>
            <svg id="icon-pause" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><rect x="14" y="4" width="4" height="16" rx="1"/><rect x="6" y="4" width="4" height="16" rx="1"/></svg>
          </button>
          <button id="btn-skip" class="w-11 h-11 rounded-full border border-hairline bg-canvas text-body hover:text-ink hover:bg-canvas-soft-2 transition-all flex items-center justify-center cursor-pointer active:scale-95 shadow-sm" title="Skip Session" aria-label="Skip Session">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" x2="19" y1="5" y2="19"/></svg>
          </button>
        </div>

        <!-- Today's Intention -->
        <div id="intention-card" class="hidden border-t border-hairline pt-4 pb-3 max-w-md mx-auto">
          <div class="bg-canvas-soft rounded-xl border border-hairline p-3.5">
            <span class="text-[9px] font-mono text-mute uppercase tracking-wider block mb-1">Today's Intention</span>
            <p id="intention-text" class="text-sm font-semibold text-ink leading-snug">Finish what matters most.</p>
          </div>
        </div>

        <!-- Task -->
        <div class="border-t border-hairline pt-4 max-w-md mx-auto">
          <div id="active-task-container" class="hidden flex items-center justify-between p-3 bg-link/5 rounded-xl border border-link/10 animate-in fade-in duration-300">
            <div class="flex items-center gap-2.5 min-w-0">
              <div class="w-2 h-2 rounded-full bg-link animate-pulse shrink-0"></div>
              <div class="min-w-0">
                <span class="block text-[9px] font-mono text-link uppercase tracking-wider">Focusing On</span>
                <span id="active-task-name" class="text-sm font-bold text-ink truncate block">Study DSA</span>
              </div>
            </div>
            <button id="btn-complete-task" class="min-h-11 px-3 py-2 text-xs font-semibold text-link hover:text-link-hover cursor-pointer border border-link/20 bg-canvas hover:bg-link/5 rounded-lg shrink-0 ml-2">Done</button>
          </div>
          <div id="task-input-container" class="space-y-2">
            <Input id="task-input" label="What are you working on?" placeholder="What's the one thing you'll finish next?" />
            <div id="recent-tasks-container" class="hidden">
              <span class="text-[10px] text-mute block mb-1 font-medium">Recent tasks:</span>
              <div id="recent-tasks-list" class="flex flex-wrap gap-1.5"></div>
            </div>
          </div>
        </div>

        <!-- Preferences -->
        <div class="border-t border-hairline mt-4 pt-4 max-w-md mx-auto">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-3">
              <label class="relative inline-flex items-center cursor-pointer select-none">
                <input type="checkbox" id="toggle-sound" class="sr-only peer" checked />
                <div class="w-9 h-5 bg-canvas-soft-2 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[1px] after:left-[1px] after:bg-white after:border-hairline after:border after:rounded-full after:h-[18px] after:w-[18px] after:transition-all peer-checked:bg-link border border-hairline"></div>
              </label>
              <span class="text-xs font-medium text-ink">Sound</span>
              <label class="relative inline-flex items-center cursor-pointer select-none">
                <input type="checkbox" id="toggle-notifications" class="sr-only peer" />
                <div class="w-9 h-5 bg-canvas-soft-2 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[1px] after:left-[1px] after:bg-white after:border-hairline after:border after:rounded-full after:h-[18px] after:w-[18px] after:transition-all peer-checked:bg-link border border-hairline"></div>
              </label>
              <span class="text-xs font-medium text-ink">Alerts</span>
              <label class="relative inline-flex items-center cursor-pointer select-none">
                <input type="checkbox" id="toggle-autostart" class="sr-only peer" />
                <div class="w-9 h-5 bg-canvas-soft-2 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[1px] after:left-[1px] after:bg-white after:border-hairline after:border after:rounded-full after:h-[18px] after:w-[18px] after:transition-all peer-checked:bg-link border border-hairline"></div>
              </label>
              <span class="text-xs font-medium text-ink">Auto</span>
            </div>
            <button id="btn-toggle-settings" class="flex items-center gap-1 min-h-11 px-2.5 py-2 text-[10px] text-mute hover:text-ink font-semibold cursor-pointer" aria-expanded="false" aria-label="Toggle settings panel">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              Custom
            </button>
          </div>
          <div id="settings-panel" class="hidden mt-4 pt-4 border-t border-hairline space-y-3 animate-in slide-in-from-top-4 duration-300">
            <h4 class="text-[10px] font-bold text-ink uppercase tracking-wider">Custom Durations (Minutes)</h4>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
              <Input type="number" id="settings-work" label="Focus" min="1" max="180" placeholder="25" />
              <Input type="number" id="settings-short" label="Short Break" min="1" max="60" placeholder="5" />
              <Input type="number" id="settings-long" label="Long Break" min="1" max="60" placeholder="15" />
              <Input type="number" id="settings-goal" label="Daily Goal" min="1" max="24" placeholder="4" />
            </div>
            <div class="flex justify-end gap-2 pt-1">
              <Button variant="secondary" size="sm" id="btn-reset-durations">Defaults</Button>
              <Button size="sm" id="btn-save-settings">Save Settings</Button>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: EMOTIONAL DASHBOARD -->
      <div class="space-y-3">

        <!-- Today's Wins -->
        <div class="bg-canvas rounded-2xl border border-hairline/60 card-shadow p-4">
          <span class="text-[9px] font-mono text-mute uppercase tracking-wider block mb-3 flex items-center gap-1.5">
            <svg class="w-3 h-3 text-link" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Today's Wins
          </span>
          <div class="grid grid-cols-3 gap-2">
            <div class="text-center">
              <span id="stat-sessions" class="text-xl font-extrabold text-ink tracking-tight block">0</span>
              <span id="stat-goal-total" class="text-[9px] text-mute">/ <span id="stat-goal-number">4</span> sessions</span>
            </div>
            <div class="text-center">
              <span id="stat-total-time" class="text-xl font-extrabold text-ink tracking-tight block">0</span>
              <span class="text-[9px] text-mute">min focused</span>
            </div>
            <div class="text-center">
              <span id="stat-focus-score" class="text-xl font-extrabold text-ink tracking-tight block">0</span>
              <span id="focus-score-label" class="text-[9px] text-mute">pts</span>
            </div>
          </div>
          <div class="mt-2">
            <div class="w-full bg-hairline/60 h-1 rounded-full overflow-hidden">
              <div id="stat-goal-bar" class="bg-link h-full transition-all duration-500 rounded-full" style="width: 0%"></div>
            </div>
            <span id="stat-goal-percentage" class="text-[8px] text-mute mt-0.5 block">0% of daily goal</span>
          </div>
        </div>

        <!-- Momentum -->
        <div class="bg-canvas rounded-2xl border border-hairline/60 card-shadow p-4">
          <span class="text-[9px] font-mono text-mute uppercase tracking-wider block mb-3 flex items-center gap-1.5">
            <svg class="w-3 h-3 text-orange-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
            Momentum
          </span>
          <div class="grid grid-cols-3 gap-2">
            <div class="text-center">
              <span id="stat-streak" class="text-xl font-extrabold text-ink tracking-tight block">0</span>
              <span class="text-[9px] text-mute">day streak</span>
            </div>
            <div class="text-center">
              <span id="stat-longest-streak" class="text-xl font-extrabold text-ink tracking-tight block">0</span>
              <span class="text-[9px] text-mute">best streak</span>
            </div>
            <div class="text-center">
              <span id="weekly-consistency" class="text-xl font-extrabold text-ink tracking-tight block">0%</span>
              <span class="text-[9px] text-mute">this week</span>
            </div>
          </div>
        </div>

        <!-- Focus Journey -->
        <div class="bg-canvas rounded-2xl border border-hairline/60 card-shadow p-4">
          <span class="text-[9px] font-mono text-mute uppercase tracking-wider block mb-3 flex items-center gap-1.5">
            <svg class="w-3 h-3 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
            Focus Journey
          </span>
          <div class="grid grid-cols-2 gap-2">
            <div class="text-center">
              <span id="total-sessions-all" class="text-xl font-extrabold text-ink tracking-tight block">0</span>
              <span class="text-[9px] text-mute">total sessions</span>
            </div>
            <div class="text-center">
              <span id="total-hours-all" class="text-xl font-extrabold text-ink tracking-tight block">0</span>
              <span class="text-[9px] text-mute">hours focused</span>
            </div>
          </div>
          <div id="milestone-text" class="text-[9px] text-link font-semibold text-center mt-2 hidden"></div>
        </div>

        <!-- Insights -->
        <div id="insights-card" class="bg-canvas-soft rounded-2xl border border-hairline/60 card-shadow p-4">
          <span class="text-[9px] font-mono text-mute uppercase tracking-wider block mb-2 flex items-center gap-1.5">
            <svg class="w-3 h-3 text-purple-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            Insights
          </span>
          <p id="insight-text" class="text-xs text-body leading-relaxed">Complete your first session to unlock personalized insights.</p>
        </div>

        <!-- Session History -->
        <div class="bg-canvas rounded-2xl border border-hairline/60 card-shadow p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-[9px] font-mono text-mute uppercase tracking-wider">Session History</span>
            <button id="btn-clear-history" class="hidden min-h-11 px-2 py-1.5 text-[9px] font-bold text-red-600 hover:text-red-500 uppercase tracking-widest cursor-pointer">Clear</button>
          </div>
          <div id="history-empty" class="py-6 px-3 text-center border border-dashed border-hairline rounded-xl bg-canvas-soft">
            <div class="w-8 h-8 rounded-full bg-canvas-soft-2 border border-hairline mx-auto flex items-center justify-center text-mute mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <p class="text-xs font-semibold text-ink">Your focus journey starts today</p>
            <p class="text-[10px] text-mute mt-0.5 mb-3">Every expert starts with a single focused session.</p>
