---
import Layout from "../layouts/Layout.astro";
import PomodoroHeader from "../components/pomodoro/PomodoroHeader.astro";
import FAQ from "../components/ui/FAQ.astro";
import Card from "../components/ui/Card.astro";
import Button from "../components/ui/Button.astro";
import Input from "../components/ui/Input.astro";

const faqItems = [
  {
    question: "What is the Pomodoro Technique?",
    answer: "The Pomodoro Technique is a time-management method developed by Francesco Cirillo in the late 1980s. It uses a timer to break work down into intervals, traditionally 25 minutes in length, separated by 5-minute breaks. These intervals are named pomodoros, the plural in English of the Italian word pomodoro (tomato), after the tomato-shaped kitchen timer Cirillo used as a university student."
  },
  {
    question: "How long should Pomodoro breaks be?",
    answer: "Traditionally, short breaks are 5 minutes and long breaks are 15 to 30 minutes. Typically, a long break is taken after completing a cycle of four Pomodoro focus sessions. Our timer allows you to customize these durations to match your personal workflow."
  },
  {
    question: "Can I customize the timer durations?",
    answer: "Yes, absolutely! You can customize the work session length, short break length, long break length, and your daily Pomodoro goal directly in the settings panel of our Pomodoro Timer."
  },
  {
    question: "How is the Flow Score calculated?",
    answer: "Your Flow Score ranges from 0 to 100 and reflects your daily focus rhythm. It grows with every session and break you take — 20 points for each focus session and 5 points for each scheduled break. Think of it as a gentle nudge to keep a healthy, balanced routine throughout the day."
  },
  {
    question: "Is the Pomodoro Technique good for studying?",
    answer: "Yes, the Pomodoro Technique is excellent for studying. Breaking study sessions into 25-minute blocks helps maintain concentration, prevents mental fatigue, and makes large subjects feel more manageable. Many students report improved retention and reduced procrastination when using this method."
  },
  {
    question: "Can I use Pomodoro for coding?",
    answer: "Absolutely. Software developers and programmers widely use the Pomodoro Technique to enter deep focus states. The 25-minute block is ideal for writing code, debugging, or code review before taking a short break to recharge. It helps prevent burnout during long coding sessions."
  },
  {
    question: "Does this timer work offline?",
    answer: "Yes, everything runs right in your browser. Your streaks, session history, and settings are stored locally — nothing is sent to any server. You can use it completely offline."
  },
  {
    question: "Is there a daily goal or streak tracker?",
    answer: "Yes, you can set a daily goal (default is 4 sessions). The timer tracks your streak, your longest streak, total focus time, and a flow score. Progress is shown with simple visual dots and a progress bar."
  },
  {
    question: "What happens when I complete my daily goal?",
    answer: "When you reach your daily goal, the progress bar fills up, the dots turn green with checkmarks, and your flow score updates. It's a small celebration of a good day's work."
  },
  {
    question: "Does the timer support browser notifications?",
    answer: "Yes, it can send a notification to your desktop when a session ends, even if you're in another tab. You can turn this on or off in the settings panel."
  },
  {
    question: "How do I reset my session history?",
    answer: "You can clear your session history by clicking the 'Clear' button in the Your Sessions section. A confirmation prompt will appear before the data is removed."
  },
  {
    question: "What is the difference between Pomodoro and time blocking?",
    answer: "Pomodoro uses fixed intervals (traditionally 25 minutes) with scheduled breaks, while time blocking assigns specific tasks to dedicated time slots in your calendar. Pomodoro is more rhythm-based, whereas time blocking is task-driven and flexible."
  },
  {
    question: "Can Pomodoro help with ADHD?",
    answer: "Yes, many people with ADHD find the Pomodoro Technique helpful. The short, structured work intervals reduce overwhelm, the timer creates external accountability, and frequent breaks accommodate shorter attention spans. The visual progress tracking provides a sense of achievement."
  },
  {
    question: "How many Pomodoros should I do per day?",
    answer: "Most people aim for 4 to 8 Pomodoros per day (roughly 2 to 4 hours of focused work). Beginners should start with 2-4 and gradually increase. The key is consistency over volume. Our timer lets you set a custom daily goal that works for you."
  },
  {
    question: "Does this tool save my data between sessions?",
    answer: "Yes, all your data is saved locally in your browser. When you return to the page, your streak, session history, settings, and daily progress are restored. Clearing your browser data will reset this information."
  }
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
    { "@type": "ListItem", "position": 2, "name": "Pomodoro Timer", "item": "https://tooltails.com/pomodoro-timer" }
  ]
};

const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Tooltails Pomodoro Timer - Focus & Productivity Timer",
  "operatingSystem": "All",
  "applicationCategory": "ProductivityApplication",
  "description": "Free Pomodoro Timer with task tracking, daily streaks, focus analytics, session history, and productivity scoring. Stay focused and get more done with Tooltails.",
  "browserRequirements": "Requires JavaScript. Requires HTML5.",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "featureList": "Task tracking, Daily streaks, Focus analytics, Productivity score, Session history, Custom durations, Sound notifications, Desktop notifications, Offline support"
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Pomodoro Timer That Tracks Real Progress - Tooltails",
  "description": "Stay focused, build streaks, measure productivity, and turn work sessions into completed goals with the Tooltails Pomodoro Timer. Free, no login required.",
  "url": "https://tooltails.com/pomodoro-timer"
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Tooltails Pomodoro",
  "url": "https://tooltails.com/pomodoro-timer",
  "description": "Free Pomodoro Timer with task tracking, daily streaks, focus analytics, session history, and productivity scoring."
};
---

<Layout
  title="Pomodoro Timer That Tracks Real Progress – Free Focus Timer | Tooltails"
  description="Stay focused, build streaks, measure productivity, and turn work sessions into completed goals. Free Pomodoro Timer with task tracking, focus analytics, and daily streaks. No login required."
  image="/og-image.png"
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- Pomodoro badge (integrated, not a second header) -->
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 pt-2 pb-0">
    <div class="flex items-center gap-2 text-xs font-semibold text-mute">
      <svg class="w-3.5 h-3.5 text-link" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span>Pomodoro Timer</span>
      <span class="w-2 h-px bg-hairline"></span>
      <a href="/pomodoro-timer/blog" class="text-link hover:text-link-hover transition-colors">Blog</a>
      <span class="text-hairline">·</span>
      <a href="/pomodoro-timer/contact" class="text-link hover:text-link-hover transition-colors">Contact</a>
    </div>
  </div>

  <!-- DASHBOARD HERO — 2-column dashboard layout -->
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6 py-3 md:py-4">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr,1.15fr] gap-5 items-start">

      <!-- LEFT: Headline + Focus + Progress + Stats -->
      <div class="space-y-4">

        <div>
          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold tracking-tight text-ink leading-[1.05]">Pomodoro<br>Timer</h1>
          <p class="text-lg md:text-xl text-body/70 mt-1.5">Focus deeply. Rest well. Grow every day.</p>
        </div>

        <!-- Focus + Progress Card -->
        <div class="bg-canvas rounded-2xl border border-hairline/60 card-shadow p-5 md:p-6">
          <!-- Current Focus -->
          <div class="mb-4">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-2.5 h-2.5 rounded-full bg-link shrink-0"></div>
              <span class="text-base font-bold text-ink">Your Focus</span>
            </div>
            <div id="active-task-container" class="hidden">
              <div class="flex items-center gap-2">
                <div class="w-2.5 h-2.5 rounded-full bg-link animate-pulse shrink-0"></div>
                <span id="active-task-name" class="text-lg font-extrabold text-ink tracking-tight truncate">Study DSA</span>
              </div>
            </div>
            <div id="task-input-container">
              <input id="task-input" type="text" placeholder="What will you accomplish this session?" class="w-full text-lg font-extrabold text-ink tracking-tight bg-transparent border-none outline-none placeholder:text-mute/30 p-0" />
            </div>
          </div>

          <!-- Daily Goal Progress -->
          <div class="mb-4">
            <div class="flex items-center justify-between mb-1.5">
              <span id="session-counter-text" class="text-base font-bold text-ink">Ready to begin</span>
              <span class="text-sm font-semibold text-mute" id="stat-goal-percentage">0%</span>
            </div>
            <div class="w-full h-3 bg-hairline/60 rounded-full overflow-hidden">
              <div id="stat-goal-bar" class="bg-link h-full transition-all duration-500 rounded-full" style="width: 0%"></div>
            </div>
            <p id="stat-encouragement" class="text-sm md:text-base text-body mt-2">Take the first step — start your first session.</p>
          </div>

          <!-- Metric row (bigger numbers) -->
          <div class="grid grid-cols-4 gap-0 pt-3 border-t border-hairline/40">
            <div class="text-center">
              <span id="stat-total-time" class="text-3xl md:text-4xl font-bold text-ink">0m</span>
              <span class="text-xs text-mute block mt-0.5 font-medium">focused</span>
            </div>
            <div class="text-center border-x border-hairline/40">
              <span id="stat-streak" class="text-3xl md:text-4xl font-bold text-orange-500">0</span>
              <span class="text-xs text-mute block mt-0.5 font-medium">streak</span>
            </div>
            <div class="text-center">
              <span id="stat-sessions" class="text-3xl md:text-4xl font-bold text-ink">0</span>
              <span class="text-xs text-mute block mt-0.5 font-medium">today</span>
            </div>
            <div class="text-center border-l border-hairline/40">
              <span id="stat-focus-score" class="text-3xl md:text-4xl font-bold text-ink">0</span>
              <span class="text-xs text-mute block mt-0.5 font-medium">flow</span>
            </div>
          </div>
        </div>

        <!-- Dashboard stat cards row -->
        <div class="grid grid-cols-3 gap-3">
          <div class="bg-canvas rounded-xl border border-hairline/60 card-shadow p-4">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-6 h-6 rounded-lg bg-link/10 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-link" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <span class="text-sm font-bold text-ink">Today</span>
            </div>
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-extrabold text-ink tracking-tight"><span id="dash-sessions">0</span>/<span id="dash-completion">4</span></span>
              <span class="text-xs text-mute">sessions</span>
            </div>
            <div class="w-full h-1.5 bg-hairline/60 rounded-full overflow-hidden mt-1.5">
              <div id="dash-goal-bar" class="bg-link h-full transition-all duration-500 rounded-full" style="width: 0%"></div>
            </div>
          </div>
          <div class="bg-canvas rounded-xl border border-hairline/60 card-shadow p-4">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-6 h-6 rounded-lg bg-orange-500/10 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-orange-500" viewBox="0 0 24 24" fill="currentColor"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
              </div>
              <span class="text-sm font-bold text-ink">Streak</span>
            </div>
            <div class="flex items-baseline gap-1">
              <span id="dash-streak" class="text-3xl font-extrabold text-orange-500 tracking-tight">0</span>
              <span class="text-xs text-mute">days</span>
            </div>
            <p id="streak-context" class="text-xs text-body mt-1.5 truncate">Start today to begin your streak</p>
          </div>
          <div class="bg-canvas rounded-xl border border-hairline/60 card-shadow p-4">
            <div class="flex items-center gap-2 mb-2">
              <div class="w-6 h-6 rounded-lg bg-amber-500/10 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-amber-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 6 8 6 9z"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 18 8 18 9z"/><path d="M4 22h16"/><path d="M10 22V5c0-.6.4-1 1-1h2c.6 0 1 .4 1 1v17"/></svg>
              </div>
              <span class="text-sm font-bold text-ink">Best</span>
            </div>
            <div class="flex items-baseline gap-1">
              <span id="dash-best-streak" class="text-3xl font-extrabold text-ink tracking-tight">0</span>
              <span class="text-xs text-mute">days</span>
            </div>
            <p id="best-context" class="text-xs text-body mt-1.5 truncate">Complete your first session</p>
          </div>
        </div>

        <!-- Motivational Message -->
        <div class="bg-canvas-soft rounded-xl border border-hairline/50 card-shadow p-4">
          <p id="hero-motivation" class="text-base text-body/80 italic leading-relaxed">Welcome back. Your focus muscle is getting stronger.</p>
        </div>
      </div>

      <!-- RIGHT: Timer + Controls -->
      <div class="bg-canvas rounded-2xl border border-hairline/60 card-shadow p-6 md:p-7 flex flex-col items-center justify-start">
        <!-- Mode Tabs -->
        <div class="flex gap-1 p-0.5 bg-canvas-soft-2 rounded-full border border-hairline w-full max-w-[320px] mb-5">
          <button id="mode-pomodoro" class="flex-1 py-2.5 text-sm font-bold rounded-full transition-all cursor-pointer bg-link text-white shadow-sm" aria-label="Switch to Pomodoro focus session">Pomodoro</button>
          <button id="mode-short" class="flex-1 py-2.5 text-sm font-bold text-body hover:text-ink rounded-full transition-all cursor-pointer" aria-label="Switch to short break">Short Break</button>
          <button id="mode-long" class="flex-1 py-2.5 text-sm font-bold text-body hover:text-ink rounded-full transition-all cursor-pointer" aria-label="Switch to long break">Long Break</button>
        </div>

        <!-- Timer Ring (bigger) -->
        <div id="timer-ring-container" class="relative w-full max-w-[360px] aspect-square mx-auto flex items-center justify-center">
          <svg class="w-full h-full transform -rotate-90" viewBox="0 0 256 256">
            <defs>
              <filter id="ring-glow"><feGaussianBlur stdDeviation="3" result="blur"/><feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge></filter>
            </defs>
            <circle cx="128" cy="128" r="114" stroke="currentColor" stroke-width="6" fill="transparent" class="text-hairline" />
            <circle id="timer-progress-ring" cx="128" cy="128" r="114" stroke="currentColor" stroke-width="6" fill="transparent" stroke-dasharray="716.28" stroke-dashoffset="0" stroke-linecap="round" class="text-link transition-all duration-1000 ease-linear" filter="url(#ring-glow)" />
          </svg>
          <div class="absolute flex flex-col items-center justify-center select-none">
            <span id="timer-display" class="text-6xl sm:text-7xl md:text-8xl font-extrabold tracking-tighter text-ink tabular-nums leading-none">25:00</span>
            <span id="timer-status-text" class="text-base font-semibold text-mute mt-2">Focus Session</span>
          </div>
          <div id="timer-pulse" class="absolute inset-0 rounded-full border-2 border-link/10 pointer-events-none hidden"></div>
          <div id="celebration-container" class="absolute inset-0 pointer-events-none hidden"></div>
        </div>

        <!-- Phase Message -->
        <div id="timer-phase-container" class="text-center min-h-[28px] mt-2">
          <span id="timer-phase" class="text-base font-semibold text-link/80 opacity-0 transition-all duration-500">Take a breath and begin.</span>
        </div>

        <!-- Controls -->
        <div class="flex items-center gap-4 mt-3">
          <button id="btn-reset" class="w-11 h-11 rounded-full border border-hairline bg-canvas text-body hover:text-ink hover:bg-canvas-soft-2 transition-all flex items-center justify-center cursor-pointer active:scale-95 shadow-sm" title="Reset" aria-label="Reset Timer">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
          </button>
          <button id="btn-play-pause" class="w-[72px] h-[72px] rounded-full bg-link text-white hover:bg-link-hover hover:shadow-2xl hover:shadow-link/30 transition-all flex items-center justify-center cursor-pointer active:scale-90 shadow-xl shadow-link/30" title="Start Session" aria-label="Start or Pause Timer">
            <svg id="icon-play" class="ml-0.5" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 3 20 12 6 21 6 3"/></svg>
            <svg id="icon-pause" class="hidden" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><rect x="14" y="4" width="4" height="16" rx="1"/><rect x="6" y="4" width="4" height="16" rx="1"/></svg>
          </button>
          <button id="btn-skip" class="w-11 h-11 rounded-full border border-hairline bg-canvas text-body hover:text-ink hover:bg-canvas-soft-2 transition-all flex items-center justify-center cursor-pointer active:scale-95 shadow-sm" title="Skip" aria-label="Skip Session">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" x2="19" y1="5" y2="19"/></svg>
          </button>
        </div>

        <!-- Preferences inline -->
        <div class="flex items-center justify-between w-full max-w-[360px] mt-4 pt-4 border-t border-hairline/40">
          <div class="flex items-center gap-4">
            <label class="flex items-center gap-1.5 cursor-pointer">
              <input type="checkbox" id="toggle-sound" class="sr-only peer" checked />
              <div class="w-6 h-3.5 bg-canvas-soft-2 rounded-full peer-checked:bg-link relative after:content-[''] after:absolute after:top-[0.5px] after:left-[0.5px] after:bg-white after:rounded-full after:h-[10px] after:w-[10px] after:transition-all peer-checked:after:translate-x-[10px] border border-hairline"></div>
              <span class="text-sm text-mute font-medium">Sound</span>
            </label>
            <label class="flex items-center gap-1.5 cursor-pointer">
              <input type="checkbox" id="toggle-notifications" class="sr-only peer" />
              <div class="w-6 h-3.5 bg-canvas-soft-2 rounded-full peer-checked:bg-link relative after:content-[''] after:absolute after:top-[0.5px] after:left-[0.5px] after:bg-white after:rounded-full after:h-[10px] after:w-[10px] after:transition-all peer-checked:after:translate-x-[10px] border border-hairline"></div>
              <span class="text-sm text-mute font-medium">Alerts</span>
            </label>
            <label class="flex items-center gap-1.5 cursor-pointer">
              <input type="checkbox" id="toggle-autostart" class="sr-only peer" />
              <div class="w-6 h-3.5 bg-canvas-soft-2 rounded-full peer-checked:bg-link relative after:content-[''] after:absolute after:top-[0.5px] after:left-[0.5px] after:bg-white after:rounded-full after:h-[10px] after:w-[10px] after:transition-all peer-checked:after:translate-x-[10px] border border-hairline"></div>
              <span class="text-sm text-mute font-medium">Auto</span>
            </label>
          </div>
          <button id="btn-toggle-settings" class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-semibold text-mute hover:text-ink border border-hairline/60 rounded-lg hover:bg-canvas-soft transition-all cursor-pointer" aria-expanded="false" aria-label="Toggle settings panel">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Custom
          </button>
        </div>

        <!-- Settings panel -->
        <div id="settings-panel" class="hidden w-full max-w-[360px] mt-3 border border-hairline/60 rounded-xl p-4 bg-canvas space-y-3">
          <h4 class="text-sm font-bold text-ink">Session Settings (Minutes)</h4>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
            <Input type="number" id="settings-work" label="Focus" min="1" max="180" placeholder="25" />
            <Input type="number" id="settings-short" label="Short Break" min="1" max="60" placeholder="5" />
            <Input type="number" id="settings-long" label="Long Break" min="1" max="60" placeholder="15" />
            <Input type="number" id="settings-goal" label="Daily Goal" min="1" max="24" placeholder="4" />
          </div>
          <div class="flex justify-end gap-2">
            <Button variant="secondary" size="sm" id="btn-reset-durations">Defaults</Button>
            <Button size="sm" id="btn-save-settings">Save Settings</Button>
          </div>
        </div>

        <div id="recent-tasks-container" class="hidden w-full max-w-[360px] mt-2">
          <span class="text-xs text-mute block mb-1.5 font-medium">Recent tasks:</span>
          <div id="recent-tasks-list" class="flex flex-wrap gap-1.5"></div>
        </div>

        <!-- Hidden JS bindings -->
        <span id="session-type-text" class="hidden">Pomodoro</span>
        <div id="intention-card" class="hidden"><p id="intention-text"></p></div>
        <div id="active-task-footer" class="hidden">
          <button id="btn-complete-task" class="px-4 py-1.5 text-sm font-semibold text-white bg-link rounded-lg hover:bg-link-hover transition-all cursor-pointer">I Did It</button>
        </div>
      </div>

    </div>
  </div>

  <!-- HIDDEN DASHBOARD ELEMENTS (kept for JS bindings) -->
  <div class="hidden">
    <span id="stat-goal-number">4</span>
    <span id="stat-longest-streak">0</span>
    <span id="trend-sessions"></span>
    <span id="trend-time"></span>
    <span id="trend-score"></span>
    <span id="focus-score-label"></span>
    <div id="goal-dots-container"></div>
  </div>

  <!-- BELOW-FOLD DASHBOARD: stats, history, achievements -->
  <div class="max-w-[1440px] mx-auto px-4 sm:px-6">
