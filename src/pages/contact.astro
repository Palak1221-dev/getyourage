---
import Layout from "../layouts/Layout.astro";
import Card from "../components/ui/Card.astro";
import Button from "../components/ui/Button.astro";
import Input from "../components/ui/Input.astro";
import { SUPPORT_EMAIL, CONTACT_FORM_ENDPOINT } from "../constants";
---

<Layout title="Contact Us - Tooltails.com" description="Have feedback, a bug report, or a feature request? Contact the Tooltails team. We reply to every message.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24">
    <h1 class="text-4xl font-bold text-ink mb-8">Contact Us</h1>
    <p class="text-lg text-body mb-12">
      Have feedback, a bug report, or a feature request? We'd love to hear from you.
    </p>
    <div class="flex items-center gap-2 mb-8 text-xs text-ink/75">
      <svg class="w-3.5 h-3.5 text-link shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      <a href={`mailto:${SUPPORT_EMAIL}`} class="text-link hover:text-link-hover transition-colors font-medium">{SUPPORT_EMAIL}</a>
    </div>

    <Card elevation="lg">
      <form class="space-y-6" action={CONTACT_FORM_ENDPOINT} method="POST">
        <Input label="Name" name="name" type="text" placeholder="Your Name" required />
        <Input label="Email" name="email" type="email" placeholder="your@email.com" required />
        <div class="flex flex-col gap-1.5">
          <label for="contact-message" class="text-sm font-medium text-ink">Message</label>
          <textarea 
            id="contact-message"
            name="message"
            class="min-h-[150px] px-3 py-2 bg-canvas border border-hairline rounded-sm text-sm text-ink placeholder:text-mute focus:outline-none focus:border-link focus:ring-2 focus:ring-link/10"
            placeholder="How can we help?"
            required
          ></textarea>
        </div>
        <Button type="submit" class="w-full">Send Message</Button>
      </form>
    </Card>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Contact Us - Tooltails.com",
    "description": "Have feedback, a bug report, or a feature request? Contact the Tooltails team.",
    "url": Astro.url.origin + "/contact",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": Astro.url.origin + "/contact"
    }
  })} />
</Layout>
