---
import Layout from "../../layouts/Layout.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
    { "@type": "ListItem", "position": 2, "name": "Pomodoro Timer", "item": "https://tooltails.com/pomodoro-timer" },
    { "@type": "ListItem", "position": 3, "name": "Terms", "item": "https://tooltails.com/pomodoro-timer/terms" }
  ]
};
---

<Layout
  title="Terms of Service - Tooltails Pomodoro"
  description="Terms of service for Tooltails Pomodoro Timer. Free to use, no login required, all data stored locally."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24">
    <h1 class="text-2xl sm:text-3xl md:text-4xl font-black tracking-tighter text-ink mb-8">Terms of Service</h1>
    <div class="prose prose-neutral max-w-none prose-headings:text-ink prose-p:text-body prose-a:text-link prose-strong:text-ink">
      <p>By using the Tooltails Pomodoro Timer, you agree to these terms.</p>

      <h2>Free Use</h2>
      <p>The Tooltails Pomodoro Timer is completely free to use. No payment, registration, or account is required. All features including session tracking, streaks, analytics, and custom durations are available without charge.</p>

      <h2>Disclaimer</h2>
      <p>The Pomodoro Timer is provided "as is" without warranty of any kind. We are not responsible for any productivity gains, losses, or missed deadlines resulting from use of this tool.</p>

      <h2>Limitation of Liability</h2>
      <p>Tooltails shall not be liable for any indirect, incidental, or consequential damages arising from your use of the Pomodoro Timer.</p>

      <h2>Changes</h2>
      <p>We reserve the right to update these terms at any time. Continued use after changes constitutes acceptance of the updated terms.</p>

      <p>Last updated: June 2026</p>
    </div>

    <div class="mt-12 pt-8 border-t border-hairline">
      <a href="/pomodoro-timer" class="text-sm font-medium text-link hover:underline">&larr; Back to Pomodoro Timer</a>
    </div>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
