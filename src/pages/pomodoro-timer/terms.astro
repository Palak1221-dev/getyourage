---
import LegalLayout from "../../components/legal/LegalLayout.astro";

const sections = [
  { id: "acceptance", title: "Acceptance" },
  { id: "use-of-services", title: "Use of Services" },
  { id: "local-data", title: "Local Data" },
  { id: "intellectual-property", title: "Intellectual Property" },
  { id: "disclaimers", title: "Disclaimers" },
  { id: "limitation-of-liability", title: "Limitation of Liability" },
  { id: "changes", title: "Changes" },
  { id: "contact", title: "Contact" },
];
---

<LegalLayout
  type="terms"
  siteTitle="Tooltails Pomodoro"
  pageTitle="Terms of Service"
  pageDescription="The terms for using Tooltails Pomodoro Timer. Free, local, and transparent."
  lastUpdated="June 27, 2026"
  {sections}
  summaryItems={[
    { text: "Free to use for everyone, no registration needed" },
    { text: "Use the tool responsibly" },
    { text: "Your session data stays on your device" },
    { text: "No warranties - the timer is provided as-is" },
    { text: "Service may evolve with new features" },
  ]}
  faqItems={[
    { question: "Do I need to pay for the Pomodoro Timer?", answer: "No. All features including session tracking, streaks, custom durations, and analytics are completely free. No payment or account required." },
    { question: "Can you see my session history?", answer: "No. All session data is stored in your browser's localStorage and never transmitted to our servers." },
    { question: "What if I lose my streak data?", answer: "Since data is stored locally, clearing your browser cache or switching devices will reset your history. We recommend not relying on the timer for critical record-keeping." },
    { question: "Can I use the timer for work?", answer: "Yes. The Pomodoro Timer is free for personal and professional use. We do not offer commercial licenses or enterprise features." },
    { question: "Does the timer work offline?", answer: "Yes. After the initial page load, all timer functionality works without an internet connection." },
  ]}
  productName="Tooltails Pomodoro"
  productUrl="/pomodoro-timer"
  backPath="/pomodoro-timer"
  breadcrumbItems={[
    { name: "Tooltails", item: "https://tooltails.com" },
    { name: "Pomodoro Timer", item: "https://tooltails.com/pomodoro-timer" },
    { name: "Terms", item: "https://tooltails.com/pomodoro-timer/terms" },
  ]}
>
  <div class="space-y-10 divide-y divide-hairline/50">
    <section id="acceptance" class="pt-0">
      <p class="text-body leading-relaxed">
        By using Tooltails Pomodoro Timer, you agree to these terms. If you do not agree, please do not use the tool. These terms supplement the main Tooltails Terms of Service.
      </p>
    </section>

    <section id="use-of-services" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Use of Services</h2>
      <p class="text-body leading-relaxed mb-4">
        Tooltails Pomodoro Timer is a free productivity tool for time management. You agree to use it responsibly:
      </p>
      <ul class="space-y-2 text-body">
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Do not use the timer for any unlawful purpose.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Do not attempt to exploit, reverse engineer, or disrupt the application.</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Do not use the timer to store or transmit harmful content.</span>
        </li>
      </ul>
    </section>

    <section id="local-data" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Local Data</h2>
      <p class="text-body leading-relaxed">
        The Pomodoro Timer stores all user data in your browser's localStorage. This includes session history, streaks, preferences, and task history. Because this data never reaches our servers, we cannot:
      </p>
      <ul class="space-y-2 text-body mt-4">
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Access or view your session history</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Back up or restore your data</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-link mt-0.5">-</span>
          <span>Recover data lost due to browser clearing or device changes</span>
        </li>
      </ul>
      <p class="text-body leading-relaxed mt-4">
        You acknowledge these limitations by using the tool.
      </p>
    </section>

    <section id="intellectual-property" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Intellectual Property</h2>
      <p class="text-body leading-relaxed">
        The Pomodoro Timer application, including its design, code, and branding, is owned by Tooltails. You may not copy, modify, or redistribute the application without permission.
      </p>
      <p class="text-body leading-relaxed mt-4">
        The tasks and session data you generate within the application belong to you.
      </p>
    </section>

    <section id="disclaimers" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Disclaimers</h2>
      <div class="bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-800/30 rounded-xl p-5">
        <p class="text-sm text-amber-800 dark:text-amber-200 leading-relaxed">
          Tooltails Pomodoro Timer is provided "as is" and "as available." We do not warrant that the timer will be uninterrupted, error-free, or meet your productivity expectations.
        </p>
      </div>
    </section>

    <section id="limitation-of-liability" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Limitation of Liability</h2>
      <div class="bg-canvas-soft rounded-xl border border-hairline p-5">
        <p class="text-sm text-body leading-relaxed">
          Tooltails shall not be liable for any damages arising from your use of the Pomodoro Timer, including data loss, lost productivity, or missed deadlines resulting from browser behavior, device failure, or application downtime.
        </p>
      </div>
    </section>

    <section id="changes" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Changes</h2>
      <p class="text-body leading-relaxed">
        We may update these terms as the Pomodoro Timer evolves. Changes take effect immediately upon posting. Continued use after updates constitutes acceptance of the revised terms.
      </p>
    </section>

    <section id="contact" class="pt-10">
      <h2 class="text-xl font-bold text-ink mb-4">Contact</h2>
      <p class="text-body leading-relaxed">
        Questions about these terms? Reach out through our <a href="/pomodoro-timer/contact" class="text-link hover:text-link-hover underline underline-offset-2">contact page</a>.
      </p>
    </section>
  </div>
</LegalLayout>
