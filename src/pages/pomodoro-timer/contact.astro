---
import Layout from "../../layouts/Layout.astro";
import PomodoroHeader from "../../components/pomodoro/PomodoroHeader.astro";
import Button from "../../components/ui/Button.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
    { "@type": "ListItem", "position": 2, "name": "Pomodoro Timer", "item": "https://tooltails.com/pomodoro-timer" },
    { "@type": "ListItem", "position": 3, "name": "Contact", "item": "https://tooltails.com/pomodoro-timer/contact" }
  ]
};
---

<Layout
  title="Contact Support - Tooltails Pomodoro"
  description="Contact support or leave feedback for Tooltails Pomodoro Timer. We would love to hear your suggestions for improving the focus timer."
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10">
    <div class="mb-8">
      <PomodoroHeader />
      <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-ink mb-2">Contact Pomodoro Support</h1>
      <p class="text-sm text-body max-w-xl leading-relaxed">
        Have a feature suggestion, found a bug, or want to share your productivity streak? Let us know how we can improve the Pomodoro Timer.
      </p>
    </div>

    <div class="bg-canvas rounded-2xl border border-hairline/60 card-shadow p-6 sm:p-8">
      <form class="space-y-6" action="https://formspree.io/f/mwpkjlol" method="POST">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="contact-name" class="block text-xs font-bold text-ink uppercase tracking-wider mb-2">Your Name</label>
            <input type="text" id="contact-name" name="name" required placeholder="John Doe" class="w-full h-11 px-4 bg-canvas-soft/70 rounded-xl text-sm text-ink placeholder:text-mute/40 focus:outline-none focus:bg-canvas-soft focus:ring-2 focus:ring-link/10 transition-all border border-hairline" />
          </div>
          <div>
            <label for="contact-email" class="block text-xs font-bold text-ink uppercase tracking-wider mb-2">Email Address</label>
            <input type="email" id="contact-email" name="email" required placeholder="john@example.com" class="w-full h-11 px-4 bg-canvas-soft/70 rounded-xl text-sm text-ink placeholder:text-mute/40 focus:outline-none focus:bg-canvas-soft focus:ring-2 focus:ring-link/10 transition-all border border-hairline" />
          </div>
        </div>
        <div>
          <label for="contact-subject" class="block text-xs font-bold text-ink uppercase tracking-wider mb-2">Subject</label>
          <input type="text" id="contact-subject" name="subject" required placeholder="Feature suggestion / Bug report / Other" class="w-full h-11 px-4 bg-canvas-soft/70 rounded-xl text-sm text-ink placeholder:text-mute/40 focus:outline-none focus:bg-canvas-soft focus:ring-2 focus:ring-link/10 transition-all border border-hairline" />
        </div>
        <div>
          <label for="contact-message" class="block text-xs font-bold text-ink uppercase tracking-wider mb-2">Message</label>
          <textarea id="contact-message" name="message" rows="6" required placeholder="Tell us more about your feedback..." class="w-full px-4 py-3 bg-canvas-soft/70 rounded-xl text-sm text-ink placeholder:text-mute/40 focus:outline-none focus:bg-canvas-soft focus:ring-2 focus:ring-link/10 transition-all border border-hairline resize-y min-h-[120px]"></textarea>
        </div>
        <div class="flex justify-end">
          <Button type="submit" variant="primary" size="lg">Send Message</Button>
        </div>
      </form>
    </div>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
