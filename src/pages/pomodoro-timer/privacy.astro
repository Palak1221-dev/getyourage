---
import Layout from "../../layouts/Layout.astro";
import PomodoroHeader from "../../components/pomodoro/PomodoroHeader.astro";
import { SUPPORT_EMAIL } from "../../constants";

const sections = [
  { id: "overview", title: "Overview" },
  { id: "information-we-collect", title: "Information We Collect" },
  { id: "how-we-use", title: "How We Use Information" },
  { id: "analytics-cookies", title: "Analytics & Cookies" },
  { id: "data-storage", title: "Data Storage" },
  { id: "third-party", title: "Third-Party Services" },
  { id: "security", title: "Security" },
  { id: "your-rights", title: "Your Rights" },
  { id: "contact", title: "Contact" },
];

const summaryItems = [
  { text: "All session data stored in your browser only" },
  { text: "No account, login, or email required" },
  { text: "No personal data sold or shared" },
  { text: "Analytics used in aggregate for product improvement" },
  { text: "You remain in full control of your information" },
];

const faqItems = [
  { question: "Is my Pomodoro session history stored on your servers?", answer: "No. All session history, streaks, preferences, and task data are stored in your browser's localStorage. We never receive this data." },
  { question: "Does the Pomodoro Timer collect personal information?", answer: "No. The timer does not ask for or collect names, emails, or any personal identifiers. Analytics data is anonymized and aggregated." },
  { question: "What happens if I clear my browser data?", answer: "Clearing localStorage will erase your session history, streaks, and settings. This data cannot be recovered as we do not store it." },
  { question: "Can I use the timer offline?", answer: "Yes. After the initial page load, the Pomodoro Timer works fully offline. All features including session tracking and streaks function without an internet connection." },
  { question: "What third-party services does the timer use?", answer: "The Pomodoro page loads Google Analytics (GA4) and Microsoft Clarity for aggregated usage analytics, same as the rest of Tooltails. No timer-specific data is transmitted to these services." },
];

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Privacy Policy - Tooltails Pomodoro",
  description: "How Tooltails Pomodoro Timer handles your session data. It stays local, stays private.",
  url: Astro.url.origin + "/pomodoro-timer/privacy",
  mainEntityOfPage: { "@type": "WebPage", "@id": Astro.url.origin + "/pomodoro-timer/privacy" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
    { "@type": "ListItem", "position": 2, "name": "Pomodoro Timer", "item": "https://tooltails.com/pomodoro-timer" },
    { "@type": "ListItem", "position": 3, "name": "Privacy", "item": "https://tooltails.com/pomodoro-timer/privacy" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};
---

<Layout
  title="Privacy Policy - Tooltails Pomodoro"
  description="How Tooltails Pomodoro Timer handles your session data. It stays local, stays private."
>
  <div class="min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-12">
      <div class="mb-8">
        <PomodoroHeader />
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-link/10 text-link mb-3">Privacy Policy</span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-ink mb-3">Privacy Policy</h1>
        <p class="text-base md:text-lg text-body max-w-2xl leading-relaxed">How Tooltails Pomodoro Timer handles your session data. It stays local, stays private.</p>
        <div class="flex items-center gap-3 mt-3 text-xs sm:text-sm text-mute">
          <span>Last updated: June 27, 2026</span>
          <span class="w-1 h-1 rounded-full bg-hairline" aria-hidden="true"></span>
          <span>3 min read</span>
        </div>
      </div>

      <div class="bg-canvas rounded-2xl border border-hairline card-shadow p-6 md:p-8 mb-10 md:mb-12">
        <h2 class="text-sm font-semibold text-mute uppercase tracking-wider mb-4">Privacy at a glance</h2>
        <ul class="space-y-3">
          {summaryItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-link shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span class="text-sm sm:text-base text-body">{item.text}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:grid lg:grid-cols-[220px_1fr] lg:gap-10 xl:gap-16">
        <nav class="lg:sticky lg:top-24 lg:self-start lg:max-h-[calc(100vh-8rem)] lg:overflow-y-auto mb-6 lg:mb-0" aria-label="Section navigation">
          <h3 class="text-xs font-semibold text-mute uppercase tracking-wider mb-3 hidden lg:block">On this page</h3>
          <div class="flex lg:flex-col gap-1 overflow-x-auto lg:overflow-x-visible pb-2 lg:pb-0 -mx-4 px-4 lg:mx-0 lg:px-0 scrollbar-none">
            {sections.map((s) => (
              <a href={"#" + s.id} class="toc-link text-sm text-body/70 hover:text-link whitespace-nowrap lg:whitespace-normal py-1.5 px-2.5 lg:px-3 rounded-lg transition-colors hover:bg-link/5 shrink-0">{s.title}</a>
            ))}
          </div>
        </nav>

        <div class="min-w-0">
          <div class="space-y-10 divide-y divide-hairline/50">
            <section id="overview" class="pt-0">
              <p class="text-body leading-relaxed">Tooltails Pomodoro Timer is a privacy-first productivity tool. Every session you complete, every streak you build, and every preference you set stays on your device. We built it that way on purpose.</p>
              <p class="text-body leading-relaxed mt-4">This policy covers what data the Pomodoro Timer accesses and how it is used. It supplements the main Tooltails Privacy Policy.</p>
            </section>
            <section id="information-we-collect" class="pt-10">
              <h2 class="text-xl font-bold text-ink mb-4">Information We Collect</h2>
              <div class="space-y-4">
                <div class="bg-green-50 dark:bg-green-950/20 border border-green-200 dark:border-green-800/30 rounded-xl p-5">
                  <h3 class="text-sm font-semibold text-green-800 dark:text-green-200 mb-2">Not collected</h3>
                  <ul class="space-y-1.5 text-sm text-green-700 dark:text-green-300"><li>- Session timestamps or completion logs</li><li>- Task names or descriptions</li><li>- Daily streaks or productivity scores</li><li>- Personal identifiers or contact information</li></ul>
                </div>
                <div class="bg-canvas-soft rounded-xl border border-hairline p-5">
                  <h3 class="text-sm font-semibold text-ink mb-2">Collected (aggregated analytics)</h3>
                  <ul class="space-y-1.5 text-sm text-body"><li>- Page views and session duration</li><li>- Browser type and device category</li><li>- Country-level location data</li></ul>
                </div>
              </div>
            </section>
            <section id="how-we-use" class="pt-10">
              <h2 class="text-xl font-bold text-ink mb-4">How We Use Information</h2>
              <p class="text-body leading-relaxed">Analytics data helps us understand how the Pomodoro Timer is used, identify bugs, and prioritize feature development. No productivity data or personal information is used for advertising, profiling, or any unrelated purpose.</p>
            </section>
            <section id="analytics-cookies" class="pt-10">
              <h2 class="text-xl font-bold text-ink mb-4">Analytics & Cookies</h2>
              <p class="text-body leading-relaxed">The Pomodoro page uses Google Analytics 4 and Microsoft Clarity for aggregated usage insights. These services may set cookies to distinguish unique visitors. We do not set any first-party cookies.</p>
              <div class="bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-800/30 rounded-xl p-5 mt-4">
                <p class="text-sm text-amber-800 dark:text-amber-200 leading-relaxed">Blocking analytics cookies will not affect the Pomodoro Timer's functionality. You can manage cookie preferences through your browser settings.</p>
              </div>
            </section>
            <section id="data-storage" class="pt-10">
              <h2 class="text-xl font-bold text-ink mb-4">Data Storage</h2>
              <p class="text-body leading-relaxed mb-4">The Pomodoro Timer uses your browser's localStorage for all persistent data:</p>
              <ul class="space-y-2 text-body mb-4">
                <li class="flex items-start gap-2"><span class="text-link mt-0.5">-</span><span>Session history and completion records</span></li>
                <li class="flex items-start gap-2"><span class="text-link mt-0.5">-</span><span>Daily streaks and productivity scores</span></li>
                <li class="flex items-start gap-2"><span class="text-link mt-0.5">-</span><span>Timer duration and sound preferences</span></li>
                <li class="flex items-start gap-2"><span class="text-link mt-0.5">-</span><span>Recent task history</span></li>
              </ul>
              <p class="text-body leading-relaxed">This data remains on your device. Clearing localStorage will erase all Pomodoro data, and we cannot recover it.</p>
            </section>
            <section id="third-party" class="pt-10">
              <h2 class="text-xl font-bold text-ink mb-4">Third-Party Services</h2>
              <p class="text-body leading-relaxed">The Pomodoro Timer integrates Google Analytics 4 and Microsoft Clarity for traffic analysis. No timer-specific data is shared with these or any other third parties.</p>
            </section>
            <section id="security" class="pt-10">
              <h2 class="text-xl font-bold text-ink mb-4">Security</h2>
              <p class="text-body leading-relaxed">All Tooltails pages are served over HTTPS. Since your timer data stays in your browser, the primary risk is local device access. Avoid using the timer on shared devices if you are concerned about local data privacy.</p>
            </section>
            <section id="your-rights" class="pt-10">
              <h2 class="text-xl font-bold text-ink mb-4">Your Rights</h2>
              <ul class="space-y-2 text-body">
                <li class="flex items-start gap-2"><span class="text-link mt-0.5">-</span><span><strong class="text-ink">Delete your data.</strong> Clear browser localStorage to remove all timer history and preferences.</span></li>
                <li class="flex items-start gap-2"><span class="text-link mt-0.5">-</span><span><strong class="text-ink">Opt out of analytics.</strong> Block analytics scripts via browser settings or extensions.</span></li>
                <li class="flex items-start gap-2"><span class="text-link mt-0.5">-</span><span><strong class="text-ink">Know what is collected.</strong> This policy provides full transparency on data access.</span></li>
              </ul>
            </section>
            <section id="contact" class="pt-10">
              <h2 class="text-xl font-bold text-ink mb-4">Contact</h2>
              <p class="text-body leading-relaxed">Questions about Pomodoro privacy? Reach out through our <a href="/pomodoro-timer/contact" class="text-link hover:text-link-hover underline underline-offset-2">contact page</a> or email us directly at <a href={`mailto:${SUPPORT_EMAIL}`} class="text-link hover:text-link-hover underline underline-offset-2">{SUPPORT_EMAIL}</a>.</p>
            </section>
          </div>

          <!-- FAQ -->
          <div class="mt-16 pt-12 border-t border-hairline" id="faq">
            <h2 class="text-2xl font-bold text-ink mb-8">Frequently asked questions</h2>
            <div class="space-y-3">
              {faqItems.map((faq) => (
                <details class="group bg-canvas rounded-xl border border-hairline card-shadow overflow-hidden">
                  <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer text-sm font-medium text-ink hover:text-link transition-colors list-none">
                    {faq.question}
                    <svg class="w-4 h-4 text-mute shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                  </summary>
                  <div class="px-5 pb-4 pt-0"><p class="text-sm text-body leading-relaxed">{faq.answer}</p></div>
                </details>
              ))}
            </div>
          </div>

          <!-- Contact Card -->
          <div class="mt-10 bg-canvas rounded-2xl border border-hairline card-shadow p-6 md:p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
              <h3 class="text-sm font-semibold text-ink mb-1">Still have questions?</h3>
              <p class="text-sm text-mute">We are happy to help. Reach out to our team.</p>
            </div>
            <a href="/pomodoro-timer/contact" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-link text-white text-sm font-medium hover:bg-link-hover transition-colors shrink-0">
              Contact us
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>

          <div class="mt-8">
            <a href="/pomodoro-timer" class="inline-flex items-center gap-1.5 text-sm text-link hover:text-link-hover transition-colors font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
              Back to Pomodoro Timer
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(webPageSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />

  <script is:inline>
    (function() {
      var links = document.querySelectorAll('.toc-link');
      var sections = [];
      links.forEach(function(link) {
        var id = link.getAttribute('href').slice(1);
        var el = document.getElementById(id);
        if (el) sections.push({ el: el, link: link });
      });
      links.forEach(function(link) {
        link.addEventListener('click', function(e) {
          var target = document.getElementById(this.getAttribute('href').slice(1));
          if (target) {
            e.preventDefault();
            var top = target.getBoundingClientRect().top + window.scrollY - 100;
            window.scrollTo({ top: top, behavior: 'smooth' });
            history.pushState(null, '', this.getAttribute('href'));
          }
        });
      });
      if (sections.length > 0 && 'IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              links.forEach(function(l) { l.classList.remove('text-link', 'bg-link/10'); l.classList.add('text-body/70'); });
              var activeLink = document.querySelector('.toc-link[href="#' + entry.target.id + '"]');
              if (activeLink) { activeLink.classList.remove('text-body/70'); activeLink.classList.add('text-link', 'bg-link/10'); }
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
        sections.forEach(function(s) { observer.observe(s.el); });
      }
    })();
  </script>
</Layout>
