---
import { getCollection } from 'astro:content';
import Layout from "../../../layouts/Layout.astro";

const posts = await getCollection('pomodoro-blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Pomodoro Blog - Tooltails",
  "description": "Master the Pomodoro Technique with guides on focus, productivity, ADHD, studying, coding, remote work, and deep work strategies.",
  "url": Astro.url.origin + "/pomodoro-timer/blog",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": sortedPosts.map((post, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": Astro.url.origin + "/pomodoro-timer/blog/" + post.id
    }))
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
    { "@type": "ListItem", "position": 2, "name": "Pomodoro Timer", "item": "https://tooltails.com/pomodoro-timer" },
    { "@type": "ListItem", "position": 3, "name": "Blog", "item": "https://tooltails.com/pomodoro-timer/blog" }
  ]
};
---

<Layout
  title="Pomodoro Blog - Focus Techniques & Productivity Guides | Tooltails Pomodoro"
  description="Master the Pomodoro Technique with expert guides on focus, productivity, studying, coding, ADHD, remote work, and deep work strategies."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-ink mb-6">
        Pomodoro <span class="text-link">Blog</span>
      </h1>
      <p class="text-lg md:text-xl text-body leading-relaxed">
        Master the Pomodoro Technique with expert guides on focus, productivity, studying, coding, ADHD, remote work, and science-backed strategies.
      </p>
      <a href="/pomodoro-timer" class="inline-flex items-center gap-2 mt-6 text-sm font-semibold text-link hover:text-link-hover transition-colors">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Back to Pomodoro Timer
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {sortedPosts.map((post) => (
        <a href={"/pomodoro-timer/blog/" + post.id} class="group">
          <div class="rounded-2xl transition-all bg-canvas text-ink border border-hairline/60 shadow-sm p-6 h-full group-hover:shadow-md group-hover:-translate-y-0.5 motion-safe:transition-all motion-safe:duration-200">
            <h2 class="text-xl font-bold text-ink mb-3 group-hover:text-link transition-colors">{post.data.title}</h2>
            <p class="text-sm text-body leading-relaxed mb-4 line-clamp-3">{post.data.description}</p>
            <div class="mt-auto pt-4 border-t border-hairline flex justify-between items-center text-xs font-mono text-mute">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
              </time>
              <span class="text-link group-hover:translate-x-1 transition-transform">Read Article &rarr;</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

<style is:global>
  @reference "../../../styles/global.css";
  .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
</style>
