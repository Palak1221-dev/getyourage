---
import { getCollection } from 'astro:content';
import Layout from "../../../layouts/Layout.astro";
import PomodoroHeader from "../../../components/pomodoro/PomodoroHeader.astro";

const posts = await getCollection('pomodoro-blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Pomodoro Blog - Tooltails",
  "description": "Master the Pomodoro Technique with guides on focus, productivity, ADHD, studying, coding, remote work, and deep work strategies.",
  "url": Astro.url.origin + "/pomodoro-timer/blog",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": sortedPosts.map((post, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": Astro.url.origin + "/pomodoro-timer/blog/" + post.id
    }))
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
    { "@type": "ListItem", "position": 2, "name": "Pomodoro Timer", "item": "https://tooltails.com/pomodoro-timer" },
    { "@type": "ListItem", "position": 3, "name": "Blog", "item": "https://tooltails.com/pomodoro-timer/blog" }
  ]
};
---

<Layout
  title="Pomodoro Blog - Focus Techniques & Productivity Guides | Tooltails Pomodoro"
  description="Master the Pomodoro Technique with expert guides on focus, productivity, studying, coding, ADHD, remote work, and deep work strategies."
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 md:py-10">
    <div class="text-center mb-8 max-w-3xl mx-auto">
      <PomodoroHeader class="inline-flex items-center gap-1 text-xs font-semibold text-link hover:text-link-hover transition-colors mb-2" />
      <h1 class="text-3xl md:text-5xl font-bold tracking-tight text-ink mb-4">
        Pomodoro <span class="text-link">Blog</span>
      </h1>
      <p class="text-base md:text-lg text-body leading-relaxed">
        Master the Pomodoro Technique with expert guides on focus, productivity, studying, coding, ADHD, remote work, and science-backed strategies.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
      {sortedPosts.map((post) => (
        <a
          href={"/pomodoro-timer/blog/" + post.id}
          class="group bg-canvas rounded-2xl border border-hairline/60 shadow-sm hover:shadow-md transition-all duration-200 overflow-hidden motion-safe:hover:-translate-y-0.5"
        >
          <div class="p-6">
            <div class="flex items-center gap-2 text-[10px] font-mono text-mute uppercase tracking-wider mb-3">
              <span>{post.data.category || "Pomodoro"}</span>
              <span class="w-1 h-1 rounded-full bg-hairline"></span>
              <span>{new Date(post.data.pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            </div>
            <h2 class="text-base font-bold text-ink mb-2 group-hover:text-link transition-colors leading-snug">{post.data.title}</h2>
            <p class="text-sm text-body leading-relaxed line-clamp-2">{post.data.description}</p>
            <span class="inline-flex items-center gap-1 mt-3 text-xs font-semibold text-link group-hover:text-link-hover transition-colors">
              Read more
              <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
