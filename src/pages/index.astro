---
import Layout from "../layouts/Layout.astro";
import Card from "../components/ui/Card.astro";

const tools = [
  {
    title: "Age Calculator",
    description: "Calculate your exact age in years, months, days, and seconds with precision.",
    href: "/age-calculator",
    icon: "clock",
    popular: true
  },
  {
    title: "Age Difference",
    description: "Find the exact age gap between two people instantly. Perfect for family and friends.",
    href: "/age-difference",
    icon: "users"
  },
  {
    title: "Birthday Countdown",
    description: "Never miss a special day. See exactly how many days, hours, and minutes remain.",
    href: "/birthday-countdown",
    icon: "gift",
    popular: true
  },
  {
    title: "Duration Calculator",
    description: "Calculate the precise time elapsed between any two dates for work or personal projects.",
    href: "/duration",
    icon: "calendar"
  },
  {
    title: "Future Age",
    description: "Planning ahead? Find out exactly how old you will be on any future date.",
    href: "/future-age",
    icon: "forward"
  }
];

const whyTooltails = [
  {
    title: "100% Free",
    description: "All our tools are completely free to use, forever. No hidden costs or premium tiers.",
    icon: "free"
  },
  {
    title: "No Registration Required",
    description: "Start using tools immediately. No sign-ups, no accounts, and no email required.",
    icon: "no-reg"
  },
  {
    title: "Mobile Friendly",
    description: "Our responsive design ensures tools work perfectly on phones, tablets, and desktops.",
    icon: "mobile"
  },
  {
    title: "Fast Results",
    description: "Optimized for speed. Get instant results without waiting for page reloads.",
    icon: "zap"
  },
  {
    title: "Privacy Focused",
    description: "Your data stays on your device. All calculations are performed locally in your browser.",
    icon: "shield"
  }
];
---

<Layout 
  title="Tooltails - Free Online Tools, Calculators & Generators" 
  description="Tooltails offers free online calculators, generators, converters and productivity tools. Fast, accurate and easy to use."
>
  <!-- Hero Section -->
  <section class="relative w-full pt-16 md:pt-24 pb-20 md:pb-28 overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-[500px] h-[500px] bg-link/5 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/4 w-[400px] h-[400px] bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-[1200px] mx-auto px-6 relative z-10">
      <div class="flex flex-col items-center text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-link/10 border border-link/20 text-link text-xs font-bold mb-8 uppercase tracking-wider animate-in fade-in slide-in-from-top-4 duration-1000">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-link opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-link"></span>
          </span>
          100% Free Online Tools
        </div>
        
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight text-ink mb-8 leading-[0.9] max-w-5xl">
          Free Online Tools for <span class="text-link">Everyday</span> Tasks.
        </h1>
        <p class="text-lg md:text-xl text-body leading-relaxed max-w-2xl mx-auto mb-12 opacity-80">
          Tooltails provides free online calculators, generators, converters and productivity tools designed to help you work faster and smarter.
        </p>

        <div class="flex flex-wrap justify-center gap-4">
          <a href="#tools" class="inline-flex items-center justify-center px-8 h-14 text-base font-bold rounded-pill bg-ink text-canvas hover:bg-link transition-all active:scale-[0.98] shadow-lg shadow-ink/10">
            Explore Popular Tools
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ml-2"><line x1="12" x2="12" y1="5" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Tools Section -->
  <section id="tools" class="w-full py-20 bg-canvas border-y border-hairline scroll-mt-16">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-ink mb-6">
          Popular Tools
        </h2>
        <p class="text-lg text-body max-w-2xl mx-auto opacity-80">
          Fast, accurate, and completely free tools to help you manage dates, ages, and more.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {tools.map((tool) => (
          <a href={tool.href} class="group block h-full">
            <Card elevation="sm" class="h-full group-hover:shadow-xl group-hover:border-link/30 transition-all duration-300 relative overflow-hidden bg-canvas">
              {tool.popular && (
                <div class="absolute top-0 right-0 px-3 py-1 bg-link text-canvas text-[10px] font-bold uppercase tracking-widest rounded-bl-lg">
                  Popular
                </div>
              )}
              
              <div class="flex flex-col h-full">
                <div class="mb-6 inline-flex items-center justify-center w-12 h-12 rounded-xl bg-canvas-soft border border-hairline text-link group-hover:bg-link group-hover:text-canvas transition-colors duration-300 shadow-sm">
                  {tool.icon === 'clock' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  )}
                  {tool.icon === 'users' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                  )}
                  {tool.icon === 'gift' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect width="20" height="5" x="2" y="7"/><line x1="12" x2="12" y1="22" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                  )}
                  {tool.icon === 'calendar' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                  )}
                  {tool.icon === 'forward' && (
                    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                  )}
                </div>
                
                <h3 class="text-xl font-bold text-ink mb-3 group-hover:text-link transition-colors duration-300">
                  {tool.title}
                </h3>
                
                <p class="text-body text-sm leading-relaxed mb-6 opacity-80">
                  {tool.description}
                </p>
                
                <div class="mt-auto flex items-center text-xs font-bold text-link uppercase tracking-widest group-hover:translate-x-1 transition-transform">
                  Use Tool &rarr;
                </div>
              </div>
            </Card>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Tooltails Section -->
  <section class="w-full py-24 bg-canvas-soft">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-ink mb-6">
          Why Tooltails?
        </h2>
        <p class="text-lg text-body max-w-2xl mx-auto opacity-80">
          The best tools on the web should be clean, fast, and free. Here's why users choose Tooltails.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {whyTooltails.map(item => (
          <div class="p-8 rounded-2xl bg-canvas border border-hairline shadow-sm hover:shadow-md transition-shadow">
            <div class="w-12 h-12 rounded-full bg-link/5 text-link flex items-center justify-center mb-6">
              {item.icon === 'free' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>}
              {item.icon === 'no-reg' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" x2="22" y1="8" y2="13"/><line x1="22" x2="17" y1="8" y2="13"/></svg>}
              {item.icon === 'mobile' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>}
              {item.icon === 'zap' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
              {item.icon === 'shield' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
            </div>
            <h3 class="text-xl font-bold text-ink mb-4">{item.title}</h3>
            <p class="text-body text-sm leading-relaxed opacity-80">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Simple CTA -->
  <section class="w-full py-24 bg-canvas border-t border-hairline">
    <div class="max-w-[1200px] mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-ink mb-8 leading-tight">
        Ready to get started?
      </h2>
      <p class="text-xl text-body max-w-2xl mx-auto mb-12 opacity-80">
        Try our most popular tool, the Age Calculator, or explore our full suite of free utilities.
      </p>
      <div class="flex flex-wrap justify-center gap-6">
        <a href="/age-calculator" class="inline-flex items-center justify-center px-10 h-16 text-lg font-bold rounded-pill bg-ink text-canvas hover:bg-link transition-all active:scale-[0.98] shadow-lg">
          Try Age Calculator
        </a>
        <a href="#tools" class="inline-flex items-center justify-center px-10 h-16 text-lg font-bold rounded-pill bg-canvas text-ink border border-hairline hover:bg-canvas-soft-2 transition-all active:scale-[0.98]">
          View All Tools
        </a>
      </div>
    </div>
  </section>
</Layout>
