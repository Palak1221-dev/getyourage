---
import Layout from "../layouts/Layout.astro";
import Card from "../components/ui/Card.astro";

const categories = [
  "All",
  "Calculators",
  "Date & Time",
  "Generators",
  "Productivity"
];

const stats = [
  { label: "Tools", value: "5+", icon: "tool" },
  { label: "Free", value: "100%", icon: "gift" },
  { label: "Signup", value: "No", icon: "user-minus" },
  { label: "Results", value: "Fast", icon: "zap" }
];

const tools = [
  {
    title: "Age Calculator",
    description: "Calculate your exact age for school, work, or just for fun. Find out exactly how many days you've been alive.",
    href: "/age-calculator",
    icon: "clock",
    popular: true,
    tag: "Calculators"
  },
  {
    title: "Age Difference",
    description: "Find the age gap between friends, siblings, or partners instantly. Great for family history and curiosity.",
    href: "/age-difference",
    icon: "users",
    tag: "Date & Time"
  },
  {
    title: "Birthday Countdown",
    description: "Track the days until your next big celebration. Perfect for planning surprises and counting down with kids.",
    href: "/birthday-countdown",
    icon: "gift",
    popular: true,
    tag: "Date & Time"
  },
  {
    title: "Duration Calculator",
    description: "Measure the exact time between two dates for project planning, travel, or milestone tracking.",
    href: "/duration",
    icon: "calendar",
    tag: "Calculators"
  },
  {
    title: "Future Age",
    description: "Curious how old you'll be in 2030 or on your next graduation? Find out exactly when you'll reach any age.",
    href: "/future-age",
    icon: "forward",
    tag: "Calculators"
  },
  {
    title: "Pomodoro Timer",
    description: "Boost your productivity with task tracking, focus analytics, custom break intervals, and streaks.",
    href: "/pomodoro-timer",
    icon: "timer",
    popular: true,
    tag: "Productivity"
  },
  {
    title: "Focus Goals Timer",
    description: "Outcome-based timer focusing on shipping goals, decomposing milestones, streaks, and recovery planning.",
    href: "/focus",
    icon: "target",
    popular: true,
    tag: "Productivity"
  },
  {
    title: "Word Counter",
    description: "Count words, characters, reading time, readability score, and analyze text instantly.",
    href: "/word-counter",
    icon: "file-text",
    popular: true,
    tag: "Productivity"
  }
];

const whyTooltails = [
  {
    title: "Fast Results",
    description: "Get answers instantly without waiting for page reloads. We value your time.",
    icon: "zap"
  },
  {
    title: "Privacy Focused",
    description: "Your information stays private on your device. All calculations are performed locally in your browser.",
    icon: "shield"
  },
  {
    title: "Mobile Friendly",
    description: "Our tools work perfectly on your phone, so you can get answers on the go.",
    icon: "mobile"
  },
  {
    title: "Accurate Calculations",
    description: "Built with care to ensure your results are mathematically perfect every time.",
    icon: "check-circle"
  }
];
---

<Layout 
  title="Tooltails - Free Online Tools for Everyday Tasks" 
  description="Calculate ages, track birthdays, compare dates and get answers instantly — all for free. Fast, accurate and easy to use."
>
  <!-- Hero Section -->
  <section class="relative w-full pt-12 md:pt-16 pb-8 md:pb-12 overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-[600px] h-[600px] bg-link/10 rounded-full blur-[120px] pointer-events-none opacity-50"></div>
    <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px] pointer-events-none opacity-30"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-hairline to-transparent opacity-50 pointer-events-none"></div>

    <div class="max-w-[1200px] mx-auto px-6 relative z-10">
      <div class="flex flex-col items-center text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-link/10 border border-link/20 text-link text-xs font-bold mb-6 uppercase tracking-wider animate-in fade-in slide-in-from-top-4 duration-1000 shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-link opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-link"></span>
          </span>
          100% Free Online Tools
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold tracking-tight text-ink mb-4 leading-[0.9] max-w-5xl animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-100">
          Free Online Tools for <span class="text-link">Everyday</span> Tasks.
        </h1>
        <p class="text-lg md:text-xl text-body leading-relaxed max-w-2xl mx-auto mb-8 opacity-80 animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-200">
          Calculate ages, track birthdays, compare dates and get answers instantly — all for free.
        </p>

        <!-- Category Pills -->
        <div class="flex flex-wrap justify-center gap-2 mb-10 animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-300">
          {categories.map(category => (
            <button 
              class="category-pill px-4 py-1.5 rounded-full bg-canvas border border-hairline text-body text-[13px] font-medium hover:border-link/50 hover:text-link transition-all cursor-pointer shadow-sm active:scale-95"
              data-category={category}
            >
              {category}
            </button>
          ))}
        </div>

        <div class="flex flex-col items-center gap-6 animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-400">
          <div class="flex flex-wrap justify-center gap-6">
            <a href="#tools" class="inline-flex items-center justify-center px-8 h-14 text-base font-bold rounded-pill bg-ink text-canvas hover:bg-link transition-all active:scale-[0.98] shadow-xl shadow-ink/10 group">
              Explore All Tools
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-y-1 transition-transform"><line x1="12" x2="12" y1="5" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            </a>
            <a href="#why" class="inline-flex items-center justify-center px-8 h-14 text-base font-bold rounded-pill bg-canvas text-ink border border-hairline hover:bg-canvas-soft-2 transition-all active:scale-[0.98]">
              Why Tooltails?
            </a>
          </div>
          
          <div class="flex flex-col items-center gap-4">
            <p class="text-sm text-ink font-semibold">
              ✨ No sign-up required. Just open a tool and get started.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="w-full pb-12">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {stats.map(stat => (
          <div class="p-6 md:p-8 rounded-3xl bg-canvas border border-hairline shadow-sm hover:shadow-md transition-all flex flex-col items-center text-center group">
            <div class="mb-4 text-link/50 group-hover:text-link transition-colors">
              {stat.icon === 'tool' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 21 8.35-8.35a5.5 5.5 0 0 0-7.78-7.78l-8.35 8.35a5.5 5.5 0 0 0 7.78 7.78Z"/><path d="m9.5 14.5 5-5"/></svg>}
              {stat.icon === 'gift' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect width="20" height="5" x="2" y="7"/><line x1="12" x2="12" y1="22" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>}
              {stat.icon === 'user-minus' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="22" x2="16" y1="11" y2="11"/></svg>}
              {stat.icon === 'zap' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
            </div>
            <div class="text-2xl md:text-3xl font-bold text-ink mb-1">{stat.value}</div>
            <div class="text-[10px] md:text-[11px] font-bold text-mute uppercase tracking-[0.2em]">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular Tools Section -->
  <section id="tools" class="w-full pt-12 pb-20 bg-canvas-soft border-y border-hairline scroll-mt-16">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-12 mb-20">
        <div class="max-w-2xl">
          <h2 class="text-4xl md:text-6xl font-bold tracking-tight text-ink mb-6">
            Popular Tools
          </h2>
          <p class="text-lg md:text-xl text-body opacity-80 leading-relaxed">
            Fast, accurate, and completely free tools to help you manage dates, ages, and more. No signup, no tracking, just utility.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="tools-grid">
        {tools.map((tool) => (
          <a href={tool.href} class="tool-card group block h-full" data-category={tool.tag}>
            <Card elevation="sm" class="h-full group-hover:shadow-2xl group-hover:border-link/40 transition-all duration-500 relative bg-canvas rounded-[2rem] p-10 flex flex-col">
              {tool.popular && (
                <div class="absolute top-0 right-0 px-4 py-1.5 bg-link text-canvas text-[10px] font-bold uppercase tracking-[0.2em] rounded-bl-2xl">
                  Popular
                </div>
              )}
              
              <div class="mb-10 inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-canvas-soft border border-hairline text-link group-hover:bg-link group-hover:text-canvas transition-all duration-500 shadow-sm">
                {tool.icon === 'clock' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                )}
                {tool.icon === 'users' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                )}
                {tool.icon === 'gift' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect width="20" height="5" x="2" y="7"/><line x1="12" x2="12" y1="22" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                )}
                {tool.icon === 'calendar' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                )}
                {tool.icon === 'forward' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 17 18 12 13 7"/><polyline points="6 17 11 12 6 7"/></svg>
                )}
                {tool.icon === 'timer' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/><path d="M12 2v2"/><path d="M17 5l-1.5 1.5"/><path d="M7 5l1.5 1.5"/></svg>
                )}
                {tool.icon === 'file-text' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/><line x1="10" x2="8" y1="9" y2="9"/></svg>
                )}
                {tool.icon === 'target' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                )}
              </div>
              
              <div class="mb-2">
                <span class="text-[10px] font-bold text-link uppercase tracking-[0.2em]">{tool.tag}</span>
              </div>
              <h3 class="text-2xl md:text-3xl font-bold text-ink mb-4 group-hover:text-link transition-colors duration-300">
                {tool.title}
              </h3>
              
              <p class="text-body text-base leading-relaxed mb-8 opacity-80">
                {tool.description}
              </p>
              
              <div class="mt-auto inline-flex items-center justify-center w-full h-12 rounded-xl bg-canvas-soft border border-hairline text-[13px] font-bold text-ink group-hover:bg-link group-hover:text-canvas group-hover:border-link transition-all duration-300 uppercase tracking-widest">
                Open Tool
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><line x1="5" x2="19" y1="12" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </div>
            </Card>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Tooltails Section -->
  <section id="why" class="w-full py-32 md:py-40">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="text-center mb-24">
        <h2 class="text-4xl md:text-7xl font-bold tracking-tight text-ink mb-8 leading-tight">
          Tools you can <span class="text-link">trust</span>.
        </h2>
        <p class="text-xl md:text-2xl text-body max-w-2xl mx-auto opacity-80 leading-relaxed">
          The best tools on the web should be clean, fast, and free. Here's why users choose Tooltails.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {whyTooltails.map(item => (
          <div class="p-12 rounded-[2.5rem] bg-canvas border border-hairline shadow-sm hover:shadow-xl transition-all group overflow-hidden relative">
            <div class="absolute top-0 right-0 w-32 h-32 bg-link/5 rounded-full translate-x-1/2 -translate-y-1/2 blur-2xl group-hover:bg-link/10 transition-colors"></div>
            
            <div class="w-16 h-16 rounded-2xl bg-link/5 text-link flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
              {item.icon === 'zap' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>}
              {item.icon === 'shield' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>}
              {item.icon === 'mobile' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>}
              {item.icon === 'check-circle' && <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>}
            </div>
            <h3 class="text-3xl font-bold text-ink mb-4">{item.title}</h3>
            <p class="text-body text-lg leading-relaxed opacity-80">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modern CTA Section -->
  <section class="w-full pb-40">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-link to-primary rounded-[3rem] blur opacity-25 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
        
        <div class="relative p-16 md:p-32 bg-ink rounded-[2.8rem] overflow-hidden">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,_var(--tw-gradient-stops))] from-link/30 via-transparent to-transparent"></div>
          
          <div class="relative z-10 flex flex-col items-center text-center">
            <h2 class="text-5xl md:text-8xl font-bold tracking-tight text-canvas mb-10 leading-[0.9]">
              Ready to work <span class="text-link">faster</span>?
            </h2>
            <p class="text-xl md:text-2xl text-canvas/60 max-w-2xl mx-auto mb-16 leading-relaxed">
              Join thousands of users who rely on Tooltails for their daily calculations and utility needs. No signup, no catch.
            </p>
            <div class="flex flex-wrap justify-center gap-6">
              <a href="/age-calculator" class="inline-flex items-center justify-center px-12 h-20 text-xl font-bold rounded-pill bg-canvas text-ink hover:bg-link hover:text-canvas transition-all active:scale-[0.98] shadow-2xl">
                Try the Age Calculator
              </a>
              <a href="#tools" class="inline-flex items-center justify-center px-12 h-20 text-xl font-bold rounded-pill bg-transparent text-canvas border border-canvas/20 hover:bg-canvas/10 transition-all active:scale-[0.98]">
                Explore All Tools
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    const setupFiltering = () => {
      const pills = document.querySelectorAll('.category-pill');
      const cards = document.querySelectorAll('.tool-card');
      const grid = document.getElementById('tools-grid');

      pills.forEach(pill => {
        pill.addEventListener('click', () => {
          const category = pill.getAttribute('data-category');
          
          // Update UI
          pills.forEach(p => {
            p.classList.remove('bg-link', 'text-canvas', 'border-link');
            p.classList.add('bg-canvas', 'text-body', 'border-hairline');
          });
          pill.classList.add('bg-link', 'text-canvas', 'border-link');
          pill.classList.remove('bg-canvas', 'text-body', 'border-hairline');

          // Filter cards
          cards.forEach(card => {
            const cardCategory = card.getAttribute('data-category');
            if (category === 'All' || cardCategory === category) {
              (card as HTMLElement).style.display = 'block';
            } else {
              (card as HTMLElement).style.display = 'none';
            }
          });

          // Smooth scroll to tools grid if not in view
          const rect = grid?.getBoundingClientRect();
          if (rect && (rect.top < 0 || rect.top > window.innerHeight)) {
            grid?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });

      // Initial state: Set "All" as active
      const allPill = Array.from(pills).find(p => p.getAttribute('data-category') === 'All');
      if (allPill) {
        allPill.classList.add('bg-link', 'text-canvas', 'border-link');
        allPill.classList.remove('bg-canvas', 'text-body', 'border-hairline');
      }
    };

    setupFiltering();
    document.addEventListener('astro:after-swap', setupFiltering);
  </script>
</Layout>
