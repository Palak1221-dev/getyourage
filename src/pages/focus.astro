            <div class="relative h-1.5 bg-hairline rounded-full mb-8">
              <!-- Start Label -->
              <div class="absolute -top-5 left-0 text-[10px] font-mono text-mute">${formatDateShort(activeForecastGoal.startDate)}</div>
              <!-- Deadline Label -->
              <div class="absolute -top-5 right-0 text-[10px] font-mono text-mute">${formatDateShort(activeForecastGoal.endDate)} (Deadline)</div>
              
              <!-- Timeline Fill up to Today -->
              <div class="absolute top-0 left-0 h-full bg-body/20 rounded-full" style="width: ${timePct}%"></div>
              
              <!-- Today Indicator Pin -->
              <div class="absolute top-1/2 -translate-y-1/2 flex flex-col items-center" style="left: ${timePct}%">
                <div class="w-3 h-3 rounded-full bg-body border-2 border-canvas shadow-sm"></div>
                <span class="absolute top-4 text-[9px] font-mono text-ink font-bold whitespace-nowrap bg-canvas px-1.5 py-0.5 border border-hairline rounded shadow-sm">Today (${timePct}% of time)</span>
              </div>
