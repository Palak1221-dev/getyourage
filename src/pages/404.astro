---
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
---

<Layout 
  title="Page Not Found - GetYourAge.com" 
  description="The page you are looking for does not exist. Return to GetYourAge.com to calculate your exact age, age difference, and more."
>
  <div class="max-w-[1200px] mx-auto px-4 py-20 md:py-32 flex flex-col items-center justify-center text-center">
    <h1 class="text-6xl md:text-8xl font-bold tracking-tighter text-ink mb-6 leading-none">
      404
    </h1>
    <h2 class="text-2xl md:text-3xl font-bold text-ink mb-4">
      Page Not Found
    </h2>
    <p class="text-lg md:text-xl text-body leading-relaxed max-w-lg mb-10">
      Oops! The page you're looking for doesn't exist, has been moved, or is temporarily unavailable.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto mb-16">
      <a href="/" class="w-full sm:w-auto">
        <Button variant="primary" size="lg" class="w-full shadow-lg shadow-link/20">Back to Home</Button>
      </a>
      <a href="/" class="w-full sm:w-auto">
        <Button variant="secondary" size="lg" class="w-full">Try Age Calculator</Button>
      </a>
    </div>

    <div class="p-6 bg-canvas-soft-2/50 rounded-xl border border-hairline w-full max-w-md">
      <p class="text-sm text-body mb-2">Need help?</p>
      <a href="/faqs" class="text-link hover:text-link-hover font-medium transition-colors">
        Read our Frequently Asked Questions &rarr;
      </a>
    </div>
  </div>
</Layout>
