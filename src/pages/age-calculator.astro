---
import Layout from "../layouts/Layout.astro";
import AgeCalculator from "../components/calculators/AgeCalculator.astro";
import FAQ from "../components/ui/FAQ.astro";

const faqItems = [
  {
    question: "How is my age calculated?",
    answer: "Your age is calculated by finding the difference between your date of birth and the current date. We account for leap years and the varying number of days in each month to provide an exact breakdown in years, months, and days."
  },
  {
    question: "Is this age calculator accurate?",
    answer: "Yes, our age calculator uses precise date logic to ensure accuracy. It handles all calendar complexities, including leap years, to give you the most reliable result."
  },
  {
    question: "Does it track seconds in real-time?",
    answer: "Our advanced calculator provides your age down to the exact second at the time of calculation, giving you a unique perspective on the math of your life."
  }
];
---

<Layout 
  title="Exact Age Calculator - Calculate Your Age in Years, Months, Days" 
  description="Free, fast, and accurate age calculator. Calculate your exact age in years, months, days, weeks, and seconds instantly."
>
  <!-- Hero Section -->
  <section class="w-full pt-4 lg:pt-8 pb-6">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-[1fr,460px] gap-6 lg:gap-16 items-start">
        <div class="text-center lg:text-left lg:pt-2">
          <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-6xl font-bold tracking-tighter text-ink mb-3 leading-[1.1]">
            Calculate Your Exact Age
          </h1>
          <p class="text-base md:text-lg text-body leading-relaxed max-w-lg mx-auto lg:mx-0 mb-6">
            Calculate your exact age in years, months, days, weeks, and seconds instantly.
          </p>
          
          <!-- Trust Signals Desktop -->
          <div class="hidden lg:flex items-center gap-8 text-[12px] font-bold text-mute uppercase tracking-[0.2em]">
            <div class="flex items-center gap-2 group">
              <div class="p-2 rounded-full bg-link/5 group-hover:bg-link/10 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-link"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </div>
              Privacy First
            </div>
            <div class="flex items-center gap-2 group">
              <div class="p-2 rounded-full bg-link/5 group-hover:bg-link/10 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-link"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg>
              </div>
              Instant Results
            </div>
            <div class="flex items-center gap-2 group">
              <div class="p-2 rounded-full bg-link/5 group-hover:bg-link/10 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="text-link"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>
              </div>
              100% Free
            </div>
          </div>
        </div>

        <div class="w-full">
          <AgeCalculator />
          
          <!-- Trust Signals Mobile -->
          <div class="flex lg:hidden flex-wrap justify-center gap-4 mt-6 text-[10px] font-bold text-mute uppercase tracking-widest">
            <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg> Privacy First</span>
            <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/></svg> Instant</span>
            <span class="flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg> Free</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature Grid -->
  <section class="w-full py-24 bg-canvas-soft-2/50 border-y border-hairline">
    <div class="max-w-[1200px] mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="p-6 sm:p-8 bg-canvas border border-hairline rounded-xl sm:rounded-lg card-shadow">
        <h3 class="text-lg font-bold text-ink mb-3">Millisecond Precision</h3>
        <p class="text-sm text-body leading-relaxed">
          We calculate your age down to the second, so you know exactly how much life you've lived.
        </p>
      </div>
      <div class="p-6 sm:p-8 bg-canvas border border-hairline rounded-xl sm:rounded-lg card-shadow">
        <h3 class="text-lg font-bold text-ink mb-3">Privacy Friendly</h3>
        <p class="text-sm text-body leading-relaxed">
          Your birth date is processed locally in your browser. We never store or share your personal data.
        </p>
      </div>
      <div class="p-6 sm:p-8 bg-canvas border border-hairline rounded-xl sm:rounded-lg card-shadow">
        <h3 class="text-lg font-bold text-ink mb-3">Easy Sharing</h3>
        <p class="text-sm text-body leading-relaxed">
          Found a fun milestone? Copy your results or share a unique link with friends and family instantly.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="w-full py-24">
    <div class="max-w-[800px] mx-auto px-6">
      <FAQ items={faqItems} />
    </div>
  </section>
</Layout>
