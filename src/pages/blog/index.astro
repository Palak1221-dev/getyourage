---
import { getCollection } from 'astro:content';
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/ui/Card.astro";

const posts = await getCollection('blog');

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Tooltails Blog",
  "description": "Insights, tips, and fun facts about age, time, writing, readability, and productivity.",
  "url": Astro.url.origin + "/blog",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": posts.map((post, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": Astro.url.origin + "/blog/" + post.id
    }))
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Tooltails", "item": "https://tooltails.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://tooltails.com/blog" }
  ]
};
---

<Layout title="Blog - Tooltails.com" description="Insights, tips, and fun facts about age, time, writing, readability, and productivity. Learn how to calculate exact age, improve readability, and master word counts.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-24">
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-ink mb-6">
        Latest from our Blog <span class="text-primary text-6xl">.</span>
      </h1>
      <p class="text-lg md:text-xl text-body leading-relaxed">
        Insights, tips, and fun facts about age, time, writing, readability, and productivity.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="group">
          <Card elevation="sm" class="h-full group-hover:card-shadow-lg transition-all">
            <h2 class="text-xl font-bold text-ink mb-3 group-hover:text-primary transition-colors">{post.data.title}</h2>
            <p class="text-sm text-body line-clamp-3 mb-4">{post.data.description}</p>
            <div class="mt-auto pt-4 border-t border-hairline flex justify-between items-center text-xs font-mono text-mute">
              <span>{post.data.pubDate.toLocaleDateString()}</span>
              <span class="text-primary group-hover:translate-x-1 transition-transform">Read More &rarr;</span>
            </div>
          </Card>
        </a>
      ))}
    </div>
  </div>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(collectionSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>
