---
import Layout from "../../layouts/Layout.astro";

export interface Props {
  type: "privacy" | "terms";
  siteTitle: string;
  pageTitle: string;
  pageDescription: string;
  lastUpdated: string;
  sections: { id: string; title: string }[];
  summaryItems: { text: string }[];
  faqItems: { question: string; answer: string }[];
  productName: string;
  productUrl: string;
  backPath: string;
  breadcrumbItems: { name: string; item: string }[];
}

const {
  type,
  siteTitle,
  pageTitle,
  pageDescription,
  lastUpdated,
  sections,
  summaryItems,
  faqItems,
  productName,
  productUrl,
  backPath,
  breadcrumbItems,
} = Astro.props;

const label = type === "privacy" ? "Privacy Policy" : "Terms of Service";
const wordCount = sections.reduce((acc, s) => acc + s.title.split(" ").length, 0) * 50;
const readingTime = Math.max(1, Math.ceil(wordCount / 200)) + " min read";

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  description: pageDescription,
  url: Astro.url.origin + backPath,
  mainEntityOfPage: { "@type": "WebPage", "@id": Astro.url.origin + backPath },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.name,
    item: item.item,
  })),
};

const faqSchema = faqItems.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqItems.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    }
  : null;
---

<Layout title={pageTitle} description={pageDescription}>
  <div class="min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
      <!-- Hero -->
      <div class="mb-10 md:mb-14">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-link/10 text-link mb-4">
          {label}
        </span>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-ink mb-4">{pageTitle}</h1>
        <p class="text-base md:text-lg text-body max-w-2xl leading-relaxed">{pageDescription}</p>
        <div class="flex items-center gap-3 mt-4 text-xs sm:text-sm text-mute">
          <span>Last updated: {lastUpdated}</span>
          <span class="w-1 h-1 rounded-full bg-hairline" aria-hidden="true"></span>
          <span>{readingTime}</span>
        </div>
      </div>

      <!-- Summary Card -->
      <div class="bg-canvas rounded-2xl border border-hairline card-shadow p-6 md:p-8 mb-12 md:mb-16">
        <h2 class="text-sm font-semibold text-mute uppercase tracking-wider mb-4">
          {type === "privacy" ? "Privacy at a glance" : "Terms at a glance"}
        </h2>
        <ul class="space-y-3">
          {summaryItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-link shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
              </svg>
              <span class="text-sm sm:text-base text-body">{item.text}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Content with TOC -->
      <div class="lg:grid lg:grid-cols-[220px_1fr] lg:gap-10 xl:gap-16">
        <!-- Sidebar TOC -->
        <nav class="lg:sticky lg:top-24 lg:self-start lg:max-h-[calc(100vh-8rem)] lg:overflow-y-auto mb-8 lg:mb-0" aria-label="Section navigation">
          <h3 class="text-xs font-semibold text-mute uppercase tracking-wider mb-3 hidden lg:block">On this page</h3>
          <div class="flex lg:flex-col gap-1 overflow-x-auto lg:overflow-x-visible pb-2 lg:pb-0 -mx-4 px-4 lg:mx-0 lg:px-0 scrollbar-none">
            {sections.map((section) => (
              <a
                href={"#" + section.id}
                class="toc-link text-sm text-body/70 hover:text-link whitespace-nowrap lg:whitespace-normal py-1.5 px-2.5 lg:px-3 rounded-lg transition-colors hover:bg-link/5 shrink-0"
              >
                {section.title}
              </a>
            ))}
          </div>
        </nav>

        <!-- Content -->
        <div class="min-w-0">
          <slot />

          <!-- FAQ -->
          {faqItems.length > 0 && (
            <div class="mt-16 pt-12 border-t border-hairline" id="faq">
              <h2 class="text-2xl font-bold text-ink mb-8">Frequently asked questions</h2>
              <div class="space-y-3">
                {faqItems.map((faq) => (
                  <details class="group bg-canvas rounded-xl border border-hairline card-shadow overflow-hidden">
                    <summary class="flex items-center justify-between gap-4 px-5 py-4 cursor-pointer text-sm font-medium text-ink hover:text-link transition-colors list-none">
                      {faq.question}
                      <svg class="w-4 h-4 text-mute shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                      </svg>
                    </summary>
                    <div class="px-5 pb-4 pt-0">
                      <p class="text-sm text-body leading-relaxed">{faq.answer}</p>
                    </div>
                  </details>
                ))}
              </div>
            </div>
          )}

          <!-- Contact Card -->
          <div class="mt-10 bg-canvas rounded-2xl border border-hairline card-shadow p-6 md:p-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <div>
              <h3 class="text-sm font-semibold text-ink mb-1">Still have questions?</h3>
              <p class="text-sm text-mute">We are happy to help. Reach out to our team.</p>
            </div>
            <a
              href={productUrl + "/contact"}
              class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-link text-white text-sm font-medium hover:bg-link-hover transition-colors shrink-0"
            >
              Contact us
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>

          <!-- Back link -->
          <div class="mt-8">
            <a href={backPath} class="inline-flex items-center gap-1.5 text-sm text-link hover:text-link-hover transition-colors font-medium">
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
              </svg>
              Back to {productName}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(webPageSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />}

  <script is:inline>
    (function() {
      var links = document.querySelectorAll('.toc-link');
      var sections = [];
      links.forEach(function(link) {
        var id = link.getAttribute('href').slice(1);
        var el = document.getElementById(id);
        if (el) sections.push({ el: el, link: link });
      });
      links.forEach(function(link) {
        link.addEventListener('click', function(e) {
          var target = document.getElementById(this.getAttribute('href').slice(1));
          if (target) {
            e.preventDefault();
            var top = target.getBoundingClientRect().top + window.scrollY - 100;
            window.scrollTo({ top: top, behavior: 'smooth' });
            history.pushState(null, '', this.getAttribute('href'));
          }
        });
      });
      if (sections.length > 0 && 'IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              links.forEach(function(l) { l.classList.remove('text-link', 'bg-link/10'); l.classList.add('text-body/70'); });
              var activeLink = document.querySelector('.toc-link[href="#' + entry.target.id + '"]');
              if (activeLink) { activeLink.classList.remove('text-body/70'); activeLink.classList.add('text-link', 'bg-link/10'); }
            }
          });
        }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
        sections.forEach(function(s) { observer.observe(s.el); });
      }
    })();
  </script>
</Layout>
