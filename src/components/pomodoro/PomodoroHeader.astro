---
export interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<a
  href="/pomodoro-timer"
  class={className ?? "inline-flex items-center gap-1 text-xs font-semibold text-link hover:text-link-hover transition-colors mb-1"}
>
  <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
  Pomodoro
</a>
