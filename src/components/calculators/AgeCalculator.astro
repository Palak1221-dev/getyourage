---
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";
import Input from "../ui/Input.astro";
---

<Card elevation="lg" padding="md" class="w-full shadow-2xl ring-1 ring-hairline">
  <form id="age-form" class="space-y-3">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <Input label="Day" type="number" id="dob-day" placeholder="01" min="1" max="31" required />
      <Input label="Month" type="number" id="dob-month" placeholder="01" min="1" max="12" required />
      <Input label="Year" type="number" id="dob-year" placeholder="1995" min={new Date().getFullYear() - 130} max={new Date().getFullYear()} required />
    </div>

    <div class="flex flex-col sm:flex-row gap-4">
      <Button type="submit" class="flex-grow shadow-lg shadow-link/20">Calculate My Exact Age</Button>
      <Button variant="secondary" id="reset-btn">Reset</Button>
    </div>
  </form>

  <div id="result-container" class="mt-12 hidden space-y-10 animate-in fade-in slide-in-from-bottom-4 duration-700 scroll-mt-24">
    <!-- Primary Result -->
    <div class="text-center">
      <h3 class="text-mute font-mono text-[10px] uppercase tracking-[0.2em] mb-4">Your Exact Age</h3>
      <div class="flex flex-wrap justify-center items-baseline gap-x-4 gap-y-2">
        <div class="flex items-baseline gap-1">
          <span id="res-years" class="text-6xl md:text-7xl font-bold tracking-tighter text-link leading-none">0</span>
          <span class="text-lg font-medium text-mute">yrs</span>
        </div>
        <div class="flex items-baseline gap-1">
          <span id="res-months" class="text-6xl md:text-7xl font-bold tracking-tighter text-ink leading-none">0</span>
          <span class="text-lg font-medium text-mute">mos</span>
        </div>
        <div class="flex items-baseline gap-1">
          <span id="res-days" class="text-6xl md:text-7xl font-bold tracking-tighter text-ink leading-none">0</span>
          <span class="text-lg font-medium text-mute">days</span>
        </div>
      </div>
    </div>

    <!-- Granular Statistics -->
    <div class="space-y-4">
      <h4 class="text-xs font-bold text-ink uppercase tracking-wider">Life Statistics</h4>
      <div class="grid grid-cols-2 md:grid-cols-2 gap-3">
        <div class="p-4 bg-canvas-soft-2/50 rounded-xl border border-hairline group hover:border-link transition-colors">
          <span class="block text-[10px] font-mono text-mute uppercase mb-1 tracking-wider">Total Days</span>
          <span id="res-total-days" class="text-xl font-bold text-link tracking-tight">0</span>
        </div>
        <div class="p-4 bg-canvas-soft-2/50 rounded-xl border border-hairline group hover:border-link transition-colors">
          <span class="block text-[10px] font-mono text-mute uppercase mb-1 tracking-wider">Total Weeks</span>
          <span id="res-total-weeks" class="text-xl font-bold text-link tracking-tight">0</span>
        </div>
        <div class="p-4 bg-canvas-soft-2/50 rounded-xl border border-hairline group hover:border-link transition-colors">
          <span class="block text-[10px] font-mono text-mute uppercase mb-1 tracking-wider">Total Hours</span>
          <span id="res-total-hours" class="text-xl font-bold text-link tracking-tight">0</span>
        </div>
        <div class="p-4 bg-canvas-soft-2/50 rounded-xl border border-hairline group hover:border-link transition-colors">
          <span class="block text-[10px] font-mono text-mute uppercase mb-1 tracking-wider">Total Seconds</span>
          <span id="res-total-seconds" class="text-xl font-bold text-link tracking-tight">0</span>
        </div>
      </div>
    </div>

    <!-- Fun Facts / Next Milestone -->
    <div class="p-5 bg-link/5 rounded-xl border border-link/10">
      <h4 class="text-xs font-bold text-link uppercase tracking-wider mb-3">Upcoming Milestone</h4>
      <div class="flex justify-between items-center">
        <div>
          <p class="text-sm text-body leading-tight">Next Birthday in <span id="res-next-days" class="font-bold text-link">0</span> days</p>
          <p class="text-[11px] text-mute mt-1">Turning <span id="res-next-age" class="font-bold text-link">0</span> on a <span id="res-next-weekday" class="font-bold text-link">-</span></p>
        </div>
        <div id="res-progress-circle" class="relative w-12 h-12 flex items-center justify-center">
            <svg class="w-full h-full -rotate-90">
                <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="4" fill="transparent" class="text-link/10" />
                <circle id="res-progress-bar" cx="24" cy="24" r="20" stroke="currentColor" stroke-width="4" fill="transparent" stroke-dasharray="125.6" stroke-dashoffset="125.6" class="text-link transition-all duration-1000" />
            </svg>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-3">
      <Button variant="secondary" size="md" id="copy-btn" class="flex-grow gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
        Copy Results
      </Button>
      <Button variant="secondary" size="md" id="share-btn" class="flex-grow gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" x2="12" y1="2" y2="15"/></svg>
        Share Link
      </Button>
    </div>
  </div>
</Card>

<script>
  import { calculateAge, getNextBirthdayCountdown } from "../../utils/dateUtils";
  import { validateBirthDate } from "../../utils/formValidation";
  import { copyToClipboard } from "../../utils/clipboard";
  import { getQueryParams, setQueryParams } from "../../utils/seoUtils";

  const form = document.getElementById('age-form') as HTMLFormElement;
  const resultContainer = document.getElementById('result-container');
  const resYears = document.getElementById('res-years');
  const resMonths = document.getElementById('res-months');
  const resDays = document.getElementById('res-days');
  const resTotalWeeks = document.getElementById('res-total-weeks');
  const resTotalDays = document.getElementById('res-total-days');
  const resTotalHours = document.getElementById('res-total-hours');
  const resTotalSeconds = document.getElementById('res-total-seconds');
  
  const resNextDays = document.getElementById('res-next-days');
  const resNextAge = document.getElementById('res-next-age');
  const resNextWeekday = document.getElementById('res-next-weekday');
  const resProgressBar = document.getElementById('res-progress-bar') as unknown as SVGCircleElement;

  const dobDay = document.getElementById('dob-day') as HTMLInputElement;
  const dobMonth = document.getElementById('dob-month') as HTMLInputElement;
  const dobYear = document.getElementById('dob-year') as HTMLInputElement;

  const updateUI = () => {
    const day = parseInt(dobDay.value);
    const month = parseInt(dobMonth.value);
    const year = parseInt(dobYear.value);

    const error = validateBirthDate(year, month, day);
    if (error) return;

    const dob = new Date(year, month - 1, day);
    const result = calculateAge(dob);
    const countdown = getNextBirthdayCountdown(dob);

    if (resYears) resYears.textContent = result.years.toString();
    if (resMonths) resMonths.textContent = result.months.toString();
    if (resDays) resDays.textContent = result.days.toString();
    if (resTotalWeeks) resTotalWeeks.textContent = result.totalWeeks.toLocaleString();
    if (resTotalDays) resTotalDays.textContent = result.totalDays.toLocaleString();
    if (resTotalHours) resTotalHours.textContent = result.totalHours.toLocaleString();
    if (resTotalSeconds) resTotalSeconds.textContent = result.totalSeconds.toLocaleString();

    if (resNextDays) resNextDays.textContent = countdown.days.toString();
    if (resNextAge) resNextAge.textContent = countdown.ageOnNextBirthday.toString();
    if (resNextWeekday) resNextWeekday.textContent = countdown.weekday;

    // Progress bar (365 days base)
    if (resProgressBar) {
        const progress = (365 - countdown.days) / 365;
        const offset = 125.6 * (1 - progress);
        resProgressBar.style.strokeDashoffset = offset.toString();
    }

    resultContainer?.classList.remove('hidden');
    resultContainer?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    
    setQueryParams({ d: day.toString(), m: month.toString(), y: year.toString() });
  };

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    updateUI();
  });

  document.getElementById('reset-btn')?.addEventListener('click', () => {
    form.reset();
    resultContainer?.classList.add('hidden');
    setQueryParams({ d: '', m: '', y: '' });
  });

  document.getElementById('copy-btn')?.addEventListener('click', () => {
    const text = `I am ${resYears?.textContent} years, ${resMonths?.textContent} months, and ${resDays?.textContent} days old! Calculated on Tooltails.com`;
    copyToClipboard(text).then(success => {
      if (success) {
        const btn = document.getElementById('copy-btn');
        if (btn) {
          const original = btn.innerHTML;
          btn.innerHTML = 'Copied!';
          setTimeout(() => btn.innerHTML = original, 2000);
        }
      }
    });
  });

  document.getElementById('share-btn')?.addEventListener('click', () => {
    copyToClipboard(window.location.href).then(success => {
      if (success) {
        const btn = document.getElementById('share-btn');
        if (btn) {
          const original = btn.innerHTML;
          btn.innerHTML = 'Link Copied!';
          setTimeout(() => btn.innerHTML = original, 2000);
        }
      }
    });
  });

  const params = getQueryParams();
  if (params.d && params.m && params.y) {
    dobDay.value = params.d;
    dobMonth.value = params.m;
    dobYear.value = params.y;
    updateUI();
  }
</script>
