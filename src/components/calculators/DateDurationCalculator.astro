---
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";
import Input from "../ui/Input.astro";
---

<Card elevation="lg" padding="xl" class="max-w-2xl mx-auto">
  <form id="duration-form" class="space-y-8">
    <div class="space-y-4">
      <h3 class="text-sm font-mono uppercase tracking-widest text-mute">Start Date</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <Input label="Day" type="number" id="s-day" placeholder="01" min="1" max="31" required />
        <Input label="Month" type="number" id="s-month" placeholder="01" min="1" max="12" required />
        <Input label="Year" type="number" id="s-year" placeholder="1995" min={new Date().getFullYear() - 130} required />
      </div>
    </div>

    <div class="space-y-4">
      <h3 class="text-sm font-mono uppercase tracking-widest text-mute">End Date</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <Input label="Day" type="number" id="e-day" placeholder="01" min="1" max="31" required />
        <Input label="Month" type="number" id="e-month" placeholder="01" min="1" max="12" required />
        <Input label="Year" type="number" id="e-year" placeholder="1995" min="1900" required />
      </div>
    </div>

    <div class="flex flex-col sm:flex-row gap-4 pt-4">
      <Button type="submit" class="flex-grow shadow-lg shadow-link/20">Calculate Duration</Button>
      <Button variant="secondary" id="reset-btn">Reset</Button>
    </div>
  </form>

  <div id="result-container" class="mt-12 hidden space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500 scroll-mt-24">
    <div class="text-center">
      <h3 class="text-mute font-mono text-xs uppercase tracking-widest mb-2">The duration is</h3>
      <div class="flex flex-wrap justify-center items-baseline gap-2">
        <span id="res-years" class="text-6xl font-bold tracking-tighter text-link">0</span>
        <span class="text-2xl font-semibold text-body">years</span>
        <span id="res-months" class="text-6xl font-bold tracking-tighter text-link">0</span>
        <span class="text-2xl font-semibold text-body">months</span>
        <span id="res-days" class="text-6xl font-bold tracking-tighter text-link">0</span>
        <span class="text-2xl font-semibold text-body">days</span>
      </div>
    </div>
  </div>
</Card>

<script>
  import { calculateAge } from "../../utils/dateUtils";
  import { setQueryParams, getQueryParams } from "../../utils/seoUtils";

  const form = document.getElementById('duration-form') as HTMLFormElement;
  const resultContainer = document.getElementById('result-container');
  const resYears = document.getElementById('res-years');
  const resMonths = document.getElementById('res-months');
  const resDays = document.getElementById('res-days');

  const updateUI = () => {
    const s = {
      d: parseInt((document.getElementById('s-day') as HTMLInputElement).value),
      m: parseInt((document.getElementById('s-month') as HTMLInputElement).value),
      y: parseInt((document.getElementById('s-year') as HTMLInputElement).value)
    };
    const e = {
      d: parseInt((document.getElementById('e-day') as HTMLInputElement).value),
      m: parseInt((document.getElementById('e-month') as HTMLInputElement).value),
      y: parseInt((document.getElementById('e-year') as HTMLInputElement).value)
    };

    const start = new Date(s.y, s.m - 1, s.d);
    const end = new Date(e.y, e.m - 1, e.d);
    const [earlier, later] = start < end ? [start, end] : [end, start];

    const result = calculateAge(earlier, later);

    if (resYears) resYears.textContent = result.years.toString();
    if (resMonths) resMonths.textContent = result.months.toString();
    if (resDays) resDays.textContent = result.days.toString();

    resultContainer?.classList.remove('hidden');

    setQueryParams({ 
      sd: s.d.toString(), sm: s.m.toString(), sy: s.y.toString(),
      ed: e.d.toString(), em: e.m.toString(), ey: e.y.toString()
    });
  };

  form.addEventListener('submit', (ev) => {
    ev.preventDefault();
    updateUI();
  });

  document.getElementById('reset-btn')?.addEventListener('click', () => {
    form.reset();
    resultContainer?.classList.add('hidden');
    setQueryParams({ 
      sd: '', sm: '', sy: '',
      ed: '', em: '', ey: ''
    });
  });

  const params = getQueryParams();
  if (params.sy && params.ey) {
    (document.getElementById('s-day') as HTMLInputElement).value = params.sd;
    (document.getElementById('s-month') as HTMLInputElement).value = params.sm;
    (document.getElementById('s-year') as HTMLInputElement).value = params.sy;
    (document.getElementById('e-day') as HTMLInputElement).value = params.ed;
    (document.getElementById('e-month') as HTMLInputElement).value = params.em;
    (document.getElementById('e-year') as HTMLInputElement).value = params.ey;
    updateUI();
  }
</script>
