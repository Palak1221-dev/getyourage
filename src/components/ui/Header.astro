---
import Button from "./Button.astro";
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname;

// Helper to check if a link is active
const isActive = (path: string) => {
  if (path === "/") return currentPath === "/";
  // Remove trailing slashes for comparison
  const normalizedPath = path.replace(/\/$/, "");
  const normalizedCurrent = currentPath.replace(/\/$/, "");
  return normalizedCurrent === normalizedPath;
};

const toolItems = [
  { href: "/age-calculator", label: "Age Calculator" },
  { href: "/age-difference", label: "Age Difference Calculator" },
  { href: "/birthday-countdown", label: "Birthday Countdown" },
  { href: "/duration", label: "Duration Calculator" },
  { href: "/future-age", label: "Future Age Calculator" },
  { href: "/pomodoro-timer", label: "Pomodoro Timer" },
  { href: "/focus", label: "Focus Goals Timer" },
  { href: "/word-counter", label: "Word Counter" }
];

const isToolActive = toolItems.some(item => isActive(item.href));
---

<header class="sticky top-0 z-50 w-full bg-canvas/80 backdrop-blur-md border-b border-hairline h-14 transition-all duration-300">
  <div class="max-w-[1440px] mx-auto h-full px-4 md:px-6 lg:px-8 flex items-center justify-between">
    <div class="flex items-center gap-4 lg:gap-8">
      <a href="/" class="flex items-center gap-2 group shrink-0">
        <span class="text-xl font-bold tracking-tight text-ink group-hover:text-link transition-colors">
          Tooltails
        </span>
      </a>
      
      <nav aria-label="Main navigation" class="hidden xl:flex items-center gap-1">
        <!-- Tools Dropdown -->
        <div class="relative group" id="tools-dropdown">
          <button 
            class:list={[
              "px-3 py-1.5 text-[13px] font-medium transition-all rounded-full whitespace-nowrap flex items-center gap-1 group-hover:bg-canvas-soft-2",
              isToolActive ? "text-link bg-link/10" : "text-body hover:text-ink"
            ]}
            aria-haspopup="true"
            aria-expanded="false"
          >
            Tools
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:rotate-180" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          
          <div class="absolute top-full left-0 pt-2 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-200 z-50">
            <div class="w-64 bg-canvas border border-hairline rounded-xl shadow-2xl p-1.5">
              {toolItems.map(item => (
                <a 
                  href={item.href} 
                  class:list={[
                    "flex items-center justify-between px-3 py-2 text-[13px] font-medium transition-all rounded-lg", 
                    isActive(item.href) 
                      ? "text-link bg-link/5" 
                      : "text-body hover:text-ink hover:bg-canvas-soft-2"
                  ]}
                >
                  {item.label}
                  {isActive(item.href) && <span class="w-1.5 h-1.5 rounded-full bg-link"></span>}
                </a>
              ))}
            </div>
          </div>
        </div>

        <a 
          href="/about" 
          class:list={[
            "px-3 py-1.5 text-[13px] font-medium transition-all rounded-full whitespace-nowrap", 
            isActive("/about") 
              ? "text-link bg-link/10" 
              : "text-body hover:text-ink hover:bg-canvas-soft-2"
          ]}
        >
          About
        </a>
        <a 
          href="/blog" 
          class:list={[
            "px-3 py-1.5 text-[13px] font-medium transition-all rounded-full whitespace-nowrap", 
            isActive("/blog") || currentPath.startsWith("/blog/") 
              ? "text-link bg-link/10" 
              : "text-body hover:text-ink hover:bg-canvas-soft-2"
          ]}
        >
          Blog
        </a>
      </nav>
    </div>

    <div class="flex items-center gap-2">
      <ThemeToggle />
      
      <button id="mobile-menu-btn" class="xl:hidden p-2 text-body hover:text-ink rounded-md hover:bg-canvas-soft-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-link/40 transition-colors" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="menu-icon" aria-hidden="true">
          <line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/>
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="close-icon hidden" aria-hidden="true">
          <line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden absolute top-14 left-0 w-full bg-canvas border-b border-hairline shadow-2xl xl:hidden max-h-[calc(100vh-56px)] overflow-y-auto" style="overscroll-behavior: contain" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <nav aria-label="Mobile navigation" class="flex flex-col px-4 py-4 space-y-1">
      <!-- Mobile Tools Section -->
      <div class="py-2">
        <div class="px-4 py-2 text-[11px] font-bold text-mute uppercase tracking-widest">
          Tools
        </div>
        <div class="flex flex-col gap-0.5 mt-1">
          {toolItems.map(item => (
            <a 
              href={item.href} 
              class:list={[
                "px-4 py-3 text-sm font-medium transition-all rounded-md mobile-link flex items-center justify-between pl-8", 
                isActive(item.href) 
                  ? "text-link bg-link/5" 
                  : "text-body hover:text-ink hover:bg-canvas-soft-2"
              ]}
            >
              {item.label}
              {isActive(item.href) && <span class="w-1.5 h-1.5 rounded-full bg-link"></span>}
            </a>
          ))}
        </div>
      </div>

      <a 
        href="/about" 
        class:list={[
          "px-4 py-3 text-sm font-medium transition-all rounded-md mobile-link flex items-center justify-between", 
          isActive("/about") ? "text-link bg-link/5" : "text-body hover:text-ink hover:bg-canvas-soft-2"
        ]}
      >
        About
        {isActive("/about") && <span class="w-1.5 h-1.5 rounded-full bg-link"></span>}
      </a>
      <a 
        href="/blog" 
        class:list={[
          "px-4 py-3 text-sm font-medium transition-all rounded-md mobile-link flex items-center justify-between", 
          isActive("/blog") || currentPath.startsWith("/blog/") ? "text-link bg-link/5" : "text-body hover:text-ink hover:bg-canvas-soft-2"
        ]}
      >
        Blog
        {(isActive("/blog") || currentPath.startsWith("/blog/")) && <span class="w-1.5 h-1.5 rounded-full bg-link"></span>}
      </a>
    </nav>
  </div>
</header>

<script>
  // State and shared logic defined outside to persist across astro:after-swap if needed,
  // but we mostly want to avoid listener accumulation on 'document'.
  
  const setupMobileMenu = () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const menuIcon = document.querySelector('.menu-icon');
    const closeIcon = document.querySelector('.close-icon');
    const links = document.querySelectorAll('.mobile-link');

    if (!btn || !menu) return;

    const toggleMenu = (show?: boolean) => {
      const shouldShow = show !== undefined ? show : menu.classList.contains('hidden');
      
      if (shouldShow) {
        menu.classList.remove('hidden');
        menuIcon?.classList.add('hidden');
        closeIcon?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      } else {
        menu.classList.add('hidden');
        menuIcon?.classList.remove('hidden');
        closeIcon?.classList.add('hidden');
        document.body.style.overflow = '';
      }
    };

    // Toggle on button click
    btn.onclick = (e) => {
      e.stopPropagation();
      toggleMenu();
    };

    // Close on link click
    links.forEach(link => {
      (link as HTMLElement).onclick = () => {
        toggleMenu(false);
      };
    });

    // We use a shared document listener to avoid accumulation.
    // We attach it only once.
    if (!(window as any).tooltailsMobileMenuInitialized) {
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          const currentMenu = document.getElementById('mobile-menu');
          const currentBtn = document.getElementById('mobile-menu-btn');
          if (currentMenu && !currentMenu.classList.contains('hidden')) {
            currentMenu.classList.add('hidden');
            document.querySelector('.menu-icon')?.classList.remove('hidden');
            document.querySelector('.close-icon')?.classList.add('hidden');
            document.body.style.overflow = '';
            currentBtn?.focus();
          }
        }
      });
      document.addEventListener('click', (e) => {
        const currentBtn = document.getElementById('mobile-menu-btn');
        const currentMenu = document.getElementById('mobile-menu');
        
        if (!currentBtn || !currentMenu || currentMenu.classList.contains('hidden')) return;
        
        if (!currentMenu.contains(e.target as Node) && !currentBtn.contains(e.target as Node)) {
          // Close the menu
          currentMenu.classList.add('hidden');
          document.querySelector('.menu-icon')?.classList.remove('hidden');
          document.querySelector('.close-icon')?.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });
      (window as any).tooltailsMobileMenuInitialized = true;
    }
  };

  // Run on initial load
  setupMobileMenu();

  // Run on view transitions
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>

<style>
  header {
    /* Ensure the backdrop blur works well with the border */
    border-bottom-width: 1px;
  }
  
  /* Smooth transitions for links */
  nav a, button {
    transition: background-color 0.2s cubic-bezier(0.4, 0, 0.2, 1), color 0.2s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1), transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
