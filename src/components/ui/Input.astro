---
interface Props {
  label?: string;
  type?: 'text' | 'number' | 'date' | 'email';
  placeholder?: string;
  name?: string;
  id?: string;
  value?: string | number;
  min?: string | number;
  max?: string | number;
  required?: boolean;
  class?: string;
  error?: string;
}

const { 
  label, 
  type = 'text', 
  placeholder, 
  name, 
  id, 
  value,
  min,
  max,
  required,
  class: className,
  error
} = Astro.props;
---

<div class:list={['flex flex-col gap-1.5', className]}>
  {label && (
    <label for={id} class="text-sm font-medium text-ink">
      {label}
    </label>
  )}
  <input
    type={type}
    id={id}
    name={name}
    placeholder={placeholder}
    value={value}
    min={min}
    max={max}
    required={required}
    class:list={[
      'w-full h-10 px-3 bg-canvas border border-hairline rounded-sm text-sm text-ink placeholder:text-mute transition-all',
      'focus:outline-none focus:border-link focus:ring-2 focus:ring-link/10',
      error ? 'border-error ring-2 ring-error/10' : ''
    ]}
  />
  {error && <span class="text-xs text-error font-medium">{error}</span>}
</div>
