---
const currentYear = new Date().getFullYear();
---

<footer class="bg-canvas border-t border-hairline py-12 md:py-24">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="text-xl font-bold tracking-tighter text-ink mb-4 inline-block">
          Tooltails<span class="text-primary">.com</span>
        </a>
        <p class="text-sm text-body leading-relaxed max-w-xs">
          Tooltails is a collection of free online calculators and utility tools designed to simplify everyday tasks.
        </p>
      </div>
      
      <div>
        <h4 class="text-xs font-mono uppercase tracking-widest text-mute mb-4">Popular Tools</h4>
        <ul class="space-y-2">
          <li><a href="/word-counter" class="text-sm text-body hover:text-ink transition-colors">Word Counter</a></li>
          <li><a href="/age-calculator" class="text-sm text-body hover:text-ink transition-colors">Age Calculator</a></li>
          <li><a href="/age-difference" class="text-sm text-body hover:text-ink transition-colors">Age Difference</a></li>
          <li><a href="/birthday-countdown" class="text-sm text-body hover:text-ink transition-colors">Birthday Countdown</a></li>
          <li><a href="/duration" class="text-sm text-body hover:text-ink transition-colors">Date Duration</a></li>
          <li><a href="/future-age" class="text-sm text-body hover:text-ink transition-colors">Future Age</a></li>
          <li><a href="/pomodoro-timer" class="text-sm text-body hover:text-ink transition-colors">Pomodoro Timer</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-mono uppercase tracking-widest text-mute mb-4">Resources</h4>
        <ul class="space-y-2">
          <li><a href="/blog" class="text-sm text-body hover:text-ink transition-colors">Blog</a></li>
          <li><a href="/faqs" class="text-sm text-body hover:text-ink transition-colors">FAQs</a></li>
          <li><a href="/about" class="text-sm text-body hover:text-ink transition-colors">About Us</a></li>
          <li><a href="/contact" class="text-sm text-body hover:text-ink transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-mono uppercase tracking-widest text-mute mb-4">Legal</h4>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-sm text-body hover:text-ink transition-colors">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-body hover:text-ink transition-colors">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-hairline flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="flex flex-col md:flex-row items-center gap-4">
        <p class="text-xs text-mute">
          &copy; {currentYear} Tooltails.com. All rights reserved.
        </p>
        <span class="hidden md:inline text-hairline-strong text-[10px]">•</span>
        <p class="text-[10px] font-medium text-mute uppercase tracking-widest">
          Free online age calculator • Privacy friendly • No signup required
        </p>
      </div>
      <div class="flex gap-6">
        <a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="text-mute hover:text-ink transition-colors"><span class="sr-only">Twitter</span><svg class="h-4 w-4 fill-current" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg></a>
      </div>
    </div>
  </div>
</footer>
